    // Load SystemExtraFields for spools and add as dynamic column group
    async function loadSpoolExtraFieldColumns() {
      try {
        const res = await fetch('/api/v1/system-extra-fields?target_type=spool', { credentials: 'include', signal: getAbortSignal() })
        if (!res.ok) return
        const fields: any[] = await res.json()
        if (fields.length === 0) return
        const extraGroup: ColumnGroup = {
          heading: t('common.columnsExtraFields'),
          columns: fields.map(f => ({ key: `cf_${f.key}`, label: f.label })),
        }
        splPicker.updateGroups([...splColumnGroups, extraGroup])
        // Add dynamic <th> headers for extra fields
        const headerRow = document.querySelector('.fm-table thead tr')
        if (headerRow) {
          const lastTh = headerRow.querySelector('th:last-child')
          fields.forEach(f => {
            const th = document.createElement('th')
            th.className = `sortable col-cf_${f.key}`
            th.dataset.sort = `cf_${f.key}`
            th.textContent = f.label
            headerRow.insertBefore(th, lastTh)
          })
        }
        // Store fields for renderSpoolRow access
        ;(window as any).__spoolExtraFields = fields
        // Refresh column reorder to include new extra field columns
        splReorder.refreshColumns()
        splResize.refreshColumns()
      } catch (e) {
