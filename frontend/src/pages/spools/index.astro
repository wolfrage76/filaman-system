        bar.classList.remove('visible')
      }
      // Update select-all checkbox state
      const visibleCheckboxes = document.querySelectorAll('#spools-table input.bulk-checkbox[data-spool-id]')
      const visibleIds = Array.from(visibleCheckboxes).map(cb => Number((cb as HTMLInputElement).dataset.spoolId))
      const allChecked = visibleIds.length > 0 && visibleIds.every(id => selectedSpoolIds.has(id))
      const someChecked = visibleIds.some(id => selectedSpoolIds.has(id))
      selectAllCb.checked = allChecked
      selectAllCb.indeterminate = someChecked && !allChecked
    }

    function toggleSpoolSelection(id: number, checked: boolean) {
