          ${((window as any).__spoolExtraFields || []).map((f: any) => {
            const val = s.custom_fields?.[f.key]
            const display = f.field_type === 'checkbox' ? (val ? '✓' : '✗') : (val ?? '-')
            return `<td class="col-cf_${f.key}" style="padding: 12px; color: var(--text-muted);">${display}</td>`
