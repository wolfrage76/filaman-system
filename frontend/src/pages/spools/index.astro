  async function openFromEmptyModal() {
    selectedEmptySpoolId = null
    fromEmptyTriggerText.textContent = t('common.select') || 'Select...'
    fromEmptyTriggerText.style.opacity = '0.6'
    fromEmptyConfirmBtn.disabled = true
    fromEmptyOptions.textContent = ''
    fromEmptyPanel.style.display = 'none'
    emptySpoolDropdownOpen = false
    fromEmptyNone.style.display = 'none'
    fromEmptyDropdownEl.style.display = ''
    fromEmptyModal.classList.add('open')

    try {
      const signal = getAbortSignal()
      // Reuse already-loaded statuses or fetch if not yet available
      let allStatuses = statuses.length > 0 ? statuses : null
      if (!allStatuses) {
        const statusesRes = await fetch('/api/v1/spools/statuses', { credentials: 'include', signal })
        allStatuses = statusesRes.ok ? await statusesRes.json() : []
      }
      const emptyStatus = (allStatuses as any[]).find((s: any) => s.key === 'empty')
      if (!emptyStatus) {
        fromEmptyNone.style.display = ''
        fromEmptyDropdownEl.style.display = 'none'
        return
      }

      // Load all empty spools with pagination (API limit: 200 per page)
      const firstRes = await fetch(`/api/v1/spools?page=1&page_size=200&status_id=${emptyStatus.id}`, { credentials: 'include', signal })
      if (!firstRes.ok) {
        console.error('Failed to load empty spools:', firstRes.status, firstRes.statusText)
        throw new Error(`HTTP ${firstRes.status}`)
      }
      const firstData = await firstRes.json()
      let emptySpools: any[] = firstData.items || []
      if (firstData.total > 200) {
        const totalPages = Math.ceil(firstData.total / 200)
        const pagePromises = []
        for (let p = 2; p <= totalPages; p++) {
          pagePromises.push(
            fetch(`/api/v1/spools?page=${p}&page_size=200&status_id=${emptyStatus.id}`, { credentials: 'include', signal })
              .then(r => r.ok ? r.json() : null)
              .then(d => d ? d.items : [])
          )
        }
        const additionalPages = await Promise.all(pagePromises)
        additionalPages.forEach(items => { emptySpools = emptySpools.concat(items) })
      }

      if (emptySpools.length === 0) {
        fromEmptyNone.style.display = ''
        fromEmptyDropdownEl.style.display = 'none'
        return
      }

      emptySpools.forEach((s: any) => {
        const filament = s.filament
        const mfg = filament?.manufacturer?.name || ''
        const designation = filament?.designation || ''
        const material = filament?.material_type || ''
        const label = [mfg, designation, material].filter(Boolean).join(' \u00b7 ')

        const opt = document.createElement('div')
        opt.dataset.emptySpoolId = String(s.id)
        opt.dataset.search = `${s.id} ${label}`
        opt.style.cssText = 'display: flex; align-items: center; gap: 8px; padding: 8px 12px; cursor: pointer; font-size: 0.9rem;'

        const idSpan = document.createElement('span')
        idSpan.style.cssText = 'color: var(--text-muted); font-size: 0.8rem; flex-shrink: 0;'
        idSpan.textContent = `#${s.id}`

        const labelSpan = document.createElement('span')
        labelSpan.style.cssText = 'overflow: hidden; text-overflow: ellipsis; white-space: nowrap;'
        labelSpan.textContent = label || '\u2014'

        opt.appendChild(idSpan)
        opt.appendChild(labelSpan)

        opt.addEventListener('mouseenter', () => {
          if (opt.dataset.emptySpoolId !== String(selectedEmptySpoolId)) opt.style.background = 'var(--bg-soft)'
        })
        opt.addEventListener('mouseleave', () => {
          if (opt.dataset.emptySpoolId !== String(selectedEmptySpoolId)) opt.style.background = ''
        })
        opt.addEventListener('click', () => selectEmptySpool(s.id, String(s.id), label || '\u2014'))
        fromEmptyOptions.appendChild(opt)
      })
    } catch (err) {
      if (isAbortError(err)) return
      console.error('Error loading empty spools:', err)
      fromEmptyNone.style.display = ''
      fromEmptyDropdownEl.style.display = 'none'
    }
  }

  fromEmptyTrigger.addEventListener('click', () => {
    if (emptySpoolDropdownOpen) closeEmptyDropdown()
    else openEmptyDropdown()
  })
  fromEmptyTrigger.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault()
      if (emptySpoolDropdownOpen) closeEmptyDropdown()
      else openEmptyDropdown()
    } else if (e.key === 'Escape') {
      closeEmptyDropdown()
    }
  })
  fromEmptySearch.addEventListener('input', (e) => filterEmptyOptions((e.target as HTMLInputElement).value))
  fromEmptySearch.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { closeEmptyDropdown(); fromEmptyTrigger.focus() }
  })
  document.addEventListener('click', (e) => {
    if (emptySpoolDropdownOpen && !fromEmptyDropdownEl.contains(e.target as Node)) closeEmptyDropdown()
  })

  fromEmptyCancelBtn.addEventListener('click', () => fromEmptyModal.classList.remove('open'))
  fromEmptyModal.addEventListener('click', (e) => {
    if (e.target === fromEmptyModal) fromEmptyModal.classList.remove('open')
  })

  fromEmptyConfirmBtn.addEventListener('click', async () => {
    if (!selectedEmptySpoolId) return
    try {
      const res = await fetch(`/api/v1/spools/${selectedEmptySpoolId}`, { credentials: 'include', signal: getAbortSignal() })
      if (!res.ok) return
      const spool = await res.json()
      const payload: Record<string, any> = {}
      if (spool.empty_spool_weight_g != null) payload.empty_spool_weight_g = spool.empty_spool_weight_g
      if (spool.rfid_uid) payload.rfid_uid = spool.rfid_uid
      if (spool.spool_width_mm != null) payload.spool_width_mm = spool.spool_width_mm
      if (spool.spool_outer_diameter_mm != null) payload.spool_outer_diameter_mm = spool.spool_outer_diameter_mm
      if (spool.spool_material) payload.spool_material = spool.spool_material
      if (spool.low_weight_threshold_g != null) payload.low_weight_threshold_g = spool.low_weight_threshold_g
      sessionStorage.setItem('filaman_duplicate_spool', JSON.stringify(payload))
      // Alte leere Spule löschen – sie existiert physisch nicht mehr
      await fetch(`/api/v1/spools/${selectedEmptySpoolId}`, {
        method: 'DELETE',
        headers: { 'X-CSRF-Token': getCsrfToken() },
        credentials: 'include',
        signal: getAbortSignal(),
      })
      window.location.href = '/spools/new'
    } catch (e) {
      if (isAbortError(e)) return
      // ignore — navigation in progress
    }
  })

  document.getElementById('btn-add-from-empty')?.addEventListener('click', openFromEmptyModal)
  </script>
</Layout>
