          <td class="col-id" style="padding: 12px; font-weight: 500;">${t('spools.spoolId', { id: s.id })}</td>
          <td class="col-filament" style="padding: 12px;">${colorDots} ${getFilamentName(s)}</td>
          <td class="col-manufacturer" style="padding: 12px; color: var(--text-muted);">${getManufacturerName(s)}</td>
