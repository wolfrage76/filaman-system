---
import Layout from '../../../layouts/Layout.astro'

export function getStaticPaths() {
  return [
    {params: {id: 'detail'}},
  ];
}

const { id } = Astro.params
const backHref = id === 'detail' ? '/spools' : `/spools/${id}`
---

<Layout title="FilaMan - Edit Spool">
  <div style="margin-bottom: 24px;">
    <a id="back-link" href={backHref} style="color: var(--accent); text-decoration: none;">&larr; <span data-i18n="spools.backToSpools">Back to Spool</span></a>
  </div>
  
  <h1 style="font-size: 1.8rem; font-weight: 700; margin-bottom: 24px; font-family: var(--font-serif);" data-i18n="spools.editSpool">Edit Spool</h1>
  
  <div id="edit-loading">
    <p style="color: var(--text-muted);" data-i18n="common.loading">Loading...</p>
  </div>

  <div id="edit-error" class="hidden">
    <p style="color: var(--error-text);" data-i18n="spools.failedLoadSingle">Failed to load spool</p>
  </div>

  <div id="edit-form-wrapper" class="hidden">
    <div class="fm-card" style="max-width: 720px; padding: 24px;">
      <form id="spool-form" style="display: grid; gap: 16px;">
        
        <!-- Filament -->
        <div>
          <label for="filament_id" class="fm-label" data-i18n="spools.filament">Filament *</label>
          <select 
            id="filament_id" 
            name="filament_id" 
            required
            class="fm-select"
          >
          <option value="" data-i18n="spools.selectFilament">Select filament...</option>
        </select>
      </div>

      <!-- Status -->
      <div>
        <label for="status_id" class="fm-label" data-i18n="spools.status">Status</label>
        <select 
          id="status_id" 
          name="status_id" 
          class="fm-select"
        >
          <option value="">-</option>
        </select>
      </div>

      <!-- Initial Total Weight -->
      <div>
        <label for="initial_total_weight_g" class="fm-label" data-i18n="spools.initialWeight">Initial Total Weight (g)</label>
        <input
          type="number"
          id="initial_total_weight_g"
          name="initial_total_weight_g"
          step="1"
          placeholder="e.g. 1250"
          data-i18n-placeholder="spools.initialWeightPlaceholder"
          class="fm-input"
        />
      </div>

      <!-- Spool Properties -->
      <div class="fm-card" style="padding: 16px; margin-top: 8px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
          <h3 class="fm-label" style="font-size: 1rem; margin: 0; color: var(--text);" data-i18n="common.spoolDefaultSettings">Spool Properties</h3>
          <button type="button" id="btn-spool-profile-lookup" class="fm-btn fm-btn-outline" style="font-size: 0.75rem; padding: 4px 10px;">
            <span data-i18n="filamentdbLookup.loadFromDb">Load from FilaManDB</span>
          </button>
        </div>
        <div id="spool-profile-lookup-section" style="display: none; margin-bottom: 16px;">
          <div id="spool-profile-lookup-container"></div>
          <div id="spool-profile-lookup-toast" class="fdb-toast" style="display: none;"></div>
        </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div>
              <label for="empty_spool_weight_g" class="fm-label" data-i18n="spools.emptySpoolWeight">Empty Spool Weight (g)</label>
              <input
                type="number"
                id="empty_spool_weight_g"
                name="empty_spool_weight_g"
                step="1"
                placeholder="e.g. 250"
                data-i18n-placeholder="spools.emptySpoolWeightPlaceholder"
                class="fm-input"
              />
            </div>
            <div>
              <label class="fm-label" data-i18n="spools.spoolCoreWeight">Core / Adapter Weight (g)</label>
              <div style="display: flex; align-items: center; gap: 8px; margin: 6px 0 8px;">
                <input type="checkbox" id="uses_spool_core" style="width: 16px; height: 16px; cursor: pointer; flex-shrink: 0;" />
                <label for="uses_spool_core" style="font-size: 0.875rem; cursor: pointer; margin: 0;" data-i18n="spools.usesSpoolCore">Uses spool core / adapter</label>
              </div>
              <div id="spool_core_weight_container" style="display: none;">
                <input
                  type="number"
                  id="spool_core_weight_g"
                  name="spool_core_weight_g"
                  step="1"
                  min="0"
                  placeholder="Global default"
                  data-i18n-placeholder="spools.spoolCoreWeightPlaceholder"
                  class="fm-input"
                />
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;" data-i18n="spools.spoolCoreWeightHint">Weight of cardboard inner tube, spool holder, or scale adapter — always on the scale when weighing. Leave blank to use the global default.</div>
              </div>
            </div>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 16px;">
            <div>
              <label for="spool_material" class="fm-label" data-i18n="spools.spoolMaterial">Spool Material</label>
              <select id="spool_material" name="spool_material" class="fm-select">
                <option value="">-</option>
                <option value="Plastic" data-i18n="spools.spoolMaterialPlastic">Plastic</option>
                <option value="Cardboard" data-i18n="spools.spoolMaterialCardboard">Cardboard</option>
                <option value="Metal" data-i18n="spools.spoolMaterialMetal">Metal</option>
                <option value="Other" data-i18n="spools.spoolMaterialOther">Other</option>
              </select>
            </div>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 16px;">
            <div>
              <label for="spool_outer_diameter_mm" class="fm-label" data-i18n="spools.spoolOuterDiameter">Spool Outer Diameter (mm)</label>
              <input
                type="number"
                id="spool_outer_diameter_mm"
                name="spool_outer_diameter_mm"
                step="0.1"
                class="fm-input"
              />
            </div>
            <div>
              <label for="spool_width_mm" class="fm-label" data-i18n="spools.spoolWidth">Spool Width (mm)</label>
              <input
                type="number"
                id="spool_width_mm"
                name="spool_width_mm"
                step="0.1"
                class="fm-input"
              />
            </div>
          </div>
        </div>

        <!-- Lot Number + External ID -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <div>
            <label for="lot_number" class="fm-label" data-i18n="spools.lotNumber">Lot Number</label>
            <input
              type="text"
              id="lot_number"
              name="lot_number"
              placeholder="e.g. LOT-2024-001"
              data-i18n-placeholder="spools.lotNumberPlaceholder"
              class="fm-input"
            />
          </div>
          
          <div>
            <label for="external_id" class="fm-label" data-i18n="spools.externalId">External ID</label>
            <input
              type="text"
              id="external_id"
              name="external_id"
              placeholder="e.g. MY-SPOOL-001"
              data-i18n-placeholder="spools.externalIdPlaceholder"
              class="fm-input"
            />
          </div>
        </div>

        <!-- Purchase Date + Purchase Price -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <div>
            <label for="purchase_date" class="fm-label" data-i18n="spools.purchaseDate">Purchase Date</label>
            <input
              type="date"
              id="purchase_date"
              name="purchase_date"
              class="fm-input"
            />
          </div>
          
          <div>
            <label for="purchase_price" class="fm-label" data-i18n="spools.purchasePrice">Purchase Price</label>
            <input
              type="number"
              id="purchase_price"
              name="purchase_price"
              step="0.01"
              class="fm-input"
            />
          </div>
        </div>

        <!-- Low Threshold + RFID UID -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <div>
            <label for="low_weight_threshold_g" class="fm-label" data-i18n="spools.lowThreshold">Low Weight Threshold (g)</label>
            <input
              type="number"
              id="low_weight_threshold_g"
              name="low_weight_threshold_g"
              step="1"
              value="100"
              class="fm-input"
            />
          </div>
          
          <div>
            <label for="rfid_uid" class="fm-label" data-i18n="spools.rfidUid">RFID UID</label>
            <input
              type="text"
              id="rfid_uid"
              name="rfid_uid"
              placeholder="e.g. 04A2B3C4D5"
              data-i18n-placeholder="spools.rfidUidPlaceholder"
              class="fm-input"
            />
          </div>
        </div>

        <!-- Location -->
        <div>
          <label for="location_id" class="fm-label" data-i18n="spools.location">Location</label>
          <select 
            id="location_id" 
            name="location_id" 
            class="fm-select"
          >
            <option value="" data-i18n="spools.noLocation">No location</option>
          </select>
        </div>

        <!-- System Fields -->
        <div id="system-fields-container" style="display: none; border-top: 1px solid var(--border); margin-top: 16px; padding-top: 16px;">
          <h3 class="fm-label" style="font-size: 1rem; margin-bottom: 12px;" data-i18n="common.systemFields">System Fields</h3>
          <div id="system-fields-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <!-- Dynamic system fields go here -->
          </div>
        </div>

        <!-- Custom Fields -->
        <div style="border-top: 1px solid var(--border); margin-top: 16px; padding-top: 16px;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <span class="fm-label" style="margin: 0;" data-i18n="common.extraFields">Extra Fields</span>
            <button type="button" id="btn-add-field" class="fm-btn fm-btn-outline" style="font-size: 0.8rem; padding: 4px 10px;">
              + <span data-i18n="common.add">Add</span>
            </button>
          </div>
          <div id="custom-fields-container" style="display: grid; gap: 8px;">
          </div>
        </div>
        
        <div id="error-message" class="fm-alert-error hidden"></div>
        
        <div style="display: flex; gap: 12px; padding-top: 24px;">
          <button
            type="submit"
            id="submit-btn"
            class="fm-btn fm-btn-primary"
            data-i18n="spools.saveSpool"
          >
            Save Spool
          </button>
          <a
            id="cancel-btn"
            href={backHref}
            class="fm-btn fm-btn-outline"
            data-i18n="common.cancel"
          >
            Cancel
          </a>
        </div>
      </form>
    </div>
  </div>
  
  <script>
    import { t, initI18n } from '../../../lib/i18n'
    import { cachedFetchAllPages, cachedFetch, fetchSequential, invalidateCachePrefix, CACHE_KEYS } from '../../../lib/cache'
    import { getAbortSignal, isAbortError } from '../../../lib/abort'
    import { createFilamentDbLookup, type LookupInstance, checkFilamentDbActive } from '../../../lib/filamentdb-lookup'
    await initI18n()

    const filamentDbActive = await checkFilamentDbActive()

    const pathParts = window.location.pathname.split('/').filter(Boolean)
    const spoolId = pathParts[pathParts.length - 2]

    // Set correct back links dynamically
    if (spoolId !== 'detail') {
      const backLink = document.getElementById('back-link') as HTMLAnchorElement
      const cancelBtn = document.getElementById('cancel-btn') as HTMLAnchorElement
      if (backLink) backLink.href = `/spools/${spoolId}`
      if (cancelBtn) {
        cancelBtn.href = `/spools/${spoolId}`
        cancelBtn.addEventListener('click', (e) => {
          if (window.history.length > 1) {
            e.preventDefault()
            window.history.back()
          }
        })
      }
    }

    let allFilaments: any[] = []
    let allStatuses: any[] = []
    let allLocations: any[] = []
    let systemFields: any[] = []

    const customFieldsContainer = document.getElementById('custom-fields-container') as HTMLElement
    const btnAddField = document.getElementById('btn-add-field') as HTMLButtonElement
    let customFields: any[] = []

    function flattenObject(obj: any, prefix = '', res: Record<string, string> = {}) {
      for (const key in obj) {
        if (Object.prototype.hasOwnProperty.call(obj, key)) {
          const val = obj[key]
          const newKey = prefix ? prefix + '.' + key : key
          if (typeof val === 'object' && val !== null) {
            flattenObject(val, newKey, res)
          } else {
            res[newKey] = String(val)
          }
        }
      }
      return res
    }

    function unflattenObject(data: any) {
      const result: Record<string, any> = {}
      for (const key in data) {
        if (Object.prototype.hasOwnProperty.call(data, key)) {
          const keys = key.split('.')
          let current: any = result
          for (let i = 0; i < keys.length; i++) {
            const k = keys[i]
            if (i === keys.length - 1) {
              const val = data[key]
              const num = Number(val)
              current[k] = !isNaN(num) && val.trim() !== '' ? num : val
            } else {
              current[k] = current[k] || {}
              current = current[k]
            }
          }
        }
      }
      return result
    }

    function renderCustomFields() {
      customFieldsContainer.innerHTML = ''
      customFields.forEach((field, index) => {
        const row = document.createElement('div')
        row.style.display = 'grid'
        row.style.gridTemplateColumns = '1fr 1fr auto'
        row.style.gap = '8px'
        row.style.alignItems = 'center'
        
        row.innerHTML = `
          <input type="text" placeholder="Key" class="fm-input custom-field-key" data-index="${index}" value="${field.key}" />
          <input type="text" placeholder="Value" class="fm-input custom-field-value" data-index="${index}" value="${field.value}" />
          <button type="button" class="fm-btn fm-btn-danger custom-field-remove" data-index="${index}" style="padding: 6px 10px;">&times;</button>
        `
        customFieldsContainer.appendChild(row)
      })

      document.querySelectorAll<HTMLInputElement>('.custom-field-key').forEach(input => {
        input.addEventListener('input', () => {
          customFields[parseInt(input.dataset.index ?? '0')].key = input.value
        })
      })
      document.querySelectorAll<HTMLInputElement>('.custom-field-value').forEach(input => {
        input.addEventListener('input', () => {
          customFields[parseInt(input.dataset.index ?? '0')].value = input.value
        })
      })
      
      document.querySelectorAll<HTMLButtonElement>('.custom-field-remove').forEach(btn => {
        btn.addEventListener('click', () => {
          const index = parseInt(btn.dataset.index ?? '0')
          customFields.splice(index, 1)
          renderCustomFields()
        })
      })
    }

    btnAddField.addEventListener('click', () => {
      customFields.push({ key: '', value: '' })
      renderCustomFields()
    })

    function applyFilamentDefaults(selectedFilamentId: any) {
      const filament = allFilaments.find((f) => f.id === selectedFilamentId)
      if (!filament) return

      const initialWeightInput = document.getElementById('initial_total_weight_g') as HTMLInputElement
      const emptySpoolInput = document.getElementById('empty_spool_weight_g') as HTMLInputElement
      const matInput = document.getElementById('spool_material') as HTMLSelectElement
      const odInput = document.getElementById('spool_outer_diameter_mm') as HTMLInputElement
      const wInput = document.getElementById('spool_width_mm') as HTMLInputElement
      const priceInput = document.getElementById('purchase_price') as HTMLInputElement

      const rawWeight = filament.raw_material_weight_g
      // Fallback to manufacturer settings if filament defaults are null
      const spoolWeight = filament.default_spool_weight_g ?? filament.manufacturer?.empty_spool_weight_g

      if (rawWeight != null && spoolWeight != null) {
        initialWeightInput.value = String(rawWeight + spoolWeight)
      } else if (rawWeight != null) {
        initialWeightInput.value = String(rawWeight)
      } else {
        initialWeightInput.value = ''
      }

      if (spoolWeight != null) {
        emptySpoolInput.value = String(spoolWeight)
      } else {
        emptySpoolInput.value = ''
      }

      matInput.value = filament.spool_material || filament.manufacturer?.spool_material || ''
      odInput.value = filament.spool_outer_diameter_mm != null ? String(filament.spool_outer_diameter_mm) : (filament.manufacturer?.spool_outer_diameter_mm != null ? String(filament.manufacturer.spool_outer_diameter_mm) : '')
      wInput.value = filament.spool_width_mm != null ? String(filament.spool_width_mm) : (filament.manufacturer?.spool_width_mm != null ? String(filament.manufacturer.spool_width_mm) : '')
      
      if (filament.price != null) {
        priceInput.value = String(filament.price)
      } else {
        priceInput.value = ''
      }
    }

    document.getElementById('filament_id')?.addEventListener('change', (e) => {
      const selectedId = parseInt((e.target as HTMLSelectElement).value)
      if (selectedId) {
        applyFilamentDefaults(selectedId)
      } else {
        (document.getElementById('initial_total_weight_g') as HTMLInputElement).value = '';
        (document.getElementById('empty_spool_weight_g') as HTMLInputElement).value = '';
        (document.getElementById('spool_material') as HTMLSelectElement).value = '';
        (document.getElementById('spool_outer_diameter_mm') as HTMLInputElement).value = '';
        (document.getElementById('spool_width_mm') as HTMLInputElement).value = '';
        (document.getElementById('purchase_price') as HTMLInputElement).value = '';
      }
    })

    function getCsrfToken() {
      const match = document.cookie.match(/(?:^|;\s*)csrf_token=([^;]*)/)
      return match ? decodeURIComponent(match[1]) : ''
    }

    // ── Spool Profile Lookup ──
    let spoolProfileLookup: LookupInstance | null = null
    const btnSpoolProfileLookup = document.getElementById('btn-spool-profile-lookup')!
    const spoolProfileSection = document.getElementById('spool-profile-lookup-section')!
    const spoolProfileContainer = document.getElementById('spool-profile-lookup-container')!
    const spoolProfileToast = document.getElementById('spool-profile-lookup-toast')!
    let spoolProfileLookupOpen = false

    // Hide spool profile lookup button if FilamentDB plugin is inactive
    if (!filamentDbActive) {
      btnSpoolProfileLookup.style.display = 'none'
    }

    btnSpoolProfileLookup.addEventListener('click', () => {
      spoolProfileLookupOpen = !spoolProfileLookupOpen
      if (spoolProfileLookupOpen) {
        spoolProfileSection.style.display = ''
        if (!spoolProfileLookup) {
          spoolProfileLookup = createFilamentDbLookup({
            container: spoolProfileContainer,
            endpoint: '/filamentdb/spool-profiles',
            placeholder: t('filamentdbLookup.searchSpoolProfile'),
            renderItem: (item: any) => {
              const weight = item.empty_weight_g ? `${item.empty_weight_g}g` : ''
              const material = item.spool_material || ''
              const diameter = item.outer_diameter_mm ? `${item.outer_diameter_mm}mm` : ''
              const details = [weight, material, diameter].filter(Boolean).join(' · ')
              const imageHtml = item.image_file
                ? `<img class="fdb-lookup-item-image" src="/api/v1/filamentdb/spool-profile-image?image_file=${encodeURIComponent(item.image_file)}" alt="" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display=''" /><span class="fdb-lookup-item-image-placeholder" style="display:none">&#x1F4E6;</span>`
                : `<span class="fdb-lookup-item-image-placeholder">&#x1F4E6;</span>`
              return `<div class="fdb-lookup-item-with-image">${imageHtml}<div class="fdb-lookup-item-text"><div class="fdb-lookup-item-name">${item.name || '?'}</div><div class="fdb-lookup-item-sub">${details}</div></div></div>`
            },
            onSelect: (item: any) => {
              // Fill spool property fields
              if (item.empty_weight_g != null) {
                (document.getElementById('empty_spool_weight_g') as HTMLInputElement).value = String(item.empty_weight_g)
              }
              if (item.spool_material) {
                (document.getElementById('spool_material') as HTMLSelectElement).value = item.spool_material
              }
              if (item.outer_diameter_mm != null) {
                (document.getElementById('spool_outer_diameter_mm') as HTMLInputElement).value = String(item.outer_diameter_mm)
              }
              if (item.width_mm != null) {
                (document.getElementById('spool_width_mm') as HTMLInputElement).value = String(item.width_mm)
              }
              spoolProfileToast.className = 'fdb-toast fdb-toast-success'
              spoolProfileToast.textContent = t('filamentdbLookup.spoolProfileLoaded')
              spoolProfileToast.style.display = ''
            },
          })
        } else {
          spoolProfileLookup.reset()
        }
      } else {
        spoolProfileSection.style.display = 'none'
        spoolProfileToast.style.display = 'none'
      }
    })

    async function loadFilaments() {
      try {
        const data = await cachedFetchAllPages(CACHE_KEYS.FILAMENTS, '/api/v1/filaments')
        const select = document.getElementById('filament_id') as HTMLSelectElement
        allFilaments = data.items
        allFilaments.forEach((f: any) => {
          const option = document.createElement('option')
          option.value = String(f.id)
          const mfgName = f.manufacturer?.name || ''
          option.textContent = mfgName ? f.designation + ' (' + mfgName + ')' : f.designation
          select.appendChild(option)
        })
      } catch (error) {
        if (isAbortError(error)) return
        console.error('Failed to load filaments:', error)
      }
    }

    async function loadStatuses() {
      try {
        allStatuses = await cachedFetch(CACHE_KEYS.STATUSES, async () => {
          const response = await fetch('/api/v1/spools/statuses', { credentials: 'include', signal: getAbortSignal() })
          if (!response.ok) throw new Error('Failed to fetch statuses')
          return response.json()
        })
        const select = document.getElementById('status_id') as HTMLSelectElement
        allStatuses.forEach((s: any) => {
          const option = document.createElement('option')
          option.value = String(s.id)
          const i18nKey = 'spools.status' + s.key.charAt(0).toUpperCase() + s.key.slice(1)
          option.textContent = t(i18nKey) || s.label
          select.appendChild(option)
        })
      } catch (error) {
        if (isAbortError(error)) return
        console.error('Failed to load statuses:', error)
      }
    }

    async function loadLocations() {
      try {
        const data = await cachedFetchAllPages(CACHE_KEYS.LOCATIONS, '/api/v1/locations')
        const select = document.getElementById('location_id') as HTMLSelectElement
        allLocations = data.items
        allLocations.forEach((l: any) => {
          const option = document.createElement('option')
          option.value = String(l.id)
          option.textContent = l.name
          select.appendChild(option)
        })
      } catch (error) {
        if (isAbortError(error)) return
        console.error('Failed to load locations:', error)
      }
    }

    async function loadSystemFields() {
      try {
        const response = await fetch('/api/v1/system-extra-fields?target_type=spool', { credentials: 'include', signal: getAbortSignal() })
        if (!response.ok) throw new Error('Failed to fetch system fields')
        systemFields = await response.json()
      } catch (error) {
        if (isAbortError(error)) return
        console.error('Failed to load system fields:', error)
      }
    }

    function renderSystemFields(spoolCustomFieldsFlat: Record<string, any> = {}) {
      const container = document.getElementById('system-fields-container') as HTMLElement
      const grid = document.getElementById('system-fields-grid') as HTMLElement
      if (!systemFields || systemFields.length === 0) {
        container.style.display = 'none'
        return
      }
      container.style.display = 'block'
      grid.innerHTML = ''
      
      systemFields.forEach(field => {
        const currentValue = spoolCustomFieldsFlat[field.key] !== undefined ? String(spoolCustomFieldsFlat[field.key]) : (field.default_value || '')
        const div = document.createElement('div')
        let inputHtml = ''

        switch (field.field_type) {
          case 'number':
            inputHtml = `<input type="number" class="fm-input system-field-input" data-key="${escapeHtml(field.key)}" data-type="${field.field_type}" value="${escapeHtml(currentValue)}" step="any" />`
            break
          case 'dropdown': {
            const opts = (field.options || []).map((opt: any) => {
              const selected = opt === currentValue ? ' selected' : ''
              return `<option value="${escapeHtml(opt)}"${selected}>${escapeHtml(opt)}</option>`
            }).join('')
            inputHtml = `<select class="fm-select system-field-input" data-key="${escapeHtml(field.key)}" data-type="${field.field_type}"><option value="">\u2014</option>${opts}</select>`
            break
          }
          case 'checkbox': {
            const checked = currentValue === 'true' ? ' checked' : ''
            inputHtml = `<label style="display: flex; align-items: center; gap: 8px; cursor: pointer;"><input type="checkbox" class="system-field-input" data-key="${escapeHtml(field.key)}" data-type="${field.field_type}"${checked} /> ${escapeHtml(field.label)}</label>`
            break
          }
          default:
            inputHtml = `<input type="text" class="fm-input system-field-input" data-key="${escapeHtml(field.key)}" data-type="${field.field_type}" value="${escapeHtml(currentValue)}" />`
        }

        if (field.field_type === 'checkbox') {
          div.innerHTML = inputHtml
        } else {
          div.innerHTML = `<label class="fm-label">${escapeHtml(field.label)}</label>${inputHtml}`
        }
        grid.appendChild(div)
      })
    }

    function escapeHtml(str: any) {
      if (!str) return ''
      const div = document.createElement('div')
      div.textContent = str
      return div.innerHTML
    }

    function prefillForm(s: any) {
      (document.getElementById('filament_id') as HTMLInputElement).value = String(s.filament_id)

      if (s.status_id) {
        (document.getElementById('status_id') as HTMLInputElement).value = String(s.status_id)
      }

      (document.getElementById('initial_total_weight_g') as HTMLInputElement).value = s.initial_total_weight_g != null ? String(s.initial_total_weight_g) : ''
      ;(document.getElementById('empty_spool_weight_g') as HTMLInputElement).value = s.empty_spool_weight_g != null ? String(s.empty_spool_weight_g) : ''

      // Core weight: 0 = explicitly no core; null = use global default; >0 = spool-specific value
      const usesCoreCheckbox = document.getElementById('uses_spool_core') as HTMLInputElement
      const coreContainer = document.getElementById('spool_core_weight_container')!
      const coreInput = document.getElementById('spool_core_weight_g') as HTMLInputElement
      if (s.spool_core_weight_g === 0) {
        usesCoreCheckbox.checked = false
        coreContainer.style.display = 'none'
        coreInput.value = ''
      } else {
        usesCoreCheckbox.checked = true
        coreContainer.style.display = 'block'
        coreInput.value = s.spool_core_weight_g != null ? String(s.spool_core_weight_g) : ''
      }

      ;(document.getElementById('low_weight_threshold_g') as HTMLInputElement).value = s.low_weight_threshold_g != null ? String(s.low_weight_threshold_g) : '100'

      ;(document.getElementById('spool_material') as HTMLInputElement).value = s.spool_material || ''
      
      ;(document.getElementById('lot_number') as HTMLInputElement).value = s.lot_number || ''

      ;(document.getElementById('rfid_uid') as HTMLInputElement).value = s.rfid_uid || ''
      ;(document.getElementById('external_id') as HTMLInputElement).value = s.external_id || ''

      if (s.location_id) {
        (document.getElementById('location_id') as HTMLInputElement).value = String(s.location_id)
      }

      ;(document.getElementById('spool_outer_diameter_mm') as HTMLInputElement).value = s.spool_outer_diameter_mm != null ? String(s.spool_outer_diameter_mm) : ''
      ;(document.getElementById('spool_width_mm') as HTMLInputElement).value = s.spool_width_mm != null ? String(s.spool_width_mm) : ''

      ;(document.getElementById('purchase_price') as HTMLInputElement).value = s.purchase_price != null ? String(s.purchase_price) : ''
      if (s.purchase_date) {
        (document.getElementById('purchase_date') as HTMLInputElement).value = s.purchase_date.split('T')[0]
      }

      if (s.custom_fields && Object.keys(s.custom_fields).length > 0) {
        const flat = flattenObject(s.custom_fields)
        const systemKeys = systemFields.map(f => f.key)
        
        customFields = Object.entries(flat)
          .filter(([key]) => !systemKeys.includes(key))
          .map(([key, value]) => ({ key, value: String(value) }))
          
        renderSystemFields(flat)
      } else {
        customFields = []
        renderSystemFields({})
      }
      renderCustomFields()
    }

    const form = document.getElementById('spool-form') as HTMLFormElement
    const errorMessage = document.getElementById('error-message') as HTMLElement
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement

    // Wire checkbox toggle for core weight field
    const usesCoreCheckbox = document.getElementById('uses_spool_core') as HTMLInputElement
    const coreWeightContainer = document.getElementById('spool_core_weight_container')!
    usesCoreCheckbox.addEventListener('change', () => {
      coreWeightContainer.style.display = usesCoreCheckbox.checked ? 'block' : 'none'
    })

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      
      const formData = new FormData(form)

      const patchData: Record<string, unknown> = {}

      const filamentId = formData.get('filament_id')
      if (filamentId) {
        patchData.filament_id = parseInt(filamentId as string)
      }

      const statusId = formData.get('status_id')
      patchData.status_id = statusId ? parseInt(statusId as string) : null

      const locationId = formData.get('location_id')
      patchData.location_id = locationId ? parseInt(locationId as string) : null

      const initialWeight = formData.get('initial_total_weight_g')
      patchData.initial_total_weight_g = initialWeight ? parseFloat(initialWeight as string) : null

      const emptySpoolWeight = formData.get('empty_spool_weight_g')
      patchData.empty_spool_weight_g = emptySpoolWeight ? parseFloat(emptySpoolWeight as string) : null

      const usesCoreChk = (document.getElementById('uses_spool_core') as HTMLInputElement).checked
      if (!usesCoreChk) {
        patchData.spool_core_weight_g = 0  // explicitly disabled for this spool
      } else {
        const spoolCoreWeight = formData.get('spool_core_weight_g')
        patchData.spool_core_weight_g = spoolCoreWeight ? parseFloat(spoolCoreWeight as string) : null  // null = use global default
      }

      const spoolMaterial = formData.get('spool_material')
      patchData.spool_material = spoolMaterial || null

      const lowThreshold = formData.get('low_weight_threshold_g')
      patchData.low_weight_threshold_g = lowThreshold ? parseInt(lowThreshold as string) : null

      const lotNumber = (formData.get('lot_number') as string || '').trim()
      patchData.lot_number = lotNumber || null

      const rfidUid = (formData.get('rfid_uid') as string || '').trim()
      patchData.rfid_uid = rfidUid || null

      const externalId = (formData.get('external_id') as string || '').trim()
      patchData.external_id = externalId || null

      const outerDiameter = formData.get('spool_outer_diameter_mm')
      patchData.spool_outer_diameter_mm = outerDiameter ? parseFloat(outerDiameter as string) : null

      const width = formData.get('spool_width_mm')
      patchData.spool_width_mm = width ? parseFloat(width as string) : null

      const price = formData.get('purchase_price')
      patchData.purchase_price = price ? parseFloat(price as string) : null

      const purchaseDate = formData.get('purchase_date')
      patchData.purchase_date = purchaseDate || null

      const fieldsObj: Record<string, string> = {}

      document.querySelectorAll<HTMLInputElement>('.system-field-input').forEach(input => {
        const key = input.dataset.key
        const type = input.dataset.type
        if (!key) return
        if (type === 'checkbox') {
          fieldsObj[key] = input.checked ? 'true' : 'false'
        } else {
          const value = input.value.trim()
          if (value) fieldsObj[key] = value
        }
      })

      if (customFields.length > 0) {
        customFields.forEach(f => {
          if (f.key.trim()) {
            fieldsObj[f.key.trim()] = f.value
          }
        })
      }
      
      patchData.custom_fields = Object.keys(fieldsObj).length > 0 ? unflattenObject(fieldsObj) : null

      errorMessage.classList.add('hidden')
      submitBtn.disabled = true
      submitBtn.textContent = t('common.saving')

      try {
        const response = await fetch('/api/v1/spools/' + spoolId, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': getCsrfToken(),
          },
          credentials: 'include',
          body: JSON.stringify(patchData),
          signal: getAbortSignal(),
        })

        if (!response.ok) {
          const errorData = await response.json()
          throw new Error(errorData.detail?.message || errorData.message || t('spools.failedUpdate'))
        }

        invalidateCachePrefix('spools')
        window.location.href = '/spools/' + spoolId
      } catch (error) {
        if (isAbortError(error)) return
        errorMessage.textContent = (error instanceof Error ? error.message : null) || t('spools.failedUpdate')
        errorMessage.classList.remove('hidden')
      } finally {
        submitBtn.disabled = false
        submitBtn.textContent = t('spools.saveSpool')
      }
    })

    async function init() {
      if (spoolId === 'detail') {
        window.location.href = '/spools'
        return
      }
      try {
        // Load reference data sequentially to avoid SQLite lock conflicts
        await fetchSequential([
          () => loadFilaments(),
          () => loadStatuses(),
          () => loadLocations(),
          () => loadSystemFields()
        ] as const)

        const response = await fetch('/api/v1/spools/' + spoolId, {
          credentials: 'include',
          signal: getAbortSignal(),
        })

        if (!response.ok) {
          throw new Error('Failed to fetch spool')
        }

        const spool = await response.json()
        prefillForm(spool)

        document.getElementById('edit-loading')?.classList.add('hidden')
        document.getElementById('edit-form-wrapper')?.classList.remove('hidden')
      } catch (error) {
        if (isAbortError(error)) return
        console.error('Failed to load spool for editing:', error)
        document.getElementById('edit-loading')?.classList.add('hidden')
        document.getElementById('edit-error')?.classList.remove('hidden')
      }
    }

    init()
  </script>
</Layout>
