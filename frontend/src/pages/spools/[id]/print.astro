  function loadDesignerSettings() {
    const s: LabelDesignerSettings = loadDesignerSettingsFromStorage()

    const rawLogo = (s as any).logo ?? {}
    const logoSpaceMm = Number(rawLogo.spaceMm ?? rawLogo.sizeMm ?? DESIGNER_DEFAULTS.logo.spaceMm)
    const logoManualMm = Number(rawLogo.manualSizeMm ?? rawLogo.sizeMm ?? DESIGNER_DEFAULTS.logo.manualSizeMm)

    // Use batch setter to apply all form values at once — consolidates ~100 lines of duplicate code
    setFormFields([
      // Logo section
      { id: 'ds-logo-show', value: s.logo.show },
      { id: 'ds-logo-space', value: logoSpaceMm, rangePartnerId: 'ds-logo-space-range' },
      { id: 'ds-logo-fit', value: s.logo.scaleToFit },
      { id: 'ds-logo-manual', value: logoManualMm, rangePartnerId: 'ds-logo-manual-range' },
      // Label section
      { id: 'ds-width', value: s.label.width },
      { id: 'ds-height', value: s.label.height },
      { id: 'ds-margin', value: s.label.marginMm, rangePartnerId: 'ds-margin-range' },
      { id: 'ds-border', value: s.label.border },
      // Title section
      { id: 'ds-title-show', value: s.title.show },
      { id: 'ds-title-size', value: s.title.sizeMm, rangePartnerId: 'ds-title-size-range' },
      { id: 'ds-title-gap', value: s.title.marginMm ?? DESIGNER_DEFAULTS.title.marginMm, rangePartnerId: 'ds-title-gap-range' },
      { id: 'ds-title-fit', value: s.title.fitToWidth },
      { id: 'ds-title-tpl', value: s.title.template },
      { id: 'ds-divider-above', value: s.title.dividerAbove ?? false },
      { id: 'ds-divider-below', value: s.title.dividerBelow ?? true },
      // Title2 section
      { id: 'ds-title2-show', value: s.title2.show },
      { id: 'ds-title2-size', value: s.title2.sizeMm, rangePartnerId: 'ds-title2-size-range' },
      { id: 'ds-title2-gap', value: s.title2.marginMm ?? DESIGNER_DEFAULTS.title2.marginMm, rangePartnerId: 'ds-title2-gap-range' },
      { id: 'ds-title2-fit', value: s.title2.fitToWidth },
      { id: 'ds-title2-tpl', value: s.title2.template },
      { id: 'ds-title2-divider-above', value: s.title2.dividerAbove ?? false },
      { id: 'ds-title2-divider-below', value: s.title2.dividerBelow ?? false },
      // QR section
      { id: 'ds-qr-show', value: s.qr.show },
      { id: 'ds-qr-mode', value: s.qr.mode },
      { id: 'ds-qr-size', value: s.qr.sizeMm, rangePartnerId: 'ds-qr-size-range' },
      { id: 'ds-qr-url-tpl', value: s.qr.urlTemplate },
      // Info section
      { id: 'ds-info-show', value: s.info.show },
      { id: 'ds-info-size', value: s.info.sizeMm, rangePartnerId: 'ds-info-size-range' },
      { id: 'ds-info-tpl', value: s.info.template },
      // Info2 section
      { id: 'ds-info2-show', value: s.info2.show },
      { id: 'ds-info2-vsep', value: s.info2.vsep ?? false },
      { id: 'ds-info2-size', value: s.info2.sizeMm, rangePartnerId: 'ds-info2-size-range' },
      { id: 'ds-info2-tpl', value: s.info2.template },
    ])

    // Handle special cases (alignment groups, visibility toggles)
    setAlignGroup('ds-logo-align-group', s.logo.align)
    setAlignGroup('ds-title-align-group', s.title.align)
    setAlignGroup('ds-title2-align-group', s.title2.align)
    setAlignGroup('ds-info-align-group', s.info.hAlign)
    setAlignGroup('ds-info2-align-group', s.info2.hAlign)
    setPillGroup('ds-qr-pos-group', s.qr.position)
    setPillGroup('ds-qr-valign-group', s.qr.vAlign)
    setPillGroup('ds-qr-link-group', s.qr.linkMode)
    setPillGroup('ds-info-valign-group', s.info.vAlign)
    setPillGroup('ds-info2-valign-group', s.info2.vAlign)

    // Update visibility-dependent UI state
    ;(document.getElementById('ds-title2-block') as HTMLElement).style.display = s.title2.show ? '' : 'none'
    ;(document.getElementById('ds-info2-block') as HTMLElement).style.display = s.info2.show ? '' : 'none'
    ;(document.getElementById('ds-qr-url-wrap') as HTMLElement).style.display = s.qr.linkMode === 'url' ? '' : 'none'

    syncLogoManualControls()
    autosizeTemplateFields()
  }

  // ─── DOM value setter helpers to reduce duplication ────────────────────────────
  // Set input/checkbox/select/textarea value by ID with proper type handling
  function setElementValue(id: string, value: string | number | boolean) {
    const el = document.getElementById(id)
    if (!el) return
    if (el instanceof HTMLInputElement) {
      if (el.type === 'checkbox') {
        el.checked = Boolean(value)
      } else {
        el.value = String(value)
      }
    } else if (el instanceof HTMLTextAreaElement) {
      el.textContent = String(value)
    } else if (el instanceof HTMLSelectElement) {
      el.value = String(value)
    } else {
      (el as HTMLInputElement).value = String(value)
    }
  }

  // Set value on both range and number inputs (synchronized pair)
  function setRangeAndNumber(rangeId: string, numberId: string, value: string | number) {
    setElementValue(rangeId, value)
    setElementValue(numberId, value)
  }

  // Batch setter for multiple form fields — significantly reduces duplication in load functions
  interface FormFieldSetter {
    id: string
    value: string | number | boolean
    rangePartnerId?: string // If set, also updates this range input's value
  }

  function setFormFields(fields: FormFieldSetter[]) {
    for (const { id, value, rangePartnerId } of fields) {
      setElementValue(id, value)
      if (rangePartnerId) setElementValue(rangePartnerId, value)
    }
  }

  // Helpers for button groups
  function setAlignGroup(groupId: string, value: string) {
    const group = document.getElementById(groupId)
    if (!group) return
    group.dataset.value = value
    group.querySelectorAll<HTMLButtonElement>('.ds-align-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.align === value)
    })
  }

  function setPillGroup(groupId: string, value: string) {
    const group = document.getElementById(groupId)
    if (!group) return
    group.dataset.value = value
    group.querySelectorAll<HTMLButtonElement>('.ds-pill-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.val === value)
    })
  }

  function wireAlignGroup(groupId: string) {
    const group = document.getElementById(groupId)
    if (!group) return
    group.querySelectorAll<HTMLButtonElement>('.ds-align-btn').forEach(btn => {
      btn.addEventListener('click', () => { setAlignGroup(groupId, btn.dataset.align!); saveDesignerSettings(); updateDesignerPreview() })
    })
  }

  function wirePillGroup(groupId: string, onChange?: (val: string) => void) {
    const group = document.getElementById(groupId)
    if (!group) return
    group.querySelectorAll<HTMLButtonElement>('.ds-pill-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        setPillGroup(groupId, btn.dataset.val!)
        saveDesignerSettings()
        onChange?.(btn.dataset.val!)
        updateDesignerPreview()
      })
    })
  }

  function syncLogoManualControls() {
    const fit = (document.getElementById('ds-logo-fit') as HTMLInputElement)?.checked ?? true
    const wrap = document.getElementById('ds-logo-manual-wrap') as HTMLElement | null
    const manualRange = document.getElementById('ds-logo-manual-range') as HTMLInputElement | null
    const manualNum = document.getElementById('ds-logo-manual') as HTMLInputElement | null
    if (wrap) wrap.hidden = fit
    if (manualRange) manualRange.disabled = fit
    if (manualNum) manualNum.disabled = fit
  }

  function autosizeTemplateField(id: string) {
    const el = document.getElementById(id) as HTMLTextAreaElement | null
    if (!el) return
    const currentHeight = el.offsetHeight || 42
    el.style.height = 'auto'
    el.style.height = `${Math.max(el.scrollHeight, currentHeight, 42)}px`
  }

  function autosizeTemplateFields() {
    autosizeTemplateField('ds-title-tpl')
    autosizeTemplateField('ds-title2-tpl')
  }

  // Wire up all designer controls
  wireAlignGroup('ds-logo-align-group')
  wireAlignGroup('ds-title-align-group')
  wireAlignGroup('ds-title2-align-group')
  wireAlignGroup('ds-info-align-group')
  wireAlignGroup('ds-info2-align-group')
  wirePillGroup('ds-qr-pos-group')
  wirePillGroup('ds-qr-valign-group')
  wirePillGroup('ds-info-valign-group')
  wirePillGroup('ds-info2-valign-group')
  wirePillGroup('ds-qr-link-group', (val) => {
    ;(document.getElementById('ds-qr-url-wrap') as HTMLElement).style.display = val === 'url' ? '' : 'none'
  })

  const dsInputIds = ['ds-width','ds-height','ds-margin','ds-logo-space','ds-logo-manual','ds-title-size','ds-title-gap','ds-title2-size','ds-title2-gap','ds-qr-size','ds-info-size','ds-info2-size','ds-title-tpl','ds-title2-tpl','ds-qr-url-tpl','ds-info-tpl','ds-info2-tpl']
  const dsCheckIds = ['ds-border','ds-logo-show','ds-logo-fit','ds-title-show','ds-title-fit','ds-divider-above','ds-divider-below','ds-title2-show','ds-title2-fit','ds-title2-divider-above','ds-title2-divider-below','ds-qr-show','ds-info-show','ds-info2-show','ds-info2-vsep']
  const dsSelectIds = ['ds-qr-mode']
  let designerPreviewDebounceTimer: ReturnType<typeof setTimeout> | null = null
  const scheduleDesignerPreview = () => {
    if (designerPreviewDebounceTimer) clearTimeout(designerPreviewDebounceTimer)
    designerPreviewDebounceTimer = setTimeout(() => {
      saveDesignerSettings()
      updateDesignerPreview()
    }, 120)
  }
  ;[...dsInputIds, ...dsCheckIds, ...dsSelectIds].forEach(id => {
    document.getElementById(id)?.addEventListener('change', () => { saveDesignerSettings(); updateDesignerPreview() })
  })
  // Toggle info2 block visibility when its show-checkbox changes
  document.getElementById('ds-info2-show')?.addEventListener('change', (e) => {
    const show = (e.target as HTMLInputElement).checked
    ;(document.getElementById('ds-info2-block') as HTMLElement).style.display = show ? '' : 'none'
  })
  document.getElementById('ds-title2-show')?.addEventListener('change', (e) => {
    const show = (e.target as HTMLInputElement).checked
    ;(document.getElementById('ds-title2-block') as HTMLElement).style.display = show ? '' : 'none'
  })
  document.getElementById('ds-logo-fit')?.addEventListener('change', () => {
    syncLogoManualControls()
  })
  dsInputIds.forEach(id => {
    const el = document.getElementById(id)
    if (el && (el as HTMLInputElement).type !== 'checkbox') {
      el.addEventListener('input', () => {
        if (id === 'ds-title-tpl' || id === 'ds-title2-tpl') autosizeTemplateField(id)
        scheduleDesignerPreview()
      })
    }
  })

  // Wire sliders ↔ number inputs bidirectionally
  const sliderPairs: [string, string][] = [
    ['ds-margin-range', 'ds-margin'],
    ['ds-logo-space-range', 'ds-logo-space'],
    ['ds-logo-manual-range', 'ds-logo-manual'],
    ['ds-title-size-range', 'ds-title-size'],
    ['ds-title-gap-range', 'ds-title-gap'],
    ['ds-title2-size-range', 'ds-title2-size'],
    ['ds-title2-gap-range', 'ds-title2-gap'],
    ['ds-qr-size-range', 'ds-qr-size'],
    ['ds-info-size-range', 'ds-info-size'],
    ['ds-info2-size-range', 'ds-info2-size'],
  ]
  for (const [rangId, numId] of sliderPairs) {
    const rang = document.getElementById(rangId) as HTMLInputElement
    const num  = document.getElementById(numId)  as HTMLInputElement
    if (!rang || !num) continue
    rang.addEventListener('input', () => {
      num.value = rang.value
      saveDesignerSettings()
      updateDesignerPreview()
    })
    num.addEventListener('input', () => {
      rang.value = num.value
    })
  }

  // Template syntax popover
  const SYNTAX_HTML = `
    <button class="ds-popover-close" title="Close">✕</button>
    <h4>Print Format Syntax</h4>
    <table>
      <tr><td>{token}</td><td>Insert token value — chips show short labels, the <code>filament.</code> prefix is added automatically when clicked<br><span class="ds-popover-eg">e.g. type → inserts {filament.type} → TPU</span></td></tr>
      <tr><td>{text{token}text}</td><td>Wrap token with literal text — the whole thing is hidden if the token is empty<br><span class="ds-popover-eg">e.g. {Ext: {filament.extruder_temp}°C} → Ext: 210°C, or nothing if temp is unset</span></td></tr>
      <tr><td>{color_swatch[1]}</td><td>Inline color swatch from <code>filament.color_hex</code>; the number in brackets sets the swatch width in character units, so <code>[1]</code> is the narrow default and <code>[10]</code> makes it wider.<br><span class="ds-popover-eg">e.g. <span style="display:inline-block;width:1ch;height:0.82em;background:#2A5BE8;border:1px solid rgba(0,0,0,0.28);border-radius:0.14em;vertical-align:baseline;margin:0 0.2ch;"></span> Blue</span></td></tr>
      <tr><td>[size=120%]text[/size]</td><td>Inline relative text size in % (50..300, % optional); works with literal text, field values, and swatches.<br><span class="ds-popover-eg">e.g. [size=140%]{filament.extruder_temp}[/size]°C or [size=120%]{color_swatch[6]}[/size] {filament.color}</span></td></tr>
      <tr><td>**text**</td><td><strong>Bold</strong></td></tr>
      <tr><td>*text*</td><td><em>Italic</em></td></tr>
      <tr><td>__text__</td><td><u>Underline</u></td></tr>
      <tr><td>^^text^^</td><td>Uppercase text and field values.<br><span class="ds-popover-eg">e.g. ^^{filament.color_hex}^^ → FF6A00</span></td></tr>
      <tr><td>==text==</td><td style="background:#000;color:#fff;padding:0 2px;border-radius:2px">Inverse (white on black)</td></tr>
      <tr><td>@@text@@</td><td>Inverse using filament color with automatic black/white text chosen for best contrast.<br><span class="ds-popover-eg"><span style="background:#2A5BE8;color:#fff;padding:0 2px;border-radius:2px">Blue uses white text</span> <span style="background:#F5E663;color:#000;padding:0 2px;border-radius:2px">Yellow uses black text</span></span></td></tr>
      <tr><td>Nested</td><td>Text modifiers can be nested manually.<br><span class="ds-popover-eg">e.g. **__{filament.name}__** → bold + underline</span></td></tr>
      <tr><td>Line breaks</td><td>Use an actual Return/Enter in the text area for a new line.</td></tr>
    </table>`

  let _activeSyntaxPopover: HTMLElement | null = null
  function openSyntaxPopover(anchorBtn: HTMLElement) {
    if (_activeSyntaxPopover) { _activeSyntaxPopover.remove(); _activeSyntaxPopover = null }
    const pop = document.createElement('div')
    pop.className = 'ds-syntax-popover'
    pop.innerHTML = SYNTAX_HTML
    pop.querySelector('.ds-popover-close')?.addEventListener('click', () => { pop.remove(); _activeSyntaxPopover = null })
    // Append first (hidden) so we can measure its natural size
    pop.style.visibility = 'hidden'
    document.body.appendChild(pop)

    const rect = anchorBtn.getBoundingClientRect()
    const pw = pop.offsetWidth
    const ph = pop.offsetHeight
    const vw = window.innerWidth
    const vh = window.innerHeight
    const GAP = 8

    // Horizontal: prefer aligning left edge with anchor, but clamp to viewport
    let left = rect.left
    if (left + pw + GAP > vw) left = vw - pw - GAP
    if (left < GAP) left = GAP

    // Vertical: prefer below anchor, flip above if not enough room
    let top = rect.bottom + 6
    if (top + ph + GAP > vh) top = rect.top - ph - 6
    if (top < GAP) top = GAP

    pop.style.position = 'fixed'
    pop.style.left = left + 'px'
    pop.style.top = top + 'px'
    pop.style.visibility = ''
    _activeSyntaxPopover = pop
    // Close on outside click
    setTimeout(() => {
      const handler = (e: MouseEvent) => {
        if (!pop.contains(e.target as Node) && e.target !== anchorBtn) {
          pop.remove(); _activeSyntaxPopover = null
          document.removeEventListener('click', handler)
        }
      }
      document.addEventListener('click', handler)
    }, 0)
  }
  document.getElementById('ds-title-syntax-btn')?.addEventListener('click', (e) => { e.stopPropagation(); openSyntaxPopover(e.currentTarget as HTMLElement) })
  document.getElementById('ds-title2-syntax-btn')?.addEventListener('click', (e) => { e.stopPropagation(); openSyntaxPopover(e.currentTarget as HTMLElement) })
  document.getElementById('ds-info-syntax-btn')?.addEventListener('click', (e) => { e.stopPropagation(); openSyntaxPopover(e.currentTarget as HTMLElement) })
  document.getElementById('ds-info2-syntax-btn')?.addEventListener('click', (e) => { e.stopPropagation(); openSyntaxPopover(e.currentTarget as HTMLElement) })

  // ── Inline token area — collapsible, with Filament and Extra fields sections ───
  const TOKENS_OPEN_KEY = 'filaman-tokens-open'

  function buildTokenArea(areaId: string, targetId: string) {
    const area = document.getElementById(areaId)
    if (!area) return
    // Clear before rebuilding so the function is idempotent.
    // Toggle open/closed state is persisted in localStorage and restored below,
    // so state is preserved across rebuilds.
    area.innerHTML = ''

    let activeModifier: DesignerModifier | null = null

    function updateModifierButtons(group: HTMLElement) {
      group.querySelectorAll<HTMLButtonElement>('.ds-modifier-chip').forEach(btn => {
        const isActive = btn.dataset.modifier === activeModifier?.key
        btn.classList.toggle('active', isActive)
        btn.setAttribute('aria-pressed', String(isActive))
      })
    }

    function insertTok(tok: string) {
      const el = document.getElementById(targetId) as HTMLInputElement | HTMLTextAreaElement
      if (!el) return
      const formattedTok = activeModifier ? activeModifier.wrap(tok) : tok
      const start = el.selectionStart ?? el.value.length
      const end   = el.selectionEnd   ?? el.value.length
      const before = el.value.slice(0, start)
      const after  = el.value.slice(end)
      const needSpaceBefore = before.length > 0 && !/\s$/.test(before)
      const needSpaceAfter  = after.length  > 0 && !/^\s/.test(after)
      const insert = (needSpaceBefore ? ' ' : '') + formattedTok + (needSpaceAfter ? ' ' : '')
      el.value = before + insert + after
      el.selectionStart = el.selectionEnd = start + insert.length
      el.focus()
      // Modifiers are one-shot: apply to this token, then clear for the next click.
      if (activeModifier) {
        activeModifier = null
        updateModifierButtons(area)
      }
      saveDesignerSettings()
      updateDesignerPreview()
    }

    function makeChip(tok: string, label: string): HTMLButtonElement {
      const chip = document.createElement('button')
      chip.className = 'ds-token-chip'
      chip.type = 'button'
      chip.textContent = label
      chip.title = tok          // full token shown on hover
      chip.addEventListener('click', () => insertTok(tok))
      return chip
    }

    function makeModifierChip(modifier: DesignerModifier, group: HTMLElement): HTMLButtonElement {
      const chip = document.createElement('button')
      chip.className = `ds-modifier-chip ${modifier.className ?? ''}`.trim()
      chip.type = 'button'
      chip.textContent = modifier.label
      chip.title = `${modifier.title}: click, then click a token`
      chip.dataset.tooltip = modifier.title
      chip.dataset.modifier = modifier.key
      if (modifier.key === 'colorInverse') {
        const theme = getFilamentInverseChipTheme()
        if (theme) {
          chip.classList.add('has-filament-color')
          chip.style.setProperty('--ds-filament-bg', theme.background)
          chip.style.setProperty('--ds-filament-fg', theme.foreground)
        }
      }
      chip.setAttribute('aria-label', `${modifier.title} token modifier`)
      chip.setAttribute('aria-pressed', 'false')
      chip.addEventListener('click', () => {
        activeModifier = activeModifier?.key === modifier.key ? null : modifier
        updateModifierButtons(group)
      })
      return chip
    }

    const isOpen = localStorage.getItem(TOKENS_OPEN_KEY) !== 'false'

    const wrap = document.createElement('div')
    wrap.className = 'ds-token-area-wrap'

    const toggle = document.createElement('button')
    toggle.className = 'ds-tokens-toggle'
    toggle.type = 'button'
    toggle.innerHTML = `Available tokens <span class="ds-tokens-caret">${isOpen ? '▾' : '▸'}</span>`

    const body = document.createElement('div')
    body.className = 'ds-tokens-body'
    body.style.display = isOpen ? '' : 'none'

    // ── Filament group ──
    const filGroup = document.createElement('div')
    const filHeader = document.createElement('div')
    filHeader.className = 'ds-tokens-group-header'
    const filLbl = document.createElement('div')
    filLbl.className = 'ds-tokens-group-label'
    filLbl.textContent = 'Filament'
    const modifierGroup = document.createElement('div')
    modifierGroup.className = 'ds-modifier-chips'
    for (const modifier of DESIGNER_MODIFIERS) {
      modifierGroup.appendChild(makeModifierChip(modifier, modifierGroup))
    }
    const filChips = document.createElement('div')
    filChips.className = 'ds-token-hints'
    for (const { token, label } of DESIGNER_TOKENS) filChips.appendChild(makeChip(token, label))
    filHeader.appendChild(filLbl)
    filHeader.appendChild(modifierGroup)
    filGroup.appendChild(filHeader)
    filGroup.appendChild(filChips)
    body.appendChild(filGroup)

    // ── Extra / custom fields group ──
    const extGroup = document.createElement('div')
    const extLbl = document.createElement('div')
    extLbl.className = 'ds-tokens-group-label'
    extLbl.textContent = 'Extra fields'
    const extChips = document.createElement('div')
    extChips.className = 'ds-token-hints'
    if (extraFields.length > 0) {
      for (const ef of extraFields) {
        const tok = `{extra.${ef.key}}`
        extChips.appendChild(makeChip(tok, ef.label !== ef.key ? ef.label : ef.key))
      }
    } else {
      const empty = document.createElement('span')
      empty.className = 'ds-tokens-empty'
      empty.textContent = 'No custom fields for this spool'
      extChips.appendChild(empty)
    }
    extGroup.appendChild(extLbl)
    extGroup.appendChild(extChips)
    body.appendChild(extGroup)

    toggle.addEventListener('click', () => {
      const open = body.style.display === 'none'
      body.style.display = open ? '' : 'none'
      toggle.querySelector<HTMLElement>('.ds-tokens-caret')!.textContent = open ? '▾' : '▸'
      localStorage.setItem(TOKENS_OPEN_KEY, String(open))
    })

    wrap.appendChild(toggle)
    wrap.appendChild(body)
    area.appendChild(wrap)
  }

  buildTokenArea('ds-title-token-area',  'ds-title-tpl')
  buildTokenArea('ds-title2-token-area', 'ds-title2-tpl')
  buildTokenArea('ds-info-token-area',   'ds-info-tpl')
  buildTokenArea('ds-info2-token-area',  'ds-info2-tpl')
  autosizeTemplateFields()
  // Load persisted designer settings
  loadDesignerSettings()

  // ─── Preview zoom ─────────────────────────────────────────────────────────

  const ZOOM_KEY = 'filaman-label-zoom-v1'
  let _previewZoom = 100
  function applyZoom(z: number) {
    _previewZoom = Math.min(300, Math.max(50, Math.round(z / 5) * 5))
    const lp = document.getElementById('label-preview') as HTMLElement
    if (lp) { lp.style.transform = `scale(${_previewZoom / 100})`; lp.style.transformOrigin = 'center center' }
    ;(document.getElementById('preview-zoom-slider') as HTMLInputElement).value = String(_previewZoom)
    const label = document.getElementById('preview-zoom-label')
    if (label) label.textContent = _previewZoom + '%'
    localStorage.setItem(ZOOM_KEY, String(_previewZoom))
  }
  document.getElementById('preview-zoom-slider')?.addEventListener('input', (e) => {
    applyZoom(Number((e.target as HTMLInputElement).value))
  })
  document.getElementById('preview-zoom-in')?.addEventListener('click', () => applyZoom(_previewZoom + 10))
  document.getElementById('preview-zoom-out')?.addEventListener('click', () => applyZoom(_previewZoom - 10))
  document.getElementById('preview-zoom-reset')?.addEventListener('click', () => applyZoom(100))
  // Restore persisted zoom level
  ;(() => { const z = Number(localStorage.getItem(ZOOM_KEY)); if (z >= 50 && z <= 300) applyZoom(z) })()

  // ─── Presets ──────────────────────────────────────────────────────────────

  const PRESETS_KEY = 'filaman-label-presets-v1'
  const PRESETS_SCHEMA_VERSION = 1

  interface LabelPreset {
    name: string
    settings: LabelDesignerSettings
  }

  function loadPresets(): LabelPreset[] {
    const parsed = parseJsonOrNull(localStorage.getItem(PRESETS_KEY))
    if (!parsed) return []
    try {
      const payload = Array.isArray(parsed)
        ? { version: 0, presets: parsed }
        : parsed
      if (!Array.isArray(payload.presets)) return []
      return payload.presets
        .filter((p: any) => p && typeof p.name === 'string' && p.settings)
        .map((p: any) => ({
          name: p.name.trim().slice(0, 120),
          settings: mergeDesignerSettings(p.settings),
        }))
    } catch {
      localStorage.removeItem(PRESETS_KEY)
      return []
    }
  }

  function savePresets(presets: LabelPreset[]) {
    const payload = JSON.stringify({
      version: PRESETS_SCHEMA_VERSION,
      presets,
    })
    safeSetLocalStorage(PRESETS_KEY, payload)
  }

  // Track which preset is currently loaded (for dirty detection)
  let _activePresetName: string | null = null
  let _activePresetSettings: LabelDesignerSettings | null = null

  function markPresetDirty(dirty: boolean) {
    const hdr = document.getElementById('dsh-presets-text')
    if (!hdr) return
    const label = (window as any).__t('spools.dsPresets') || 'Presets'
    hdr.textContent = dirty ? `● ${label}` : label
    hdr.classList.toggle('ds-preset-dirty', dirty)
  }

  function refreshPresetList(selectName?: string) {
    const list = document.getElementById('ds-preset-list') as HTMLSelectElement
    if (!list) return
    const presets = loadPresets()
    list.innerHTML = ''
    if (presets.length === 0) {
      const opt = document.createElement('option')
      opt.value = ''
      opt.textContent = '— no saved presets —'
      opt.disabled = true
      opt.selected = true
      list.appendChild(opt)
    } else {
      // Add placeholder option at the top
      const placeholder = document.createElement('option')
      placeholder.value = ''
      placeholder.textContent = 'Saved presets'
      placeholder.disabled = true
      placeholder.selected = !selectName
      list.appendChild(placeholder)
      // Add preset options
      for (const p of presets) {
        const opt = document.createElement('option')
        opt.value = p.name
        opt.textContent = p.name
        list.appendChild(opt)
      }
      if (selectName) list.value = selectName
    }
    updateSaveBtn()
  }

  function updateSaveBtn() {
    const btn = document.getElementById('ds-preset-save-btn') as HTMLButtonElement
    const nameInput = document.getElementById('ds-preset-name-input') as HTMLInputElement
    if (!btn || !nameInput) return
    const name = nameInput.value.trim()
    const presets = loadPresets()
    const exists = presets.some(p => p.name === name)
    const tSaveNew = (window as any).__t('spools.dsPresetsSaveNew') || 'Save as New'
    const tOverwrite = (window as any).__t('spools.dsPresetsOverwrite') || 'Overwrite'
    if (!name) {
      btn.textContent = tSaveNew
      btn.className = 'ds-action-btn ds-action-btn-primary'
      btn.disabled = true
    } else if (exists) {
      btn.textContent = tOverwrite
      btn.className = 'ds-action-btn ds-action-btn-overwrite'
      btn.disabled = false
    } else {
      btn.textContent = tSaveNew
      btn.className = 'ds-action-btn ds-action-btn-primary'
      btn.disabled = false
    }
  }
  syncLogoManualControls()

  // Wire preset controls
  const presetList = document.getElementById('ds-preset-list') as HTMLSelectElement
  const presetNameInput = document.getElementById('ds-preset-name-input') as HTMLInputElement
  const presetSaveBtn = document.getElementById('ds-preset-save-btn') as HTMLButtonElement
  const presetLoadBtn = document.getElementById('ds-preset-load-btn') as HTMLButtonElement
  const presetDeleteBtn = document.getElementById('ds-preset-delete-btn') as HTMLButtonElement

  presetNameInput?.addEventListener('input', updateSaveBtn)

  presetList?.addEventListener('change', () => {
    // Pre-fill the name input with the selected preset name
    presetNameInput.value = presetList.value
    updateSaveBtn()
  })

  presetSaveBtn?.addEventListener('click', () => {
    const name = presetNameInput.value.trim()
    if (!name) return
    const presets = loadPresets()
    const idx = presets.findIndex(p => p.name === name)
    const settings = loadDesignerSettingsFromStorage()
    if (idx >= 0) {
      presets[idx].settings = settings
    } else {
      presets.push({ name, settings })
    }
    savePresets(presets)
    _activePresetName = name
    _activePresetSettings = JSON.parse(JSON.stringify(settings)) as LabelDesignerSettings
    markPresetDirty(false)
    refreshPresetList(name)
  })

  presetLoadBtn?.addEventListener('click', () => {
    const name = presetList.value
    if (!name) return
    const presets = loadPresets()
    const preset = presets.find(p => p.name === name)
    if (!preset) return
    // Deep merge into defaults then apply
    const s: LabelDesignerSettings = {
      ...DESIGNER_DEFAULTS,
      ...preset.settings,
      logo:   { ...DESIGNER_DEFAULTS.logo,   ...preset.settings.logo },
      label:  { ...DESIGNER_DEFAULTS.label,  ...preset.settings.label },
      title:  { ...DESIGNER_DEFAULTS.title,  ...preset.settings.title },
      title2: { ...DESIGNER_DEFAULTS.title2, ...(preset.settings.title2 ?? {}) },
      qr:     normalizeQrSettings((preset.settings as any).qr),
      info:   { ...DESIGNER_DEFAULTS.info,   ...preset.settings.info },
      info2:  { ...DESIGNER_DEFAULTS.info2,  ...(preset.settings.info2 ?? {}) },
    }
    // Apply to form using batch setter
    const presetLogoAny = (s as any).logo ?? {}
    const presetLogoSpace = Number(presetLogoAny.spaceMm ?? presetLogoAny.sizeMm ?? DESIGNER_DEFAULTS.logo.spaceMm)
    const presetLogoManual = Number(presetLogoAny.manualSizeMm ?? presetLogoAny.sizeMm ?? DESIGNER_DEFAULTS.logo.manualSizeMm)
    
    // Use batch setter to reduce duplication from ~100 repeated lines
    setFormFields([
      { id: 'ds-logo-show', value: s.logo.show },
      { id: 'ds-logo-space', value: presetLogoSpace, rangePartnerId: 'ds-logo-space-range' },
      { id: 'ds-logo-fit', value: s.logo.scaleToFit },
      { id: 'ds-logo-manual', value: presetLogoManual, rangePartnerId: 'ds-logo-manual-range' },
      { id: 'ds-width', value: s.label.width },
      { id: 'ds-height', value: s.label.height },
      { id: 'ds-margin', value: s.label.marginMm, rangePartnerId: 'ds-margin-range' },
      { id: 'ds-border', value: s.label.border },
      { id: 'ds-title-show', value: s.title.show },
      { id: 'ds-title-size', value: s.title.sizeMm, rangePartnerId: 'ds-title-size-range' },
      { id: 'ds-title-gap', value: s.title.marginMm ?? DESIGNER_DEFAULTS.title.marginMm, rangePartnerId: 'ds-title-gap-range' },
      { id: 'ds-title-fit', value: s.title.fitToWidth },
      { id: 'ds-title-tpl', value: s.title.template },
      { id: 'ds-divider-above', value: s.title.dividerAbove ?? false },
      { id: 'ds-divider-below', value: s.title.dividerBelow ?? true },
      { id: 'ds-title2-show', value: s.title2.show },
      { id: 'ds-title2-size', value: s.title2.sizeMm, rangePartnerId: 'ds-title2-size-range' },
      { id: 'ds-title2-gap', value: s.title2.marginMm ?? DESIGNER_DEFAULTS.title2.marginMm, rangePartnerId: 'ds-title2-gap-range' },
      { id: 'ds-title2-fit', value: s.title2.fitToWidth },
      { id: 'ds-title2-tpl', value: s.title2.template },
      { id: 'ds-title2-divider-above', value: s.title2.dividerAbove ?? false },
      { id: 'ds-title2-divider-below', value: s.title2.dividerBelow ?? false },
      { id: 'ds-qr-show', value: s.qr.show },
      { id: 'ds-qr-mode', value: s.qr.mode },
      { id: 'ds-qr-size', value: s.qr.sizeMm, rangePartnerId: 'ds-qr-size-range' },
      { id: 'ds-qr-url-tpl', value: s.qr.urlTemplate },
      { id: 'ds-info-show', value: s.info.show },
      { id: 'ds-info-size', value: s.info.sizeMm, rangePartnerId: 'ds-info-size-range' },
      { id: 'ds-info-tpl', value: s.info.template },
      { id: 'ds-info2-show', value: s.info2.show },
      { id: 'ds-info2-vsep', value: s.info2.vsep ?? false },
      { id: 'ds-info2-size', value: s.info2.sizeMm, rangePartnerId: 'ds-info2-size-range' },
      { id: 'ds-info2-tpl', value: s.info2.template },
    ])

    // Handle alignment groups and visibility toggles
    syncLogoManualControls()
    setAlignGroup('ds-logo-align-group', s.logo.align)
    setAlignGroup('ds-title-align-group', s.title.align)
    setAlignGroup('ds-title2-align-group', s.title2.align)
    setAlignGroup('ds-info-align-group', s.info.hAlign)
    setAlignGroup('ds-info2-align-group', s.info2.hAlign)
    setPillGroup('ds-qr-pos-group', s.qr.position)
    setPillGroup('ds-qr-valign-group', s.qr.vAlign)
    setPillGroup('ds-qr-link-group', s.qr.linkMode)
    setPillGroup('ds-info-valign-group', s.info.vAlign)
    setPillGroup('ds-info2-valign-group', s.info2.vAlign)

    ;(document.getElementById('ds-title2-block') as HTMLElement).style.display = s.title2.show ? '' : 'none'
    ;(document.getElementById('ds-info2-block') as HTMLElement).style.display = s.info2.show ? '' : 'none'
    ;(document.getElementById('ds-qr-url-wrap') as HTMLElement).style.display = s.qr.linkMode === 'url' ? '' : 'none'

    autosizeTemplateFields()
    saveDesignerSettings()
    _activePresetName = name
    _activePresetSettings = JSON.parse(JSON.stringify(s)) as LabelDesignerSettings
    presetNameInput.value = name
    markPresetDirty(false)
    updateSaveBtn()
    updateDesignerPreview()
  })

  presetDeleteBtn?.addEventListener('click', () => {
    const name = presetList.value
    if (!name) return
    const presets = loadPresets().filter(p => p.name !== name)
    savePresets(presets)
    if (_activePresetName === name) {
      _activePresetName = null
      _activePresetSettings = null
      markPresetDirty(false)
    }
    presetNameInput.value = ''
    refreshPresetList()
  })

  // Detect changes to any designer control → mark dirty if a preset is loaded
  function onDesignerChange() {
    if (_activePresetName !== null) markPresetDirty(true)
  }

  // Attach dirty listener to all designer inputs (after preset wiring, so order doesn't matter)
  document.querySelectorAll<HTMLElement>(
    '#tab-panel-designer input, #tab-panel-designer select, #tab-panel-designer textarea'
  ).forEach(el => {
    if (el.id === 'ds-preset-name-input') return  // not a settings input
    el.addEventListener('change', onDesignerChange)
