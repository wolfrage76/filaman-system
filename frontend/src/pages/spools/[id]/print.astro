---
import Layout from '../../../layouts/Layout.astro'

export function getStaticPaths() {
  return [
    {params: {id: 'detail'}},
  ];
}

const { id } = Astro.params
---

<Layout title="FilaMan - Print Label">
  <div class="print-page">
    <aside class="print-sidebar">
      <div class="print-sidebar-scroll">
      <a id="btn-back" class="sidebar-header back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        <span id="label-back">Zurück zur Spule</span>
      </a>

      <!-- Tab navigation -->
      <div class="tab-nav">
        <button class="tab-btn active" id="tab-btn-print" data-tab="print">Print Settings</button>
        <button class="tab-btn" id="tab-btn-designer" data-tab="designer">Label Designer</button>
      </div>

      <!-- Print Settings panel -->
      <div id="tab-panel-print" class="settings-section">
        <h3 id="title-settings">Print Settings</h3>

        <div>
          <label class="fm-label" id="label-width-text">Breite (mm)</label>
          <input type="number" id="input-width" value="60" class="fm-input">
        </div>

        <div>
          <label class="fm-label" id="label-height-text">Höhe (mm)</label>
          <input type="number" id="input-height" value="40" class="fm-input">
        </div>

        <div>
          <label class="fm-label" id="label-font-size-text">Schriftgröße (%)</label>
          <input type="range" id="input-font-size" min="50" max="200" value="100" class="fm-input" style="padding: 8px;">
        </div>

        <div>
          <label class="fm-label" id="label-qr-size-text">QR-Größe (mm)</label>
          <input type="number" id="input-qr-size" value="18" class="fm-input">
        </div>

        <h3>Anzeige</h3>
        <div class="checkbox-grid">
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-logo" checked>
            <span id="label-show-logo">Logo</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-qr" checked>
            <span id="label-show-qr">QR-Code</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-id" checked>
            <span id="label-show-id">Spool-ID</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-mfr" checked>
            <span id="label-show-mfr">Hersteller</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-mat" checked>
            <span id="label-show-mat">Material</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-color" checked>
            <span id="label-show-color">Farbe</span>
          </label>
          <label class="fm-checkbox-group">
            <input type="checkbox" id="check-color-swatch" checked>
            <span id="label-show-color-swatch">Farbbalken</span>
          </label>
        </div>

        <h3 id="title-extra-fields" style="display: none;">Extra-Felder</h3>
        <div id="extra-fields-checkboxes" class="checkbox-grid checkbox-grid-single" style="display: none;"></div>
      </div>

      <!-- Label Designer panel -->
      <div id="tab-panel-designer" class="settings-section" style="display: none;">

        <!-- Section: Presets -->
        <details class="ds-section" open>
          <summary class="ds-section-header" id="dsh-presets"><span id="dsh-presets-text">Presets</span></summary>
          <div class="ds-section-body">
            <div>
              <label class="fm-label" id="dsl-preset-saved">Saved presets</label>
              <div class="ds-preset-row">
                <select id="ds-preset-list" class="fm-input fm-select ds-preset-select"></select>
                <button id="ds-preset-load-btn" class="ds-action-btn">Load</button>
                <button id="ds-preset-delete-btn" class="ds-action-btn ds-action-btn-danger" title="Delete selected preset">✕</button>
              </div>
            </div>
            <div>
              <label class="fm-label" id="dsl-preset-name">Preset name</label>
              <div class="ds-preset-row">
                <input type="text" id="ds-preset-name-input" class="fm-input ds-preset-name-input" placeholder="My label">
                <button id="ds-preset-save-btn" class="ds-action-btn ds-action-btn-primary">Save as New</button>
              </div>
            </div>
          </div>
        </details>

        <!-- Section: Label -->
        <details class="ds-section" open>
          <summary class="ds-section-header" id="dsh-label">
            <span id="dsl-label-label">Label</span>
            <button class="ds-reset-btn" id="dsr-label" title="Reset section">↺</button>
          </summary>
          <div class="ds-section-body">
            <div class="ds-dim-grid">
              <div>
                <label class="fm-label" id="dsl-width">W (mm)</label>
                <input type="number" id="ds-width" value="60" min="10" max="300" class="fm-input">
              </div>
              <div>
                <label class="fm-label" id="dsl-height">H (mm)</label>
                <input type="number" id="ds-height" value="40" min="5" max="200" class="fm-input">
              </div>
            </div>
            <div class="ds-label-bottom-row">
              <label class="fm-checkbox-group ds-label-border-toggle">
                <input type="checkbox" id="ds-border">
                <span id="dsl-border">Print Border</span>
              </label>
              <div class="ds-size-row ds-size-row-compact ds-label-margin-inline">
                <label class="fm-label ds-size-label" id="dsl-margin">Margin (mm)</label>
                <input type="range" id="ds-margin-range" min="0" max="6" step="0.5" value="1" class="ds-slider">
                <input type="number" id="ds-margin" value="1" step="0.5" min="0" max="6" class="fm-input ds-size-num">
              </div>
            </div>
          </div>
        </details>

        <!-- Section: Logo -->
        <details class="ds-section" open>
          <summary class="ds-section-header" id="dsh-logo">
            <label class="ds-header-show" onclick="event.stopPropagation()">
              <input type="checkbox" id="ds-logo-show" checked>
              <span id="dsl-logo-label">Logo</span>
            </label>
            <button class="ds-reset-btn" id="dsr-logo" title="Reset section">↺</button>
          </summary>
          <div class="ds-section-body">
            <div class="ds-size-row">
              <label class="fm-label ds-size-label" id="dsl-logo-space">Space (mm)</label>
              <input type="range" id="ds-logo-space-range" min="2" max="20" step="0.5" value="6" class="ds-slider">
              <input type="number" id="ds-logo-space" value="6" step="0.5" min="2" max="20" class="fm-input ds-size-num">
            </div>
            <div class="ds-logo-fit-row">
              <div class="ds-logo-primary-inline">
                <label class="fm-checkbox-group ds-logo-fit-toggle">
                  <input type="checkbox" id="ds-logo-fit" checked>
                  <span id="dsl-logo-fit">Scale to fit bounds</span>
                </label>
                <div class="ds-logo-justify-inline">
                  <label class="fm-label ds-logo-justify-label" id="dsl-logo-align">Justification</label>
                  <div class="ds-align-group" id="ds-logo-align-group" data-value="left">
                    <button class="ds-align-btn active" data-align="left" title="Left">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>
                    </button>
                    <button class="ds-align-btn" data-align="center" title="Center">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
                    </button>
                    <button class="ds-align-btn" data-align="right" title="Right">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>
                    </button>
                  </div>
                </div>
              </div>
              <div class="ds-logo-manual-inline" id="ds-logo-manual-wrap" hidden>
                <label class="fm-label ds-logo-manual-label" id="dsl-logo-manual">Max logo height (mm)</label>
                <input type="range" id="ds-logo-manual-range" min="2" max="20" step="0.5" value="6" class="ds-slider">
                <input type="number" id="ds-logo-manual" value="6" step="0.5" min="2" max="20" class="fm-input ds-size-num">
              </div>
            </div>
          </div>
        </details>

        <!-- Section: Title -->
        <details class="ds-section" open>
          <summary class="ds-section-header" id="dsh-title">
            <label class="ds-header-show" onclick="event.stopPropagation()">
              <input type="checkbox" id="ds-title-show" checked>
              <span id="dsl-title-label">Title</span>
            </label>
            <button class="ds-reset-btn" id="dsr-title" title="Reset section">↺</button>
          </summary>
          <div class="ds-section-body">
            <div class="ds-size-row">
              <label class="fm-label ds-size-label" id="dsl-title-size">Max size (mm)</label>
              <input type="range" id="ds-title-size-range" min="1" max="20" step="0.5" value="4" class="ds-slider">
              <input type="number" id="ds-title-size" value="4" step="0.5" min="1" max="20" class="fm-input ds-size-num">
            </div>
            <div class="ds-options-row">
              <label class="fm-checkbox-group">
                <input type="checkbox" id="ds-title-fit" checked>
                <span id="dsl-title-fit">Fit to width</span>
              </label>
              <label class="fm-checkbox-group">
                <input type="checkbox" id="ds-divider-above">
                <span id="dsl-divider-above">Line above</span>
              </label>
              <label class="fm-checkbox-group">
                <input type="checkbox" id="ds-divider-below" checked>
                <span id="dsl-divider-below">Line below</span>
              </label>
            </div>
            <div>
              <div class="ds-align-combo">
                <div class="ds-align-main-inline">
                  <label class="fm-label ds-logo-justify-label" id="dsl-title-align">Justification</label>
                  <div class="ds-align-group" id="ds-title-align-group" data-value="left">
                    <button class="ds-align-btn active" data-align="left" title="Left">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>
                    </button>
                    <button class="ds-align-btn" data-align="center" title="Center">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
                    </button>
                    <button class="ds-align-btn" data-align="right" title="Right">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>
                    </button>
                  </div>
                </div>
                <div class="ds-title-gap-inline">
                  <label class="fm-label ds-mini-label" id="dsl-title-gap">Margin (mm)</label>
                  <div class="ds-size-row ds-size-row-compact">
                    <input type="range" id="ds-title-gap-range" min="-1" max="4" step="0.1" value="0" class="ds-slider">
                    <input type="number" id="ds-title-gap" value="0" min="-1" max="4" step="0.1" class="fm-input ds-size-num">
                  </div>
                </div>
              </div>
            </div>
            <div>
              <div class="ds-tpl-label-row">
                <label class="fm-label" id="dsl-title-tpl">Title Format</label>
                <button class="ds-syntax-btn" id="ds-title-syntax-btn" type="button" title="Template syntax help">?</button>
              </div>
              <textarea id="ds-title-tpl" class="fm-input ds-tpl-input ds-tpl-textarea" rows="1" placeholder="{filament.name}"></textarea>
              <div class="ds-token-area" id="ds-title-token-area"></div>
            </div>

            <div class="ds-secondary-toggle">
              <label class="fm-checkbox-group ds-secondary-check">
                <input type="checkbox" id="ds-title2-show">
                <span id="dsl-title2-show">Subtitle</span>
              </label>
            </div>

            <div id="ds-title2-block" class="ds-secondary-panel" style="display:none">
              <div class="ds-size-row">
                <label class="fm-label ds-size-label" id="dsl-title2-size">Max size (mm)</label>
                <input type="range" id="ds-title2-size-range" min="1" max="20" step="0.5" value="4" class="ds-slider">
                <input type="number" id="ds-title2-size" value="4" step="0.5" min="1" max="20" class="fm-input ds-size-num">
              </div>
              <div class="ds-options-row">
                <label class="fm-checkbox-group">
                  <input type="checkbox" id="ds-title2-fit" checked>
                  <span id="dsl-title2-fit">Fit to width</span>
                </label>
                <label class="fm-checkbox-group">
                  <input type="checkbox" id="ds-title2-divider-above">
                  <span id="dsl-title2-divider-above">Line above</span>
                </label>
                <label class="fm-checkbox-group">
                  <input type="checkbox" id="ds-title2-divider-below">
                  <span id="dsl-title2-divider-below">Line below</span>
                </label>
              </div>
              <div>
                <div class="ds-align-combo">
                  <div class="ds-align-main-inline">
                    <label class="fm-label ds-logo-justify-label" id="dsl-title2-align">Justification</label>
                    <div class="ds-align-group" id="ds-title2-align-group" data-value="left">
                      <button class="ds-align-btn active" data-align="left" title="Left">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>
                      </button>
                      <button class="ds-align-btn" data-align="center" title="Center">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
                      </button>
                      <button class="ds-align-btn" data-align="right" title="Right">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>
                      </button>
                    </div>
                  </div>
                  <div class="ds-title-gap-inline">
                    <label class="fm-label ds-mini-label" id="dsl-title2-gap">Margin (mm)</label>
                    <div class="ds-size-row ds-size-row-compact">
                      <input type="range" id="ds-title2-gap-range" min="-1" max="4" step="0.1" value="0" class="ds-slider">
                      <input type="number" id="ds-title2-gap" value="0" min="-1" max="4" step="0.1" class="fm-input ds-size-num">
                    </div>
                  </div>
                </div>
              </div>
              <div>
                <div class="ds-tpl-label-row">
                  <label class="fm-label" id="dsl-title2-tpl">Subtitle Format</label>
                  <button class="ds-syntax-btn" id="ds-title2-syntax-btn" type="button" title="Template syntax help">?</button>
                </div>
                <textarea id="ds-title2-tpl" class="fm-input ds-tpl-input ds-tpl-textarea" rows="1" placeholder="{filament.material}"></textarea>
                <div class="ds-token-area" id="ds-title2-token-area"></div>
              </div>
            </div>
          </div>
        </details>

        <!-- Section: QR Code -->
        <details class="ds-section" open>
          <summary class="ds-section-header" id="dsh-qr">
            <label class="ds-header-show" onclick="event.stopPropagation()">
              <input type="checkbox" id="ds-qr-show" checked>
              <span id="dsl-qr-label">QR Code</span>
            </label>
            <button class="ds-reset-btn" id="dsr-qr" title="Reset section">↺</button>
          </summary>
          <div class="ds-section-body">
            <div class="ds-qr-top-row">
              <div class="ds-qr-mode-inline">
                <label class="fm-label" id="dsl-qr-mode">Mode</label>
                <select id="ds-qr-mode" class="fm-input fm-select">
                  <option value="simple" selected id="dso-qr-simple">Simple</option>
                  <option value="logo" id="dso-qr-logo">Logo</option>
                  <option value="colorLogo" id="dso-qr-color-logo">Color Logo</option>
                </select>
              </div>
              <div class="ds-qr-size-inline">
                <label class="fm-label ds-size-label" id="dsl-qr-size">Size (mm)</label>
                <div class="ds-size-row ds-size-row-compact">
                  <input type="range" id="ds-qr-size-range" min="5" max="60" step="1" value="18" class="ds-slider">
                  <input type="number" id="ds-qr-size" value="18" step="1" min="5" max="60" class="fm-input ds-size-num">
                </div>
              </div>
            </div>
            <div>
              <label class="fm-label" id="dsl-qr-link">Link mode</label>
              <div class="ds-pill-group" id="ds-qr-link-group" data-value="spool">
                <button class="ds-pill-btn" data-val="url" id="dsp-qr-url">Custom URL</button>
                <button class="ds-pill-btn active" data-val="spool" id="dsp-qr-spool">Spool URL</button>
              </div>
            </div>
            <div id="ds-qr-url-wrap" style="display:none;">
              <label class="fm-label" id="dsl-qr-url-tpl">Custom URL base</label>
              <input type="text" id="ds-qr-url-tpl" class="fm-input ds-tpl-input" placeholder="https://example.com">
            </div>
            <div class="ds-two-col-row">
              <div class="ds-field-col">
                <label class="fm-label" id="dsl-qr-pos">Position</label>
                <div class="ds-pill-group" id="ds-qr-pos-group" data-value="right">
                  <button class="ds-pill-btn" data-val="left" id="dsp-qr-left">Left</button>
                  <button class="ds-pill-btn active" data-val="right" id="dsp-qr-right">Right</button>
                </div>
              </div>
              <div class="ds-field-col">
                <label class="fm-label" id="dsl-qr-valign">Vertical align</label>
                <div class="ds-pill-group" id="ds-qr-valign-group" data-value="bottom">
                  <button class="ds-pill-btn" data-val="top" id="dsp-qr-top">Top</button>
                  <button class="ds-pill-btn" data-val="center" id="dsp-qr-mid">Mid</button>
                  <button class="ds-pill-btn active" data-val="bottom" id="dsp-qr-bot">Bot</button>
                </div>
              </div>
            </div>
          </div>
        </details>

        <!-- Section: Information -->
        <details class="ds-section" open>
          <summary class="ds-section-header" id="dsh-info">
            <label class="ds-header-show" onclick="event.stopPropagation()">
              <input type="checkbox" id="ds-info-show" checked>
              <span id="dsl-info-label">Information</span>
            </label>
            <button class="ds-reset-btn" id="dsr-info" title="Reset section">↺</button>
          </summary>
          <div class="ds-section-body">
            <div class="ds-size-row">
              <label class="fm-label ds-size-label" id="dsl-info-size">Text size (mm)</label>
              <input type="range" id="ds-info-size-range" min="1" max="10" step="0.5" value="2.5" class="ds-slider">
              <input type="number" id="ds-info-size" value="2.5" step="0.5" min="1" max="10" class="fm-input ds-size-num">
            </div>
            <div class="ds-two-col-row">
              <div class="ds-field-col">
                <label class="fm-label" id="dsl-info-halign">Justification</label>
                <div class="ds-align-group" id="ds-info-align-group" data-value="left">
                  <button class="ds-align-btn active" data-align="left" title="Left">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>
                  </button>
                  <button class="ds-align-btn" data-align="center" title="Center">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
                  </button>
                  <button class="ds-align-btn" data-align="right" title="Right">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>
                  </button>
                </div>
              </div>
              <div class="ds-field-col">
                <label class="fm-label" id="dsl-info-valign">Vertical align</label>
                <div class="ds-pill-group" id="ds-info-valign-group" data-value="bottom">
                  <button class="ds-pill-btn" data-val="top" id="dsip-top">Top</button>
                  <button class="ds-pill-btn" data-val="center" id="dsip-mid">Mid</button>
                  <button class="ds-pill-btn active" data-val="bottom" id="dsip-bot">Bot</button>
                </div>
              </div>
            </div>
            <div>
              <div class="ds-tpl-label-row">
                <label class="fm-label" id="dsl-info-tpl">Information Format</label>
                <button class="ds-syntax-btn" id="ds-info-syntax-btn" type="button" title="Template syntax help">?</button>
              </div>
              <textarea id="ds-info-tpl" class="fm-input ds-tpl-input" rows="7" placeholder="{filament.material}&#10;{filament.color}&#10;Ext: {filament.extruder_temp}°C&#10;Bed: {filament.bed_temp}°C"></textarea>
              <div class="ds-token-area" id="ds-info-token-area"></div>
            </div>

            <!-- Second info column toggle -->
            <div class="ds-secondary-toggle">
              <label class="fm-checkbox-group ds-secondary-check">
                <input type="checkbox" id="ds-info2-show">
                <span id="dsl-info2-show">Side Column</span>
              </label>
            </div>

