  }

  @media print {
    /* Reset page */
    html, body {
      margin: 0 !important;
      padding: 0 !important;
      overflow: visible !important;
      background: white !important;
    }

    /* Hide Layout elements */
    .fm-sidebar,
    #fm-confirm-overlay,
    .fm-sidebar-backdrop {
      display: none !important;
    }

    /* Reset Layout grid to block - ensure visibility */
    .fm-page {
      display: block !important;
      visibility: visible !important;
      opacity: 1 !important;
      background: white !important;
      min-height: 0 !important;
      height: auto !important;
      position: static !important;
    }

    .fm-page > main {
      padding: 0 !important;
      margin: 0 !important;
      overflow: visible !important;
      background: white !important;
    }

    /* Hide print settings sidebar */
    .print-sidebar {
      display: none !important;
    }

    /* Reset print page containers */
    .print-page {
      margin: 0 !important;
      height: auto !important;
      display: block !important;
    }

    .preview-container {
      padding: 0 !important;
      margin: 0 !important;
      display: block !important;
      overflow: visible !important;
      background: white !important;
    }

    /* Hide UI chrome during print */
    .preview-zoom-bar {
      display: none !important;
    }

    /* The label */
    .label-preview {
      box-shadow: none !important;
      border: none !important;
      border-radius: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      background: white !important;
      color: black !important;
      margin: 0 !important;
      padding: var(--print-label-padding, 2mm) !important;
      overflow: hidden !important;
      break-inside: avoid !important;
      page-break-inside: avoid !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
      /* Dimensions set dynamically via JS #page-style tag */
    }

    .label-preview div,
    .label-preview span {
      color: inherit !important;
    }

    .label-color-swatch {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }

    .label-qr {
      flex-shrink: 0 !important;
    }

    .label-qr img {
      display: block !important;
    }

    .label-logo {
      display: block !important;
    }

    @page {
      /* margin set dynamically via JS #page-style tag */
    }
  }
</style>

<script>
  import { captureLabelElement, downloadDataUrl, saveLabelPagesAsPdf } from '../../../lib/label-export'
  import { initLabelDesignerEditor } from '../../../lib/label-designer-editor'
  import {
    buildSpoolDataFromFlatLabel,
    getDesignerLabelDimensions,
    loadDesignerSettingsFromStorage,
    renderDesignerLabel,
  } from '../../../lib/label-designer'
  import {
    buildStandardLabelDataFromFlat,
    getStandardLabelDimensions,
    renderStandardLabel,
    type StandardExtraField,
    type StandardLabelSettings,
  } from '../../../lib/label-standard'

  // Auto-collapse nav sidebar on the print page when the viewport is narrow —
  // the print page needs maximum horizontal space and the overlay would cover the controls.
  function applyPrintSidebarCollapse() {
    const page = document.getElementById('fm-page')
    if (!page) return
    if (window.innerWidth < 1100) {
      document.documentElement.classList.add('sidebar-collapsed')
      page.classList.add('collapsed')
      if (window.innerWidth > 768) {
        localStorage.setItem('sidebar-collapsed', 'true')
      }
    }
  }
  applyPrintSidebarCollapse()
  window.addEventListener('resize', applyPrintSidebarCollapse, { passive: true })

  // Global print function for Safari compatibility
  ;(window as any).filamanPrint = function() {
    try {
      // Try execCommand first (better Safari support)
      document.execCommand('print', false, undefined)
    } catch (e) {
      // Fallback to window.print
      window.print()
    }
  }

  const id = window.location.pathname.split('/').filter(Boolean).slice(-2, -1)[0]

  const params = new URLSearchParams(window.location.search)
  const labelData = {
    id: id,
    designation: params.get('designation') || '',
    manufacturer: params.get('mfr') || '',
    type: params.get('type') || '',
    color: params.get('color') || '',
    subtype: params.get('subtype') || '',
    mfr_id: params.get('mfr_id') || '',
    hex_code: params.get('hex_code') || '',
    extruder_temp: params.get('extruder_temp') || '',
    bed_temp: params.get('bed_temp') || '',
    weight: params.get('weight') || '',
    diameter: params.get('diameter') || '',
    finish: params.get('finish') || '',
    density: params.get('density') || '',
    price: params.get('price') || '',
  }


  let extraFields: {key: string, label: string, value: string, source?: string}[] = []
  try {
    const stored = sessionStorage.getItem('filaman-label-extra-fields')
    if (stored) {
      const parsed = JSON.parse(stored)
      if (Array.isArray(parsed)) {
        extraFields = parsed.filter((item) => (
          item &&
          typeof item.key === 'string' &&
          typeof item.label === 'string' &&
          typeof item.value === 'string'
        ))
      }
    }
  } catch(e) { /* ignore */ }

  const PRINT_DPI = 600
  const STORAGE_SOFT_LIMIT_BYTES = 4_500_000

  function safeSetLocalStorage(key: string, value: string) {
    if (value.length > STORAGE_SOFT_LIMIT_BYTES) {
      console.warn(`Skipped persisting ${key}: payload too large`) 
      return false
    }
    try {
      localStorage.setItem(key, value)
      return true
    } catch (error) {
      console.warn(`Failed to persist ${key}`, error)
      return false
    }
  }

  function parseJsonOrNull(raw: string | null): any | null {
    if (!raw) return null
    try {
      return JSON.parse(raw)
    } catch {
      return null
    }
  }

  function clampNumber(value: number, min: number, max: number, fallback: number) {
    if (!Number.isFinite(value)) return fallback
    return Math.min(max, Math.max(min, value))
  }

  function clampInputValue(input: HTMLInputElement, min: number, max: number, fallback: number, decimals = 2) {
    const next = clampNumber(Number(input.value), min, max, fallback)
    const normalized = Number(next.toFixed(decimals))
    input.value = String(normalized)
    return normalized
  }

  // Flat SpoolData object consumed by the template parser (Phase 3)
  // Keys match the {token} names used in designer templates.
  function buildSpoolData() {
    return buildSpoolDataFromFlatLabel({
      id: labelData.id,
      designation: labelData.designation,
      manufacturer: labelData.manufacturer,
      type: labelData.type,
      subtype: labelData.subtype,
      color: labelData.color,
      hex_code: labelData.hex_code,
      extruder_temp: labelData.extruder_temp,
      bed_temp: labelData.bed_temp,
      weight: labelData.weight,
      diameter: labelData.diameter,
      finish: labelData.finish,
      density: labelData.density,
      price: labelData.price,
      extraFields,
    })
  }

  // DOM references
  const widthInput = document.getElementById('input-width') as HTMLInputElement
  const heightInput = document.getElementById('input-height') as HTMLInputElement
  const fontSizeInput = document.getElementById('input-font-size') as HTMLInputElement
  const qrSizeInput = document.getElementById('input-qr-size') as HTMLInputElement
  const checkLogo = document.getElementById('check-logo') as HTMLInputElement
  const checkQR = document.getElementById('check-qr') as HTMLInputElement
  const checkID = document.getElementById('check-id') as HTMLInputElement
  const checkMfr = document.getElementById('check-mfr') as HTMLInputElement
  const checkMat = document.getElementById('check-mat') as HTMLInputElement
  const checkColor = document.getElementById('check-color') as HTMLInputElement
  const checkColorSwatch = document.getElementById('check-color-swatch') as HTMLInputElement
  const exportPngBtn = document.getElementById('btn-export-png') as HTMLButtonElement
  const exportPdfBtn = document.getElementById('btn-export-pdf') as HTMLButtonElement
  const labelPreview = document.getElementById('label-preview') as HTMLElement

  const LABEL_SETTINGS_KEY = 'filaman-label-settings'
  const ACTIVE_TAB_KEY = 'filaman-label-active-tab'

  // --- Tab switching ---
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn')
  const tabPanelPrint = document.getElementById('tab-panel-print') as HTMLElement | null
  const tabPanelDesigner = document.getElementById('tab-panel-designer') as HTMLElement | null
  const resetBtn = document.getElementById('btn-reset') as HTMLButtonElement | null
  let activePreviewTab: 'print' | 'designer' = 'print'
  let previewRenderVersion = 0

  function beginPreviewRender(tab: 'print' | 'designer') {
    activePreviewTab = tab
    const token = ++previewRenderVersion
    return () => activePreviewTab !== tab || token !== previewRenderVersion
  }

  function activateTab(tab: 'print' | 'designer') {
    if (!tabPanelPrint || !tabPanelDesigner || !labelPreview) return
    tabBtns.forEach(b => b.classList.toggle('active', b.dataset.tab === tab))
    tabPanelPrint.style.display = tab === 'print' ? '' : 'none'
    tabPanelDesigner.style.display = tab === 'designer' ? '' : 'none'
    if (resetBtn) resetBtn.style.display = tab === 'print' ? '' : 'none'
    localStorage.setItem(ACTIVE_TAB_KEY, tab)
    // Widen sidebar for designer, narrow for print settings
    document.querySelector<HTMLElement>('.print-sidebar')?.classList.toggle('sidebar-wide', tab === 'designer')
    // Trigger the appropriate preview when switching tabs — explicitly clear labelPreview first to ensure no cross-contamination
    if (tab === 'designer') {
      const isStale = beginPreviewRender('designer')
      // Clear any classic preview remnants before building designer layout
      labelPreview.innerHTML = ''
      labelPreview.style.border = ''
      labelPreview.style.padding = ''
      updateDesignerPreview(isStale)
    } else {
      const isStale = beginPreviewRender('print')
      // Force reset of classic layout detection before building print preview
      labelPreview.innerHTML = ''
      labelPreview.style.border = 'none'
      labelPreview.style.padding = ''
      updatePreview(isStale)
    }
  }

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => activateTab(btn.dataset.tab as 'print' | 'designer'))
  })

  // Restore last active tab — deferred until after designer setup completes
  const savedTab = localStorage.getItem(ACTIVE_TAB_KEY)

  // ─── Label Designer ────────────────────────────────────────────────────────

  const designerEditor = initLabelDesignerEditor({
    extraFields,
    getFilamentColorHex: () => labelData.hex_code,
    safeSetLocalStorage,
    translate: (key, fallback) => (window as any).__t?.(key) || fallback,
    onChange: () => updateDesignerPreview(),
  })

  // ─── Preview zoom ─────────────────────────────────────────────────────────

  const ZOOM_KEY = 'filaman-label-zoom-v1'
  const setZoomTitle = (id: string, key: string, fallback: string) => {
    const button = document.getElementById(id)
    if (!button) return
    const label = (window as any).__t?.(key) || fallback
    button.title = label
    button.setAttribute('aria-label', label)
  }
  setZoomTitle('preview-zoom-out', 'labelPrint.zoomOut', 'Zoom out')
  setZoomTitle('preview-zoom-in', 'labelPrint.zoomIn', 'Zoom in')
  setZoomTitle('preview-zoom-reset', 'labelPrint.zoomReset', 'Reset zoom')
  let _previewZoom = 100
  function applyZoom(z: number) {
    _previewZoom = Math.min(300, Math.max(50, Math.round(z / 5) * 5))
    const lp = document.getElementById('label-preview') as HTMLElement
    if (lp) { lp.style.transform = `scale(${_previewZoom / 100})`; lp.style.transformOrigin = 'center center' }
    ;(document.getElementById('preview-zoom-slider') as HTMLInputElement).value = String(_previewZoom)
    const label = document.getElementById('preview-zoom-label')
    if (label) label.textContent = _previewZoom + '%'
    localStorage.setItem(ZOOM_KEY, String(_previewZoom))
  }
  document.getElementById('preview-zoom-slider')?.addEventListener('input', (e) => {
    applyZoom(Number((e.target as HTMLInputElement).value))
  })
  document.getElementById('preview-zoom-in')?.addEventListener('click', () => applyZoom(_previewZoom + 10))
  document.getElementById('preview-zoom-out')?.addEventListener('click', () => applyZoom(_previewZoom - 10))
  document.getElementById('preview-zoom-reset')?.addEventListener('click', () => applyZoom(100))
  // Restore persisted zoom level
  ;(() => { const z = Number(localStorage.getItem(ZOOM_KEY)); if (z >= 50 && z <= 300) applyZoom(z) })()


  // Label logo state
  let labelLogoUrl: string | null = null
  let labelLogoLoaded = false

  // Try to load the manufacturer's label-logo
  async function loadLabelLogo() {
    if (!labelData.mfr_id) return
    try {
      const resp = await fetch(`/api/v1/manufacturers/${labelData.mfr_id}/label-logo`, {
        credentials: 'include',
      })
      if (resp.ok) {
        const blob = await resp.blob()
        labelLogoUrl = URL.createObjectURL(blob)
        labelLogoLoaded = true
      }
    } catch {
      // Label logo not available — fall back to manufacturer name text
    }
  }

  // Build extra field checkboxes dynamically
  const extraFieldsTitle = document.getElementById('title-extra-fields')!
  const extraFieldsCheckboxes = document.getElementById('extra-fields-checkboxes')!
  const extraFieldChecks: {key: string, label: string, value: string, checkbox: HTMLInputElement}[] = []

  let savedExtraFieldSettings: Record<string, boolean> = {}
  const parsedClassicSettings = parseJsonOrNull(localStorage.getItem(LABEL_SETTINGS_KEY))
  if (parsedClassicSettings?.extraFields && typeof parsedClassicSettings.extraFields === 'object') {
    savedExtraFieldSettings = parsedClassicSettings.extraFields as Record<string, boolean>
  }

  if (extraFields.length > 0) {
    extraFieldsTitle.style.display = ''
    extraFieldsCheckboxes.style.display = ''
    const hasBothSources = extraFields.some(ef => ef.source === 'spool') && extraFields.some(ef => ef.source === 'filament')

    // Copy Astro scoped-style attribute from existing checkboxes so dynamic elements get the same styles
    const scopeAttr = (() => {
      const existing = document.querySelector('.fm-checkbox-group')
      if (!existing) return null
      return Array.from(existing.attributes).find(a => a.name.startsWith('data-astro-cid-'))
    })()

    for (const ef of extraFields) {
      const lbl = document.createElement('label')
      lbl.className = 'fm-checkbox-group'
      const cb = document.createElement('input')
      cb.type = 'checkbox'
      cb.id = `check-ef-${ef.key}`
      cb.checked = savedExtraFieldSettings[ef.key] || false
      const span = document.createElement('span')
      span.textContent = hasBothSources ? `${ef.label} (${ef.source === 'spool' ? ((window as any).__t('dashboard.spool') || 'Spool') : ((window as any).__t('spools.filament') || 'Filament')})` : ef.label
      if (scopeAttr) {
        lbl.setAttribute(scopeAttr.name, '')
        cb.setAttribute(scopeAttr.name, '')
        span.setAttribute(scopeAttr.name, '')
      }
      lbl.appendChild(cb)
      lbl.appendChild(span)
      extraFieldsCheckboxes.appendChild(lbl)
      extraFieldChecks.push({ key: ef.key, label: ef.label, value: ef.value, checkbox: cb })
      cb.addEventListener('change', () => updatePreview())
    }
  }

  function saveSettings() {
    const settings: Record<string, any> = {
      width: (widthInput as HTMLInputElement).value,
      height: (heightInput as HTMLInputElement).value,
      fontSize: (fontSizeInput as HTMLInputElement).value,
      qrSize: (qrSizeInput as HTMLInputElement).value,
      showLogo: checkLogo.checked,
      showQR: checkQR.checked,
      showID: checkID.checked,
      showMfr: checkMfr.checked,
      showMat: checkMat.checked,
      showColor: checkColor.checked,
      showColorSwatch: checkColorSwatch.checked,
      extraFields: extraFieldChecks.reduce((acc, ef) => {
        acc[ef.key] = ef.checkbox.checked
        return acc
      }, {} as Record<string, boolean>)
    }
    safeSetLocalStorage(LABEL_SETTINGS_KEY, JSON.stringify(settings))
  }

  function loadSettings() {
    const s = parseJsonOrNull(localStorage.getItem(LABEL_SETTINGS_KEY))
    if (!s || typeof s !== 'object') return
    if (s.width !== undefined) widthInput.value = String(s.width)
    if (s.height !== undefined) heightInput.value = String(s.height)
    if (s.fontSize !== undefined) fontSizeInput.value = String(s.fontSize)
    if (s.qrSize !== undefined) qrSizeInput.value = String(s.qrSize)
    clampInputValue(widthInput, 20, 200, 60, 0)
    clampInputValue(heightInput, 10, 120, 40, 0)
    clampInputValue(fontSizeInput, 50, 200, 100, 0)
    clampInputValue(qrSizeInput, 8, 40, 18, 1)
    if (s.showLogo !== undefined) checkLogo.checked = !!s.showLogo
    if (s.showQR !== undefined) checkQR.checked = !!s.showQR
    if (s.showID !== undefined) checkID.checked = !!s.showID
    if (s.showMfr !== undefined) checkMfr.checked = !!s.showMfr
    if (s.showMat !== undefined) checkMat.checked = !!s.showMat
    if (s.showColor !== undefined) checkColor.checked = !!s.showColor
    if (s.showColorSwatch !== undefined) checkColorSwatch.checked = !!s.showColorSwatch
  }

  loadSettings()

  document.getElementById('tab-btn-print')!.textContent = (window as any).__t('spools.printSettings') || 'Print Settings'
  document.getElementById('tab-btn-designer')!.textContent = (window as any).__t('spools.labelDesigner') || 'Label Designer'
  document.getElementById('title-settings')!.textContent = (window as any).__t('spools.printSettings')

  document.getElementById('label-width-text')!.textContent = (window as any).__t('spools.labelWidth')
  document.getElementById('label-height-text')!.textContent = (window as any).__t('spools.labelHeight')
  document.getElementById('label-font-size-text')!.textContent = (window as any).__t('spools.fontSize')
  document.getElementById('label-qr-size-text')!.textContent = (window as any).__t('spools.qrSize')
  document.getElementById('label-show-logo')!.textContent = (window as any).__t('spools.showLogo') || 'Logo'
  document.getElementById('label-show-qr')!.textContent = (window as any).__t('spools.showQRCode')
  document.getElementById('label-show-id')!.textContent = (window as any).__t('spools.showSpoolId')
  document.getElementById('label-show-mfr')!.textContent = (window as any).__t('spools.showManufacturer')
  document.getElementById('label-show-mat')!.textContent = (window as any).__t('spools.showMaterial')
  document.getElementById('label-show-color')!.textContent = (window as any).__t('spools.showColor')
  document.getElementById('label-show-color-swatch')!.textContent = (window as any).__t('spools.showColorSwatch') || 'Color Swatch'
  if (extraFields.length > 0) {
    document.getElementById('title-extra-fields')!.textContent = (window as any).__t('spools.extraFieldsLabel')
  }
  const backBtn = document.getElementById('btn-back') as HTMLAnchorElement
  backBtn.href = `/spools/${id}`
  document.getElementById('label-back')!.textContent = (window as any).__t('spools.backToSpool')
  exportPngBtn.textContent = (window as any).__t('labelPrint.btnExportPng') || 'Export PNG'
  exportPdfBtn.textContent = (window as any).__t('labelPrint.btnExportPdf') || 'Export PDF'
  document.getElementById('btn-print')!.textContent = (window as any).__t('common.print')
  document.getElementById('btn-reset')!.textContent = (window as any).__t('spools.resetDefaults')

  function getSelectedStandardExtraFields(): StandardExtraField[] {
    return extraFieldChecks
      .filter(ef => ef.checkbox.checked)
      .map(ef => ({ label: ef.label, value: ef.value }))
  }

  function getStandardSettings(): StandardLabelSettings {
    return {
      widthMm: clampInputValue(widthInput, 20, 200, 60, 0),
      heightMm: clampInputValue(heightInput, 10, 120, 40, 0),
      fontScale: clampInputValue(fontSizeInput, 50, 200, 100, 0) / 100,
      qrSizeMm: clampInputValue(qrSizeInput, 8, 40, 18, 1),
      showLogo: checkLogo.checked,
      showQR: checkQR.checked,
      showID: checkID.checked,
      showManufacturer: checkMfr.checked,
      showMaterial: checkMat.checked,
      showColor: checkColor.checked,
      showColorSwatch: checkColorSwatch.checked,
    }
  }

  function buildStandardData() {
    return buildStandardLabelDataFromFlat({
      id: labelData.id,
      designation: labelData.designation,
      manufacturer: labelData.manufacturer,
      material: labelData.type,
      colorName: labelData.color,
      hexCode: labelData.hex_code,
      extraFields: getSelectedStandardExtraFields(),
    })
  }

  async function updatePreview(isStale = () => false) {
    if (activePreviewTab !== 'print') return
    if (isStale() || activePreviewTab !== 'print') return

    labelPreview.style.border = 'none'
    labelPreview.style.padding = ''
    await renderStandardLabel({
      element: labelPreview,
      data: buildStandardData(),
      settings: getStandardSettings(),
      logoUrl: labelLogoLoaded ? labelLogoUrl : null,
      isStale: () => isStale() || activePreviewTab !== 'print',
    })
    if (isStale() || activePreviewTab !== 'print') return
    saveSettings()
  }

  ;[widthInput, heightInput, fontSizeInput, qrSizeInput, checkLogo, checkQR, checkID, checkMfr, checkMat, checkColor, checkColorSwatch].forEach(el => {
    el.addEventListener('change', () => updatePreview())
    if ((el as HTMLInputElement).type === 'range' || (el as HTMLInputElement).type === 'number') {
      el.addEventListener('input', () => updatePreview())
    }
  })

  // ─── Designer preview ─────────────────────────────────────────────────────

  async function updateDesignerPreview(isStale = () => false) {
    if (activePreviewTab !== 'designer') return
    if (isStale() || activePreviewTab !== 'designer') return

    await renderDesignerLabel({
      element: labelPreview,
      settings: loadDesignerSettingsFromStorage(),
      data: buildSpoolData(),
      logoUrl: labelLogoLoaded ? labelLogoUrl : null,
      isStale: () => isStale() || activePreviewTab !== 'designer',
    })
  }

  // ─── Export ───────────────────────────────────────────────────────────────

  function getTranslation(key: string, fallback: string) {
    return (window as any).__t?.(key) || fallback
  }

  function sanitizeFilename(value: string) {
    return value
      .trim()
      .replace(/[<>:"/\\|?*\x00-\x1F]/g, '-')
      .replace(/\s+/g, ' ')
      .replace(/\.+$/g, '')
  }

  function buildExportBaseName() {
    const mode = activePreviewTab === 'designer' ? 'designer' : 'classic'
    const parts = [
      'spool-label',
      labelData.manufacturer,
      labelData.designation,
      labelData.id ? `spool-${labelData.id}` : '',
      mode,
    ].filter(Boolean)
    return sanitizeFilename(parts.join(' - ')) || `spool-label-${mode}`
  }

  function getActiveLabelDimensions() {
    if (activePreviewTab === 'designer') {
      return getDesignerLabelDimensions(loadDesignerSettingsFromStorage())
    }

    return getStandardLabelDimensions(getStandardSettings())
  }

  async function refreshActiveLabelPreview() {
    if (activePreviewTab === 'designer') {
      await updateDesignerPreview()
    } else {
      await updatePreview()
    }
  }

  async function captureActiveLabelPng() {
    await refreshActiveLabelPreview()
    return captureLabelElement(labelPreview, {
      pixelRatio: PRINT_DPI / 96,
      resetTransform: true,
    })
  }

  async function withExportButtonsDisabled(action: () => Promise<void>) {
    const pngText = exportPngBtn.textContent
    const pdfText = exportPdfBtn.textContent
    exportPngBtn.disabled = true
    exportPdfBtn.disabled = true
    exportPngBtn.textContent = getTranslation('labelPrint.exporting', 'Exporting...')
    exportPdfBtn.textContent = getTranslation('labelPrint.exporting', 'Exporting...')
    try {
      await action()
    } finally {
      exportPngBtn.disabled = false
      exportPdfBtn.disabled = false
      exportPngBtn.textContent = pngText
      exportPdfBtn.textContent = pdfText
    }
  }

  async function exportActiveLabelAsPng() {
    await withExportButtonsDisabled(async () => {
      try {
        downloadDataUrl(await captureActiveLabelPng(), `${buildExportBaseName()}.png`)
      } catch (error) {
        alert(getTranslation('labelPrint.pngExportFailed', 'PNG export failed. Please check that all label images and logos loaded correctly.'))
        console.error('Failed to export label PNG:', error)
      }
    })
  }

  async function exportActiveLabelAsPdf() {
    await withExportButtonsDisabled(async () => {
      try {
        const { widthMm, heightMm } = getActiveLabelDimensions()
        await saveLabelPagesAsPdf(
          [{ dataUrl: await captureActiveLabelPng(), widthMm, heightMm }],
          `${buildExportBaseName()}.pdf`,
        )
      } catch (error) {
        alert(getTranslation('labelPrint.pdfExportFailed', 'PDF export failed. Please check that all label images and logos loaded correctly.'))
        console.error('Failed to export label PDF:', error)
      }
    })
  }

  exportPngBtn.addEventListener('click', exportActiveLabelAsPng)
  exportPdfBtn.addEventListener('click', exportActiveLabelAsPdf)

  document.getElementById('btn-reset')?.addEventListener('click', () => {
    localStorage.removeItem(LABEL_SETTINGS_KEY);
    (widthInput as HTMLInputElement).value = '60';
    (heightInput as HTMLInputElement).value = '40';
    (fontSizeInput as HTMLInputElement).value = '100';
    (qrSizeInput as HTMLInputElement).value = '18';
    checkLogo.checked = true;
    checkQR.checked = true;
    checkID.checked = true;
    checkMfr.checked = true;
    checkMat.checked = true;
    checkColor.checked = true;
    checkColorSwatch.checked = true;
    for (const ef of extraFieldChecks) {
      ef.checkbox.checked = false
    }
    updatePreview()
  })

  // Restore active tab now that all designer state is fully initialized
  if (savedTab === 'designer') activateTab('designer')

  // Initialize: load logo then render whichever tab is active
  loadLabelLogo().then(() => {
    const activeTab = localStorage.getItem(ACTIVE_TAB_KEY)
    if (activeTab === 'designer') activateTab('designer')
    else activateTab('print')
  })

  // Fallback: if no extra fields came from sessionStorage (e.g. direct navigation),
  // fetch definitions from the API and rebuild the extra-fields UI.
  if (extraFields.length === 0) {
    ;(async () => {
      try {
        const [spoolDefs, filamentDefs] = await Promise.all([
          fetch('/api/v1/system-extra-fields?target_type=spool', { credentials: 'include' }).then(r => r.ok ? r.json() : []),
          fetch('/api/v1/system-extra-fields?target_type=filament', { credentials: 'include' }).then(r => r.ok ? r.json() : []),
        ])
        const allDefs: {key: string, label: string, target_type: string}[] = [
          ...(Array.isArray(spoolDefs) ? spoolDefs : []).map((d: {key: string, label: string}) => ({...d, target_type: 'spool'})),
          ...(Array.isArray(filamentDefs) ? filamentDefs : []).map((d: {key: string, label: string}) => ({...d, target_type: 'filament'})),
        ]
        if (allDefs.length === 0) return

        // Attempt to get actual spool values
        const spoolCustom: Record<string, string> = {}
        const filamentCustom: Record<string, string> = {}
        const spoolRes = await fetch(`/api/v1/spools/${id}`, { credentials: 'include' })
        if (spoolRes.ok) {
          const sd = await spoolRes.json()
          if (sd.custom_fields) {
            for (const [k, v] of Object.entries(sd.custom_fields as Record<string, unknown>)) {
              if (v !== null && v !== undefined) spoolCustom[k] = String(v)
            }
          }
          if (sd.filament?.custom_fields) {
            for (const [k, v] of Object.entries(sd.filament.custom_fields as Record<string, unknown>)) {
              if (v !== null && v !== undefined) filamentCustom[k] = String(v)
            }
          }
        }

        // Populate extraFields and rebuild UI
        const hasBothSources = allDefs.some(d => d.target_type === 'spool') && allDefs.some(d => d.target_type === 'filament')
        const scopeAttr = (() => {
          const existing = document.querySelector('.fm-checkbox-group')
          if (!existing) return null
          return Array.from(existing.attributes).find(a => a.name.startsWith('data-astro-cid-'))
        })()

        for (const def of allDefs) {
          const valueMap = def.target_type === 'spool' ? spoolCustom : filamentCustom
          const ef = {
            key: `${def.target_type}.${def.key}`,
            label: def.label,
            value: valueMap[def.key] ?? '',
            source: def.target_type,
          }
          extraFields.push(ef)

          const lbl = document.createElement('label')
          lbl.className = 'fm-checkbox-group'
          const cb = document.createElement('input')
          cb.type = 'checkbox'
          cb.id = `check-ef-${ef.key}`
          cb.checked = savedExtraFieldSettings[ef.key] || false
          const span = document.createElement('span')
          span.textContent = hasBothSources
            ? `${ef.label} (${def.target_type === 'spool' ? ((window as any).__t('dashboard.spool') || 'Spool') : ((window as any).__t('spools.filament') || 'Filament')})`
            : ef.label
          if (scopeAttr) {
            lbl.setAttribute(scopeAttr.name, '')
            cb.setAttribute(scopeAttr.name, '')
            span.setAttribute(scopeAttr.name, '')
          }
          lbl.appendChild(cb)
          lbl.appendChild(span)
          extraFieldsCheckboxes.appendChild(lbl)
          extraFieldChecks.push({ key: ef.key, label: ef.label, value: ef.value, checkbox: cb })
          cb.addEventListener('change', () => updatePreview())
        }

        // Show the print-settings extra-fields section
        extraFieldsTitle.style.display = ''
        extraFieldsCheckboxes.style.display = ''
        document.getElementById('title-extra-fields')!.textContent = (window as any).__t('spools.extraFieldsLabel') || 'Extra Fields'

        // Rebuild token areas in the designer so extra-field chips appear.
        designerEditor.refreshExtraFields(extraFields)

        updatePreview()
      } catch { /* ignore */ }
    })()
  }
</script>
