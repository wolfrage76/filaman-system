  async function updatePreview(isStale = () => false) {
    if (activePreviewTab !== 'print') return
    if (typeof (window as any).QRCode === 'undefined') {
      await new Promise((resolve, reject) => {
        const script = document.createElement('script')
        script.src = '/vendor/qrcode.min.js'
        script.onload = resolve
        script.onerror = reject
        document.head.appendChild(script)
      })
    }
    if (isStale() || activePreviewTab !== 'print') return

    ensureClassicPreviewLayout()
    const qrContainer = document.getElementById('label-qr-container') as HTMLElement

    const widthMm = clampInputValue(widthInput, 20, 200, 60, 0)
    const heightMm = clampInputValue(heightInput, 10, 120, 40, 0)
    const qrSizeMm = clampInputValue(qrSizeInput, 8, 40, 18, 1)
    const fontSizeBase = clampInputValue(fontSizeInput, 50, 200, 100, 0) / 100
    const w = String(widthMm)
    const h = String(heightMm)
    const qrSize = String(qrSizeMm)

    labelPreview.style.border = 'none'
    labelPreview.style.padding = ''
    labelPreview.style.width = w + 'mm'
    labelPreview.style.height = h + 'mm'
    labelPreview.style.setProperty('--print-label-padding', '2mm')
    labelPreview.style.setProperty('--inner-border-style', 'none')
    labelPreview.style.setProperty('--inner-border-inset', '2mm')

    // === TOP: Logo / Manufacturer ===
    const topArea = document.getElementById('label-top')!
    const topDivider = document.getElementById('label-top-divider')!
    const logoImg = document.getElementById('prev-logo') as HTMLImageElement
    const mfrTextEl = document.getElementById('prev-mfr-text')!

    const showLogo = checkLogo.checked
    const showMfr = checkMfr.checked

    if (showLogo && labelLogoLoaded && labelLogoUrl) {
      logoImg.src = labelLogoUrl
      logoImg.style.display = 'block'
      logoImg.style.maxHeight = (fontSizeBase * 8) + 'mm'
      mfrTextEl.style.display = 'none'
      topArea.style.display = 'flex'
      topDivider.style.display = 'block'
    } else if (showLogo && showMfr && labelData.manufacturer) {
      // No logo available — show manufacturer name as text in top area
      logoImg.style.display = 'none'
      mfrTextEl.textContent = labelData.manufacturer
      mfrTextEl.style.display = 'block'
      mfrTextEl.style.fontSize = (fontSizeBase * 11) + 'pt'
      topArea.style.display = 'flex'
      topDivider.style.display = 'block'
    } else if (showMfr && labelData.manufacturer) {
      logoImg.style.display = 'none'
      mfrTextEl.textContent = labelData.manufacturer
      mfrTextEl.style.display = 'block'
      mfrTextEl.style.fontSize = (fontSizeBase * 11) + 'pt'
      topArea.style.display = 'flex'
      topDivider.style.display = 'block'
    } else {
      topArea.style.display = 'none'
      topDivider.style.display = 'none'
    }

    // === MIDDLE: Designation + Color ===
    const filamentEl = document.getElementById('prev-filament')!
    const matText = checkMat.checked ? labelData.type : ''
    const desigText = labelData.designation || ''
    const fullDesig = [desigText, matText].filter(Boolean).join(' ')
    filamentEl.textContent = fullDesig
    filamentEl.style.fontSize = (fontSizeBase * 12) + 'pt'
    filamentEl.style.display = fullDesig ? 'block' : 'none'

    // Color row: swatch + name
    const colorRow = document.getElementById('prev-color-row')!
    const colorSwatch = document.getElementById('prev-color-swatch')!
    const colorName = document.getElementById('prev-color-name')!
    const hexCodeEl = document.getElementById('prev-hex-code')!

    const showColor = checkColor.checked
    const showSwatch = checkColorSwatch.checked
    const hasHex = !!labelData.hex_code

    if (showSwatch && hasHex) {
      colorSwatch.style.display = 'block'
      colorSwatch.style.backgroundColor = labelData.hex_code.startsWith('#') ? labelData.hex_code : `#${labelData.hex_code}`
    } else {
      colorSwatch.style.display = 'none'
    }

    if (showColor && labelData.color) {
      colorName.textContent = labelData.color
      colorName.style.display = 'inline'
      colorName.style.fontSize = (fontSizeBase * 10) + 'pt'
    } else {
      colorName.style.display = 'none'
    }

    colorRow.style.display = (showColor || showSwatch) ? 'flex' : 'none'

    if (hasHex && (showColor || showSwatch)) {
      const hexStr = labelData.hex_code.startsWith('#') ? labelData.hex_code.toUpperCase() : `#${labelData.hex_code.toUpperCase()}`
      hexCodeEl.textContent = hexStr
      hexCodeEl.style.display = 'block'
      hexCodeEl.style.fontSize = (fontSizeBase * 9) + 'pt'
    } else {
      hexCodeEl.style.display = 'none'
    }

    // === BOTTOM: ID + Extra fields + QR ===
    const idEl = document.getElementById('prev-id')!
    if (checkID.checked) {
      idEl.textContent = `#${labelData.id}`
      idEl.style.display = 'block'
      idEl.style.fontSize = (fontSizeBase * 7.5) + 'pt'
    } else {
      idEl.style.display = 'none'
    }

    // Extra fields
    const extraContainer = document.getElementById('prev-extra-fields')!
    extraContainer.innerHTML = ''
    for (const ef of extraFieldChecks) {
      if (ef.checkbox.checked) {
        const div = document.createElement('div')
        div.style.fontSize = (fontSizeBase * 7) + 'pt'
        div.style.color = 'black'
        div.style.whiteSpace = 'nowrap'
        div.style.overflow = 'hidden'
        div.style.textOverflow = 'ellipsis'
        div.style.lineHeight = '1.3'
        const labelSpan = document.createElement('span')
        labelSpan.style.color = '#555'
        labelSpan.textContent = ef.label + ':'
        div.appendChild(labelSpan)
        div.appendChild(document.createTextNode(' ' + ef.value))
        extraContainer.appendChild(div)
      }
    }

    // QR Code
    qrContainer.style.display = checkQR.checked ? 'block' : 'none'
    if (checkQR.checked) {
      qrContainer.innerHTML = ''
      const url = window.location.origin + '/spools/' + labelData.id
      const qrPx = Math.min(1024, Math.max(256, Math.round(qrSizeMm * (PRINT_DPI / 25.4))))

      // @ts-expect-error — QRCode loaded dynamically
      new QRCode(qrContainer, {
        text: url,
        width: qrPx,
        height: qrPx,
        colorDark: "#000000",
        colorLight: "#ffffff",
        correctLevel: (window as any).QRCode.CorrectLevel.H
      })

      qrContainer.style.width = qrSize + 'mm'
      qrContainer.style.height = qrSize + 'mm'
      qrContainer.style.imageRendering = 'pixelated'

      const canvas = qrContainer.querySelector('canvas')
      if (canvas) {
        qrContainer.innerHTML = ''
        qrContainer.appendChild(canvasToQrImage(canvas as HTMLCanvasElement, true))
      }

      qrContainer.style.flexShrink = '0'
    }

    // Print styles
    const isSafari = /Safari/.test(navigator.userAgent) && !/Chrome/.test(navigator.userAgent)
    const style = document.createElement('style')
    // Safari doesn't support @page { size } — use default page margins so label stays in printable area
    // Chrome/Edge support @page { size } — set exact label dimensions with no margin
    const pageRule = isSafari
      ? ''
      : `@page { size: ${w}mm ${h}mm; margin: 0; }`
    style.innerHTML = `
      ${pageRule}
      @media print {
        .label-preview {
          width: ${w}mm !important;
          height: ${h}mm !important;
          min-width: ${w}mm !important;
          min-height: ${h}mm !important;
          max-width: ${w}mm !important;
          max-height: ${h}mm !important;
          transform: none !important;
          transform-origin: unset !important;
        }
      }
    `
    const oldStyle = document.querySelector('style#page-style')
    if (oldStyle) oldStyle.remove()
    style.id = 'page-style'
    document.head.appendChild(style)
    if (isStale() || activePreviewTab !== 'print') return
    saveSettings()
  }

  ;[widthInput, heightInput, fontSizeInput, qrSizeInput, checkLogo, checkQR, checkID, checkMfr, checkMat, checkColor, checkColorSwatch].forEach(el => {
    el.addEventListener('change', () => updatePreview())
    if ((el as HTMLInputElement).type === 'range' || (el as HTMLInputElement).type === 'number') {
      el.addEventListener('input', () => updatePreview())
    }
  })

  // ─── Designer preview ─────────────────────────────────────────────────────

  async function updateDesignerPreview(isStale = () => false) {
    if (activePreviewTab !== 'designer') return
    // Load QR library if needed
    if (typeof (window as any).QRCode === 'undefined') {
      await new Promise((resolve, reject) => {
        const script = document.createElement('script')
        script.src = '/vendor/qrcode.min.js'
        script.onload = resolve
        script.onerror = reject
        document.head.appendChild(script)
      })
    }
    if (isStale() || activePreviewTab !== 'designer') return

    const s = loadDesignerSettingsFromStorage()

    const data = buildSpoolData() as SpoolData

    // --- Size & border ---
    const w = clampNumber(Number(s.label.width), 20, 300, DESIGNER_DEFAULTS.label.width)
    const h = clampNumber(Number(s.label.height), 10, 200, DESIGNER_DEFAULTS.label.height)
    const marginMm = Math.max(0, Number(s.label.marginMm ?? DESIGNER_DEFAULTS.label.marginMm))
    const borderWidthMm = 0.3
    const borderTextGapMm = borderWidthMm
    const contentInsetMm = marginMm + (s.label.border ? (borderWidthMm + borderTextGapMm) : 0)
    labelPreview.style.width = w + 'mm'
    labelPreview.style.height = h + 'mm'
    labelPreview.style.padding = contentInsetMm + 'mm'
    labelPreview.style.border = '1px dashed #ccc'
    labelPreview.style.setProperty('--print-label-padding', contentInsetMm + 'mm')
    labelPreview.style.setProperty('--inner-border-style', s.label.border ? '0.3mm solid black' : 'none')
    labelPreview.style.setProperty('--inner-border-inset', marginMm + 'mm')

    // Clear and rebuild preview in designer layout
    labelPreview.innerHTML = ''

    // --- Logo row (if logo enabled and available) ---
    const makeRule = () => {
      const r = document.createElement('div')
      r.style.borderTop = '0.3mm solid black'
      r.style.margin = '0'
      return r
    }
    const hasLogo = s.logo?.show !== false && labelLogoLoaded && labelLogoUrl
    const hasTitle1 = !!(s.title.show && s.title.template.trim())
    const hasTitle2 = !!(s.title2?.show && s.title2.template.trim())

    // Rule ABOVE logo/title block — no longer used here, moved below logo
    // (kept for structure reference)

    if (hasLogo) {
      const logoRow = document.createElement('div')
      logoRow.style.padding = '0 0 0.5mm 0'
      logoRow.style.display = 'flex'
      logoRow.style.alignItems = 'center'
      const logoAlign = s.logo?.align ?? 'left'
      const logoImg = document.createElement('img')
      logoImg.src = labelLogoUrl!
      const logoAny = (s.logo ?? {}) as any
      const logoSpaceMm = Number(logoAny.spaceMm ?? logoAny.sizeMm ?? DESIGNER_DEFAULTS.logo.spaceMm)
      const logoManualMm = Number(logoAny.manualSizeMm ?? logoAny.sizeMm ?? DESIGNER_DEFAULTS.logo.manualSizeMm)
      const logoSpacePx = Math.max(1, Math.round(logoSpaceMm * MM_TO_PX))
      const logoManualPx = Math.max(1, Math.round(logoManualMm * MM_TO_PX))
      const logoBox = document.createElement('div')
      logoBox.style.width = '100%'
      logoBox.style.height = logoSpacePx + 'px'
      logoBox.style.display = 'flex'
      logoBox.style.alignItems = 'center'
      logoBox.style.justifyContent = logoAlign === 'center' ? 'center' : logoAlign === 'right' ? 'flex-end' : 'flex-start'
      if (s.logo.scaleToFit) {
        // Fit within bounds while keeping intrinsic aspect size so horizontal
        // justification (left/center/right) still has visible effect.
        logoImg.style.height = 'auto'
        logoImg.style.width = 'auto'
        logoImg.style.maxHeight = '100%'
        logoImg.style.maxWidth = '100%'
      } else {
        logoImg.style.height = logoManualPx + 'px'
        logoImg.style.width = 'auto'
        logoImg.style.maxHeight = '100%'
        logoImg.style.maxWidth = '100%'
      }
      logoBox.appendChild(logoImg)
      logoRow.appendChild(logoBox)
      logoImg.style.objectFit = 'contain'
      labelPreview.appendChild(logoRow)
    }

    // --- Title rows ---
    const renderTitleRow = (cfg: { sizeMm: number; marginMm: number; fitToWidth: boolean; align: 'left'|'center'|'right'; template: string; dividerAbove: boolean; dividerBelow: boolean }) => {
      const rowGapMm = Math.max(-1, Math.min(4, Number(cfg.marginMm ?? 0)))
      if (cfg.dividerAbove) {
        const r = makeRule(); r.style.marginBottom = '0'; labelPreview.appendChild(r)
      }

      const titleRow = document.createElement('div')
      titleRow.style.margin = `${rowGapMm}mm 0`
      titleRow.style.overflow = 'hidden'

      const titleEl = document.createElement('div')
      titleEl.style.textAlign = cfg.align
      titleEl.style.fontWeight = '700'
      titleEl.style.lineHeight = '1'
      titleEl.style.overflow = 'hidden'
      titleEl.style.whiteSpace = 'nowrap'
      titleEl.style.textOverflow = cfg.fitToWidth ? 'clip' : 'ellipsis'
      titleEl.style.color = 'black'

      // If the whole title template is wrapped in ==...== or @@...@@,
      // render it as a full-row inverse block instead of glyph-bounded inverse spans.
      const trimmedTemplate = cfg.template.trim()
      const rowInverseMatch = trimmedTemplate.match(/^==([\s\S]*?)==$/)
      const rowColorInverseMatch = trimmedTemplate.match(/^@@([\s\S]*?)@@$/)
      const rowInverseEnabled = !!(rowInverseMatch || rowColorInverseMatch)
      const renderTemplate = rowInverseMatch ? rowInverseMatch[1] : rowColorInverseMatch ? rowColorInverseMatch[1] : cfg.template
      if (rowInverseEnabled) {
        if (rowColorInverseMatch) {
          const bg = normalizeHexColor(data['filament.color_hex']) ?? '#000000'
          titleEl.style.backgroundColor = bg
          titleEl.style.color = getReadableTextColor(bg)
        } else {
          titleEl.style.backgroundColor = '#000'
          titleEl.style.color = '#fff'
        }
        titleEl.style.display = 'block'
        titleEl.style.width = '100%'
        titleEl.style.boxSizing = 'border-box'
        titleEl.style.padding = '0 0.6mm'
      }

      const resolvedTitleText = renderTemplateText(renderTemplate, data).trim()
      if (!resolvedTitleText) {
        return
      }

      const frag = parseTemplate(renderTemplate, data)
      titleEl.appendChild(frag)
      titleRow.appendChild(titleEl)
      labelPreview.appendChild(titleRow)

      if (cfg.fitToWidth) {
        const maxPx = cfg.sizeMm * 3.78
        titleEl.style.fontSize = maxPx + 'px'
        let lo = 1, hi = maxPx, bestPx = lo
        if (titleEl.scrollWidth <= titleRow.clientWidth) {
          bestPx = maxPx
        } else {
          for (let i = 0; i < 12; i++) {
            const mid = (lo + hi) / 2
            titleEl.style.fontSize = mid + 'px'
            if (titleEl.scrollWidth <= titleRow.clientWidth) { bestPx = mid; lo = mid }
            else hi = mid
          }
          titleEl.style.fontSize = bestPx + 'px'
          while (bestPx > 1 && titleEl.scrollWidth > titleRow.clientWidth) {
            bestPx -= 0.25
            titleEl.style.fontSize = bestPx + 'px'
          }
        }
        titleEl.style.fontSize = bestPx + 'px'
      } else {
        titleEl.style.fontSize = cfg.sizeMm * 3.78 + 'px'
      }

      if (cfg.dividerBelow) {
        const r = makeRule(); r.style.marginTop = '0'; labelPreview.appendChild(r)
      }

    }

    if (hasTitle1) renderTitleRow(s.title)
    if (hasTitle2) renderTitleRow(s.title2)

    // Keep legacy behavior for logo-only labels when no title rows are shown.
    if (!hasTitle1 && !hasTitle2 && hasLogo && s.title.dividerBelow) {
      const r = makeRule(); r.style.marginTop = '0.5mm'; labelPreview.appendChild(r)
    }

    // --- Main row: info (left/right) + QR (left/right) ---
    const mainRow = document.createElement('div')
    mainRow.style.display = 'flex'
    mainRow.style.flex = '1'
    mainRow.style.minHeight = '0'
    mainRow.style.padding = '0'
    mainRow.style.gap = '1.5mm'
    mainRow.style.flexDirection = s.qr.position === 'left' ? 'row-reverse' : 'row'
    mainRow.style.alignItems = (() => {
      const v = (s.info.show && s.info.template.trim()) ? s.info.vAlign
               : (s.info2?.show && s.info2.template.trim()) ? s.info2.vAlign
               : null
      if (!v) return 'stretch'
      return v === 'top' ? 'flex-start' : v === 'center' ? 'center' : 'flex-end'
    })()
    labelPreview.appendChild(mainRow)

    // Information block (primary)
    if (s.info.show && s.info.template.trim()) {
      const infoEl = document.createElement('div')
      infoEl.style.flex = '1'
      infoEl.style.minWidth = '0'
      infoEl.style.fontSize = s.info.sizeMm * 3.78 + 'px'
      infoEl.style.textAlign = s.info.hAlign
      infoEl.style.color = 'black'
      infoEl.style.overflow = 'hidden'
      infoEl.style.lineHeight = '1.4'
      const frag = parseTemplate(s.info.template, data)
      infoEl.appendChild(frag)
      mainRow.appendChild(infoEl)
    }

    // Information block 2 (second column)
    const hasInfo2 = s.info2?.show && s.info2.template.trim()
    if (hasInfo2) {
      // Vertical separator between info1 and info2
      if (s.info2.vsep) {
        const sep = document.createElement('div')
        sep.style.width = '1px'
        sep.style.alignSelf = 'stretch'
        sep.style.minHeight = '100%'
        sep.style.background = 'black'
        sep.style.flexShrink = '0'
        mainRow.appendChild(sep)
      }
      const info2El = document.createElement('div')
      info2El.style.flex = '1'
      info2El.style.minWidth = '0'
      info2El.style.fontSize = (s.info2.sizeMm * 3.78) + 'px'
      info2El.style.textAlign = s.info2.hAlign
      info2El.style.color = 'black'
      info2El.style.overflow = 'hidden'
      info2El.style.lineHeight = '1.4'
      info2El.style.alignSelf = s.info2.vAlign === 'top' ? 'flex-start' : s.info2.vAlign === 'center' ? 'center' : 'flex-end'
      const frag2 = parseTemplate(s.info2.template, data)
      info2El.appendChild(frag2)
      mainRow.appendChild(info2El)
    }

    // QR Code block
    if (s.qr.show) {
      const qrWrap = document.createElement('div')
      qrWrap.style.flexShrink = '0'
      qrWrap.style.width = s.qr.sizeMm + 'mm'
      qrWrap.style.height = s.qr.sizeMm + 'mm'
      qrWrap.style.alignSelf = s.qr.vAlign === 'top' ? 'flex-start' : s.qr.vAlign === 'center' ? 'center' : 'flex-end'

      const qrUrl = buildSafeQrUrl(s.qr.linkMode, s.qr.urlTemplate, labelData.id)
      const qrPx = Math.min(1024, Math.max(256, Math.round(s.qr.sizeMm * (PRINT_DPI / 25.4))))

      // @ts-expect-error — QRCode loaded dynamically
      new QRCode(qrWrap, {
        text: qrUrl, width: qrPx, height: qrPx,
        colorDark: '#000000', colorLight: '#ffffff',
        correctLevel: (window as any).QRCode.CorrectLevel.H,
      })

      // Optionally draw center brand mark.
      if (s.qr.mode === 'logo' || s.qr.mode === 'colorLogo') {
        const canvas = qrWrap.querySelector('canvas')
        if (canvas) {
          await decorateQrCenter(canvas as HTMLCanvasElement, qrPx, s.qr.mode === 'colorLogo')
          if (isStale() || activePreviewTab !== 'designer') return
          qrWrap.innerHTML = ''
          qrWrap.appendChild(canvasToQrImage(canvas as HTMLCanvasElement, false))
        }
      } else {
        // Convert canvas to img for reliable printing
        const canvas = qrWrap.querySelector('canvas')
        if (canvas) {
          qrWrap.innerHTML = ''
          qrWrap.appendChild(canvasToQrImage(canvas as HTMLCanvasElement, true))
        }
      }

      mainRow.appendChild(qrWrap)
    }

    // Print page style
    const isSafari = /Safari/.test(navigator.userAgent) && !/Chrome/.test(navigator.userAgent)
    const pageRule = isSafari ? '' : `@page { size: ${w}mm ${h}mm; margin: 0; }`
    const style = document.createElement('style')
    style.innerHTML = `
      ${pageRule}
      @media print {
        .label-preview {
          width: ${w}mm !important; height: ${h}mm !important;
          min-width: ${w}mm !important; min-height: ${h}mm !important;
          max-width: ${w}mm !important; max-height: ${h}mm !important;
          transform: none !important;
          transform-origin: unset !important;
        }
      }
    `
    const oldStyle = document.querySelector('style#page-style')
    if (oldStyle) oldStyle.remove()
    style.id = 'page-style'
    document.head.appendChild(style)
  }

  document.getElementById('btn-reset')?.addEventListener('click', () => {
    localStorage.removeItem(LABEL_SETTINGS_KEY);
    (widthInput as HTMLInputElement).value = '60';
    (heightInput as HTMLInputElement).value = '40';
    (fontSizeInput as HTMLInputElement).value = '100';
    (qrSizeInput as HTMLInputElement).value = '18';
    checkLogo.checked = true;
    checkQR.checked = true;
    checkID.checked = true;
    checkMfr.checked = true;
    checkMat.checked = true;
    checkColor.checked = true;
    checkColorSwatch.checked = true;
    for (const ef of extraFieldChecks) {
      ef.checkbox.checked = false
    }
    updatePreview()
  })

  // Restore active tab now that all designer state is fully initialized
  if (savedTab === 'designer') activateTab('designer')

  // Initialize: load logo then render whichever tab is active
  loadLabelLogo().then(() => {
    const activeTab = localStorage.getItem(ACTIVE_TAB_KEY)
    if (activeTab === 'designer') activateTab('designer')
    else activateTab('print')
  })

  // Fallback: if no extra fields came from sessionStorage (e.g. direct navigation),
  // fetch definitions from the API and rebuild the extra-fields UI.
  if (extraFields.length === 0) {
    ;(async () => {
      try {
        const [spoolDefs, filamentDefs] = await Promise.all([
          fetch('/api/v1/system-extra-fields?target_type=spool', { credentials: 'include' }).then(r => r.ok ? r.json() : []),
          fetch('/api/v1/system-extra-fields?target_type=filament', { credentials: 'include' }).then(r => r.ok ? r.json() : []),
        ])
        const allDefs: {key: string, label: string, target_type: string}[] = [
          ...(Array.isArray(spoolDefs) ? spoolDefs : []).map((d: {key: string, label: string}) => ({...d, target_type: 'spool'})),
          ...(Array.isArray(filamentDefs) ? filamentDefs : []).map((d: {key: string, label: string}) => ({...d, target_type: 'filament'})),
        ]
        if (allDefs.length === 0) return

        // Attempt to get actual spool values
        const spoolCustom: Record<string, string> = {}
        const filamentCustom: Record<string, string> = {}
        const spoolRes = await fetch(`/api/v1/spools/${id}`, { credentials: 'include' })
        if (spoolRes.ok) {
          const sd = await spoolRes.json()
          if (sd.custom_fields) {
            for (const [k, v] of Object.entries(sd.custom_fields as Record<string, unknown>)) {
              if (v !== null && v !== undefined) spoolCustom[k] = String(v)
            }
          }
          if (sd.filament?.custom_fields) {
            for (const [k, v] of Object.entries(sd.filament.custom_fields as Record<string, unknown>)) {
              if (v !== null && v !== undefined) filamentCustom[k] = String(v)
            }
          }
        }

        // Populate extraFields and rebuild UI
        const hasBothSources = allDefs.some(d => d.target_type === 'spool') && allDefs.some(d => d.target_type === 'filament')
        const scopeAttr = (() => {
          const existing = document.querySelector('.fm-checkbox-group')
          if (!existing) return null
          return Array.from(existing.attributes).find(a => a.name.startsWith('data-astro-cid-'))
        })()

        for (const def of allDefs) {
          const valueMap = def.target_type === 'spool' ? spoolCustom : filamentCustom
          const ef = {
            key: `${def.target_type}.${def.key}`,
            label: def.label,
            value: valueMap[def.key] ?? '',
            source: def.target_type,
          }
          extraFields.push(ef)

          const lbl = document.createElement('label')
          lbl.className = 'fm-checkbox-group'
          const cb = document.createElement('input')
          cb.type = 'checkbox'
          cb.id = `check-ef-${ef.key}`
          cb.checked = savedExtraFieldSettings[ef.key] || false
          const span = document.createElement('span')
          span.textContent = hasBothSources
            ? `${ef.label} (${def.target_type === 'spool' ? ((window as any).__t('dashboard.spool') || 'Spool') : ((window as any).__t('spools.filament') || 'Filament')})`
            : ef.label
          if (scopeAttr) {
            lbl.setAttribute(scopeAttr.name, '')
            cb.setAttribute(scopeAttr.name, '')
            span.setAttribute(scopeAttr.name, '')
          }
          lbl.appendChild(cb)
          lbl.appendChild(span)
          extraFieldsCheckboxes.appendChild(lbl)
          extraFieldChecks.push({ key: ef.key, label: ef.label, value: ef.value, checkbox: cb })
          cb.addEventListener('change', () => updatePreview())
        }

        // Show the print-settings extra-fields section
        extraFieldsTitle.style.display = ''
        extraFieldsCheckboxes.style.display = ''
        document.getElementById('title-extra-fields')!.textContent = (window as any).__t('spools.extraFieldsLabel') || 'Extra Fields'

        // Rebuild token areas in the designer so extra-field chips appear
        buildTokenArea('ds-title-token-area',  'ds-title-tpl')
        buildTokenArea('ds-title2-token-area', 'ds-title2-tpl')
        buildTokenArea('ds-info-token-area',   'ds-info-tpl')
        buildTokenArea('ds-info2-token-area',  'ds-info2-tpl')

        updatePreview()
      } catch { /* ignore */ }
    })()
  }
</script>
