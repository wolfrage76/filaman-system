    document.getElementById('modal-form')?.addEventListener('submit', async (e) => {
      e.preventDefault()
      
      const container = document.getElementById('modal-container') as HTMLElement
      const type = container.dataset.type
      const error = document.getElementById('modal-error') as HTMLElement
      const submitBtn = document.getElementById('modal-submit') as HTMLButtonElement
      
      let url = ''
      const body: Record<string, unknown> = {}
      
      if (type === 'measurement') {
        url = `/api/v1/spools/${id}/measurements`
        body.measured_weight_g = parseFloat((document.getElementById('field-weight') as HTMLInputElement).value)
        body.note = (document.getElementById('field-note') as HTMLInputElement).value || null
      } else if (type === 'adjustment') {
        url = `/api/v1/spools/${id}/adjustments`
        const adjType = (document.getElementById('field-adjustment-type') as HTMLInputElement).value
        body.adjustment_type = adjType
        body.note = (document.getElementById('field-note') as HTMLInputElement).value || null
        if (adjType === 'relative') {
          body.delta_weight_g = parseFloat((document.getElementById('field-delta') as HTMLInputElement).value) || null
        } else {
          body.measured_weight_g = parseFloat((document.getElementById('field-measured') as HTMLInputElement).value) || null
        }
      } else if (type === 'status') {
        url = `/api/v1/spools/${id}/status`
        body.status = (document.getElementById('field-status') as HTMLInputElement).value
        body.note = (document.getElementById('field-note') as HTMLInputElement).value || null
      } else if (type === 'move') {
        url = `/api/v1/spools/${id}/move`
        const locId = (document.getElementById('field-location') as HTMLInputElement).value
        body.location_id = locId ? parseInt(locId) : null
        body.note = (document.getElementById('field-note') as HTMLInputElement).value || null
      }
      
      error.classList.add('hidden')
      submitBtn.disabled = true
      submitBtn.textContent = t('common.submitting')
      
      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': getCsrfToken(),
          },
          credentials: 'include',
          signal: getAbortSignal(),
          body: JSON.stringify(body),
        })
        
        if (!response.ok) {
          const data = await response.json()
          throw new Error(data.message || t('spools.failedSubmit'))
        }
        
        container.classList.add('hidden')
        loadData()
      } catch (err) {
        if (isAbortError(err)) return
        error.textContent = (err instanceof Error ? err.message : null) || t('spools.failedSubmit')
        error.classList.remove('hidden')
      } finally {
        submitBtn.disabled = false
        submitBtn.textContent = t('common.submit')
      }
    })
    
    async function loadPrintersForParams() {
      try {
        const res = await fetch('/api/v1/printers', { credentials: 'include', signal: getAbortSignal() })
        if (!res.ok) return
        const data = await res.json()
        printersList = data.items || data || []
        if (printersList.length === 0) return

        document.getElementById('printer-params-section')!.classList.remove('hidden')
        const select = document.getElementById('printer-select') as HTMLSelectElement
        select.innerHTML = '<option value="">\u2014</option>' +
          printersList.map((p: any) => `<option value="${p.id}" data-driver="${p.driver_key || ''}">${p.name}</option>`).join('')

        select.addEventListener('change', async () => {
          const printerId = select.value
          if (printerId) {
            const option = select.selectedOptions[0]
            const driverKey = option?.dataset.driver || ''
            currentDriverKey = driverKey
            currentPrinterId = parseInt(printerId)
            await loadFieldDefinitions(driverKey)
            await loadCloudPresets(currentPrinterId, driverKey)
            await loadSpoolPrinterParams(parseInt(printerId))
          } else {
            fieldDefinitions = []
            currentPrinterParams = []
            filamentPrinterParams = []
            currentDriverKey = ''
            currentPrinterId = 0
            cloudPresets = []
            cloudPresetsByCode = {}
            renderPrinterParams()
          }
        })
      } catch (e) {
        if (isAbortError(e)) return
        console.error('Failed to load printers:', e)
      }
    }

    async function loadFieldDefinitions(driverKey: string) {
      if (!driverKey) {
        fieldDefinitions = []
        return
      }
      try {
        const res = await fetch(`/api/v1/system-extra-fields?target_type=spool_printer_param&source=${driverKey}`, { credentials: 'include', signal: getAbortSignal() })
        if (!res.ok) throw new Error('Failed')
        fieldDefinitions = await res.json()
      } catch (e) {
        if (isAbortError(e)) return
        console.error('Failed to load field definitions:', e)
        fieldDefinitions = []
      }
    }

    async function loadSpoolPrinterParams(printerId: number) {
      try {
        // Fetch spool params and filament params in parallel
        const [spoolRes, filamentRes] = await Promise.all([
          fetch(`/api/v1/spools/${id}/printer-params?printer_id=${printerId}`, { credentials: 'include', signal: getAbortSignal() }),
          fetch(`/api/v1/filaments/${spool.filament_id}/printer-params?printer_id=${printerId}`, { credentials: 'include', signal: getAbortSignal() }),
        ])
        currentPrinterParams = spoolRes.ok ? await spoolRes.json() : []
        filamentPrinterParams = filamentRes.ok ? await filamentRes.json() : []
        renderPrinterParams()
      } catch (e) {
        if (isAbortError(e)) return
        console.error('Failed to load printer params:', e)
      }
    }

    async function loadCloudPresets(printerId: number, driverKey: string) {
      cloudPresets = []
      cloudPresetsByCode = {}
      if (driverKey !== 'bambuddy') return
      try {
        const res = await fetch(`/api/v1/printers/${printerId}/driver/cloud-presets`, { credentials: 'include', signal: getAbortSignal() })
        if (!res.ok) return
        const data = await res.json()
        cloudPresets = data.presets || []
        cloudPresetsByCode = {}
        cloudPresets.forEach((p: any) => { cloudPresetsByCode[p.code] = p })
      } catch (e) {
        if (isAbortError(e)) return
        console.error('Failed to load cloud presets:', e)
      }
    }

    function escapeHtml(s: string): string {
      return (s || '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string))
    }

    function presetLabel(code: string): string {
      if (!code) return ''
      const p = cloudPresetsByCode[code]
      return p ? p.displayName : code
    }

    // Slicer profiles use driver actions (set_spool_profile): full preset →
    // bambu_slicer_setting_id, generic AMS code → bambu_idx. Params PUT must not
    // write PFUS codes into bambu_idx (standalone picker handles profiles).
    const BAMBUDDY_PROFILE_PARAM_KEYS = ['bambu_idx', 'bambu_slicer_setting_id']
    function isBambuddyCloudProfileManaged(): boolean {
      return currentDriverKey === 'bambuddy' && cloudPresets.length > 0
    }
    function excludeManagedProfileParams(params: { param_key: string; param_value: string | null }[]) {
      if (!isBambuddyCloudProfileManaged()) return params
      return params.filter(p => !BAMBUDDY_PROFILE_PARAM_KEYS.includes(p.param_key))
    }

    // Codes reflected from the printer's AMS (e.g. "SUN20010") are not part of
    // the selectable cloud-preset catalog, so the picker can't label them.
    // Ask the driver to resolve the readable name and inject a display-only
    // entry so presetLabel() shows the name instead of the raw code.
    async function ensureCodeLabel(printerId: number, code: string): Promise<void> {
      if (!code || cloudPresetsByCode[code]) return
      try {
        const res = await fetch(`/api/v1/printers/${printerId}/driver/action`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          credentials: 'include',
          signal: getAbortSignal(),
          body: JSON.stringify({ action: 'resolve_preset_label', params: { code } }),
        })
        if (!res.ok) return
        const json = await res.json()
        const name = json && json.data && json.data.name
        if (name && name !== code) cloudPresetsByCode[code] = { code, displayName: name, name }
      } catch (e) {
        if (!isAbortError(e)) console.error('Failed to resolve preset label:', e)
      }
    }

    function renderCloudCombobox(key: string, code: string, placeholderLabel: string, inheritedStyle: string, forParamsSave = true): string {
      const label = presetLabel(code)
      const ph = placeholderLabel
        ? escapeHtml(presetLabel(placeholderLabel))
        : escapeHtml(t('printers.searchProfile') || 'Search profile…')
      const hiddenClass = forParamsSave ? 'param-value' : 'slicer-profile-code'
      return `<div class="cloud-combo" data-key="${key}" style="flex: 2; position: relative;${inheritedStyle}">
        <input type="hidden" class="${hiddenClass}" data-key="${key}" value="${escapeHtml(code)}" />
        <input type="text" class="fm-input cloud-combo-search" autocomplete="off" spellcheck="false"
          placeholder="${ph}" value="${escapeHtml(label)}" style="width: 100%;" />
        <div class="cloud-combo-list" style="display:none; position:absolute; z-index:50; left:0; right:0; max-height:260px; overflow-y:auto; background:var(--surface, #1e1e1e); border:1px solid var(--border, #444); border-radius:6px; margin-top:2px; box-shadow:0 4px 16px rgba(0,0,0,0.3);"></div>
      </div>`
    }

    function wireCombo(combo: any, onSelect: ((code: string) => void) | null) {
      const hidden = combo.querySelector('.param-value, .slicer-profile-code') as HTMLInputElement
      const search = combo.querySelector('.cloud-combo-search') as HTMLInputElement
      const list = combo.querySelector('.cloud-combo-list') as HTMLElement

      const renderList = (query: string) => {
        const q = query.trim().toLowerCase()
        const matches = (q
          ? cloudPresets.filter((p: any) => (p.displayName || '').toLowerCase().includes(q))
          : cloudPresets).slice(0, 200)
        if (matches.length === 0) {
          list.innerHTML = `<div style="padding:8px 10px; color:var(--text-muted); font-size:0.85rem;">${escapeHtml(t('printers.noProfileMatches') || 'No matches')}</div>`
          return
        }
        list.innerHTML = matches.map((p: any) => {
          const sel = p.code === hidden.value ? ' style="background:var(--accent-muted, rgba(59,130,246,0.15));"' : ''
          return `<div class="cloud-combo-opt" data-code="${escapeHtml(p.code)}"${sel}
            style="padding:7px 10px; cursor:pointer; font-size:0.85rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"
            title="${escapeHtml(p.displayName)}">${escapeHtml(p.displayName)}</div>`
        }).join('')
        list.querySelectorAll('.cloud-combo-opt').forEach((opt: any) => {
          opt.addEventListener('mousedown', (ev: Event) => {
            ev.preventDefault()
            const code = opt.dataset.code
            hidden.value = code
            search.value = presetLabel(code)
            list.style.display = 'none'
            if (onSelect) onSelect(code)
          })
        })
      }

      search.addEventListener('focus', () => { renderList(''); list.style.display = 'block' })
      search.addEventListener('input', () => { renderList(search.value); list.style.display = 'block' })
      search.addEventListener('blur', () => {
        setTimeout(() => {
          list.style.display = 'none'
          search.value = presetLabel(hidden.value)
        }, 150)
      })
    }

    function wireCloudComboboxes() {
      document.querySelectorAll('#printer-params-list .cloud-combo').forEach((combo: any) =>
        wireCombo(combo, (code: string) => onCloudProfileSelected(code, currentPrinterId)))
    }

    // Spool-level select: push immediately to Bambuddy so both systems match.
    async function onCloudProfileSelected(code: string, printerId: number) {
      if (!code || !printerId) return
      try {
        const res = await fetch(`/api/v1/printers/${printerId}/driver/action`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          credentials: 'include',
          signal: getAbortSignal(),
          body: JSON.stringify({ action: 'set_spool_profile', params: { spool_id: parseInt(id), code } }),
        })
        if (!res.ok) throw new Error('set_spool_profile failed')
        try {
          const pr = await fetch(`/api/v1/spools/${id}/printer-params?printer_id=${printerId}`, { credentials: 'include', signal: getAbortSignal() })
          if (pr.ok) currentPrinterParams = await pr.json()
        } catch {}
        showSlicerMsg(t('common.saved') || 'Saved', false)
        showParamsFeedback(true)
      } catch (e) {
        if (!isAbortError(e)) { console.error('Failed to set spool profile:', e); showSlicerMsg(t('printers.paramsSaveFailed') || 'Failed', true) }
      }
    }

    // -- Standalone (printer-independent) slicer profile picker --
    let slicerRepPrinterId = 0

    function showSlicerMsg(text: string, isError: boolean) {
      const msg = document.getElementById('slicer-profile-msg')
      if (!msg) return
      msg.textContent = text
      msg.style.color = isError ? 'var(--error-text)' : 'var(--success-text)'
      msg.classList.remove('hidden')
      setTimeout(() => msg.classList.add('hidden'), 3000)
    }

    async function initSlicerProfilePicker() {
      try {
        const res = await fetch('/api/v1/printers', { credentials: 'include', signal: getAbortSignal() })
        if (!res.ok) return
        const data = await res.json()
        const bambuPrinters = (data.items || data || []).filter((p: any) => p.driver_key === 'bambuddy')
        if (bambuPrinters.length === 0) return
        let rep = 0
        for (const p of bambuPrinters) {
          try {
            const h = await fetch(`/api/v1/printers/${p.id}/driver/health`, { credentials: 'include', signal: getAbortSignal() })
            if (h.ok) { const hj = await h.json(); if (hj && (hj.connected || hj.running)) { rep = p.id; break } }
          } catch {}
        }
        if (!rep) rep = bambuPrinters[0].id
        slicerRepPrinterId = rep
        await loadCloudPresets(rep, 'bambuddy')
        if (cloudPresets.length === 0) return
        // current value: spool-level, fallback to filament-level
        let currentCode = ''
        try {
          const [spRes, flRes] = await Promise.all([
            fetch(`/api/v1/spools/${id}/printer-params?printer_id=${rep}`, { credentials: 'include', signal: getAbortSignal() }),
            spool?.filament_id ? fetch(`/api/v1/filaments/${spool.filament_id}/printer-params?printer_id=${rep}`, { credentials: 'include', signal: getAbortSignal() }) : Promise.resolve(null),
          ])
          const sp = spRes && spRes.ok ? await spRes.json() : []
          const fl = flRes && flRes.ok ? await flRes.json() : []
          const sSid = (sp || []).find((x: any) => x.param_key === 'bambu_slicer_setting_id')
          const fSid = (fl || []).find((x: any) => x.param_key === 'bambu_slicer_setting_id')
          const sm = (sp || []).find((x: any) => x.param_key === 'bambu_idx')
          const fm = (fl || []).find((x: any) => x.param_key === 'bambu_idx')
          currentCode = (sSid && sSid.param_value) || (fSid && fSid.param_value) || (sm && sm.param_value) || (fm && fm.param_value) || ''
        } catch {}
        await ensureCodeLabel(rep, currentCode)
        const c = document.getElementById('slicer-profile-picker')!
        c.innerHTML = renderCloudCombobox('bambu_idx', currentCode, '', '', false)
        const combo = c.querySelector('.cloud-combo')
        if (combo) wireCombo(combo, (code: string) => onCloudProfileSelected(code, slicerRepPrinterId))
        document.getElementById('slicer-profile-section')!.classList.remove('hidden')
      } catch (e) {
        if (!isAbortError(e)) console.error('Slicer picker init failed:', e)
      }
    }

    function renderPrinterParams() {
      const container = document.getElementById('printer-params-list') as HTMLElement
      const actions = document.getElementById('printer-params-actions') as HTMLElement
      const printerId = (document.getElementById('printer-select') as HTMLSelectElement | null)?.value

      if (!printerId) {
        container.innerHTML = '<p style="color: var(--text-muted); font-size: 0.85rem;">' + t('printers.selectPrinterHint') + '</p>'
        actions.classList.add('hidden')
        return
      }

      actions.classList.remove('hidden')

      // Build value maps: spool-level (own) and filament-level (inherited)
      const spoolValuesMap: Record<string, string> = {}
      currentPrinterParams.forEach((p: any) => { spoolValuesMap[p.param_key] = p.param_value || '' })
      const filamentValuesMap: Record<string, string> = {}
      filamentPrinterParams.forEach((p: any) => { filamentValuesMap[p.param_key] = p.param_value || '' })

      if (fieldDefinitions.length === 0) {
        container.innerHTML = '<p style="color: var(--text-muted); font-size: 0.85rem;">' + t('printers.noFieldDefinitions') + '</p>'
        actions.classList.add('hidden')
        return
      }

      container.innerHTML = fieldDefinitions.map(fd => {
        // Profile picker lives in the standalone slicer section; params save only handles AMS tuning fields.
        if (isBambuddyCloudProfileManaged() && fd.key === 'bambu_idx') return ''

        const spoolValue = spoolValuesMap[fd.key] || ''
        const filamentValue = filamentValuesMap[fd.key] || ''
        const value = spoolValue || filamentValue
        const isInherited = !spoolValue && !!filamentValue
        let inputHtml = ''
        const inheritedStyle = isInherited ? ' opacity: 0.6; font-style: italic;' : ''

        if (fd.field_type === 'dropdown' && fd.options) {
          const opts = fd.options.map((o: any) => {
            const selected = value === o ? ' selected' : ''
            return `<option value="${o}"${selected}>${o}</option>`
          }).join('')
          inputHtml = `<select class="fm-select param-value" data-key="${fd.key}" style="flex: 2;${inheritedStyle}">
            <option value="">\u2014</option>${opts}</select>`
        } else if (fd.field_type === 'number') {
          if (isInherited) {
            inputHtml = `<input type="number" step="any" class="fm-input param-value" data-key="${fd.key}" value="" placeholder="${filamentValue}" style="flex: 2;${inheritedStyle}" />`
          } else {
            inputHtml = `<input type="number" step="any" class="fm-input param-value" data-key="${fd.key}" value="${value}" style="flex: 2;" />`
          }
        } else if (fd.field_type === 'checkbox') {
          inputHtml = `<label style="flex: 2; display: flex; align-items: center;${inheritedStyle}"><input type="checkbox" class="param-value" data-key="${fd.key}" ${value === 'true' || value === '1' ? 'checked' : ''} style="width: 18px; height: 18px; accent-color: var(--accent);" /></label>`
        } else {
          if (isInherited) {
            inputHtml = `<input type="text" class="fm-input param-value" data-key="${fd.key}" value="" placeholder="${filamentValue}" style="flex: 2;${inheritedStyle}" />`
          } else {
            inputHtml = `<input type="text" class="fm-input param-value" data-key="${fd.key}" value="${value}" style="flex: 2;" />`
          }
        }

        const inheritedBadge = isInherited ? `<span style="font-size: 0.7rem; color: var(--text-muted); opacity: 0.7;" title="${t('printers.inheritedFromFilament') || 'Inherited from filament'}">&#8593; Filament</span>` : ''

        return `<div class="param-row" style="display: flex; gap: 8px; align-items: center; margin-bottom: 8px;">
          <label style="flex: 1; font-size: 0.85rem; font-weight: 500; color: var(--text-muted);">${fd.label} ${inheritedBadge}</label>
          ${inputHtml}
        </div>`
      }).join('')

      wireCloudComboboxes()
    }

    function showParamsFeedback(success: boolean) {
      const fb = document.getElementById('params-save-feedback')
      if (!fb) return
      fb.textContent = success ? (t('common.saved') || '✓ Saved') : (t('common.saveFailed') || '✗ Failed')
      fb.style.color = success ? 'var(--success-text)' : 'var(--error-text)'
      fb.style.opacity = '1'
      setTimeout(() => { fb.style.opacity = '0' }, 3000)
    }

    document.getElementById('btn-save-params')?.addEventListener('click', async () => {
      const printerId = (document.getElementById('printer-select') as HTMLSelectElement | null)?.value
      if (!printerId) return

      const params: any[] = []
      document.querySelectorAll<HTMLInputElement>('#printer-params-list .param-value').forEach(el => {
        const key = el.dataset.key
        let value = null
        if (el.type === 'checkbox') {
          value = el.checked ? 'true' : ''
        } else {
          value = el.value?.trim() || null
        }
        if (key) params.push({ param_key: key, param_value: value })
      })

      // Filter out empty values for clean storage; never PUT cloud presets into bambu_idx
      const nonEmptyParams = excludeManagedProfileParams(
        params.filter(p => p.param_value !== null && p.param_value !== '')
      )

      if (nonEmptyParams.length === 0) {
        try {
          await fetch(`/api/v1/spools/${id}/printer-params/${printerId}`, {
            method: 'DELETE',
            headers: { 'X-CSRF-Token': getCsrfToken() },
            credentials: 'include',
            signal: getAbortSignal(),
          })
          currentPrinterParams = []
          filamentPrinterParams = []
          renderPrinterParams()
          showParamsFeedback(true)
        } catch (e) {
          if (isAbortError(e)) return
          console.error('Failed to delete params:', e)
          showParamsFeedback(false)
        }
        return
      }

      try {
        const res = await fetch(`/api/v1/spools/${id}/printer-params/${printerId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          credentials: 'include',
          signal: getAbortSignal(),
          body: JSON.stringify({ params: nonEmptyParams }),
        })
        if (res.ok) {
          currentPrinterParams = await res.json()
          renderPrinterParams()
          showParamsFeedback(true)
        } else {
          showParamsFeedback(false)
        }
      } catch (e) {
        if (isAbortError(e)) return
        console.error('Failed to save printer params:', e)
        showParamsFeedback(false)
      }
    })

    async function loadPrinterSlotOverview() {
      try {
        const res = await fetch('/api/v1/printers', { credentials: 'include', signal: getAbortSignal() })
        if (!res.ok) return
        const data = await res.json()
        const printers = data.items || data || []
        if (printers.length === 0) return

        const healthResults = await Promise.allSettled(
          printers.map((p: any) =>
            fetch(`/api/v1/printers/${p.id}/driver/health`, { credentials: 'include', signal: getAbortSignal() })
              .then(r => r.ok ? r.json() : null)
              .then(h => h ? { printer: p, health: h } : null)
          )
        )

        const onlinePrinters = healthResults
          .filter((r): r is PromiseFulfilledResult<any> => r.status === 'fulfilled' && r.value != null && r.value.health?.connected)
          .map(r => r.value)

        // Force a direct Moonraker status refresh via backend before loading
        // DB slot assignments. This ensures active spool changes made outside
        // FilaMan are visible immediately on page load.
        await Promise.allSettled(
          onlinePrinters.map(async ({ printer }) => {
            try {
              await fetch(`/api/v1/printers/${printer.id}/driver/health?refresh=1`, {
                credentials: 'include',
                signal: getAbortSignal()
              })
            } catch {}
          })
        )

        // Fetch DB slot assignments for all online printers
        const dbSlotsByPrinter: Record<string, any> = {}
        await Promise.allSettled(
          onlinePrinters.map(async ({ printer }) => {
            try {
              const slotsRes = await fetch(`/api/v1/printers/${printer.id}/slots`, { credentials: 'include', signal: getAbortSignal() })
              if (slotsRes.ok) {
                const dbSlots = await slotsRes.json()
                dbSlotsByPrinter[printer.id] = dbSlots
              }
            } catch {}
          })
        )

        const container = document.getElementById('printer-slots-inline')
        if (onlinePrinters.length === 0 || !container) return

        let html = `<div class="fm-card" style="padding:10px 14px;">`

        for (let i = 0; i < onlinePrinters.length; i++) {
          const { printer, health } = onlinePrinters[i]
          const slots = health.slots || []
          if (slots.length === 0) continue

          // Merge DB slot assignments into health slots
          const dbSlots = dbSlotsByPrinter[printer.id] || []
          const dbSlotAssignments: Record<string, any> = {}
          for (const s of dbSlots) {
            const slotIndexFromDb = s?.custom_fields?.slot_index
            const legacySlotIndex = `${Math.floor(s.slot_no / 4)}-${s.slot_no % 4}`
            const resolvedSlotIndex = slotIndexFromDb || legacySlotIndex
            if (s.assignment) {
              dbSlotAssignments[resolvedSlotIndex] = s.assignment
            }
          }
          for (const slot of slots) {
            const assignment = dbSlotAssignments[slot.slot_index] || null
            slot._assignment = assignment
            if (assignment) {
              if (!slot.tray_color) {
                slot.tray_color = assignment.tray_color || assignment.color_hex || ''
              }
              if (!slot.tray_type && assignment.tray_type) {
                slot.tray_type = assignment.tray_type
              }
              if (slot.present === false && assignment.present) {
                slot.present = true
              }
            }
          }

          // Group slots by kind
          const toolSlots: any[] = []
          const amsGroups: Record<string, any[]> = {}
          const externalSlots: any[] = []
          for (const slot of slots) {
            const kind = String(slot.slot_kind || '').toLowerCase()
            if (kind === 'toolhead' || kind === 'tool') {
              toolSlots.push(slot)
              continue
            }

            const idx = slot.slot_index || ''
            const parts = idx.split('-')
            const amsId = parseInt(parts[0])
            if (amsId === 255) {
              externalSlots.push(slot)
            } else {
              if (!amsGroups[amsId]) amsGroups[amsId] = []
              amsGroups[amsId].push(slot)
            }
          }

          if (i > 0) html += `<div style="border-top:1px solid var(--border);margin:6px 0;"></div>`

          html += `<div style="display:flex;align-items:center;gap:12px;">`
          // Printer name + slot count
          html += `<div style="min-width:80px;">` +
            `<div style="font-size:0.8rem;font-weight:600;white-space:nowrap;">${printer.name}</div>` +
            `<div style="font-size:0.65rem;color:var(--text-muted);">${slots.length} Slots</div>` +
            `</div>`

          // Toolheads
          if (toolSlots.length > 0) {
            html += `<div style="display:flex;align-items:center;gap:4px;padding:2px 6px;border:1px solid var(--border);border-radius:6px;">` +
              `<span style="font-size:0.6rem;color:var(--text-muted);">${t('spools.slotGroupTools')}</span>`
            for (const slot of toolSlots) html += renderSlotDot(slot, printer.id)
            html += `</div>`
          }

          // External tray
          if (externalSlots.length > 0) {
            html += `<div style="display:flex;align-items:center;gap:4px;padding:2px 6px;border:1px solid var(--border);border-radius:6px;">` +
              `<span style="font-size:0.6rem;color:var(--text-muted);">${t('spools.slotGroupExternal')}</span>`
            for (const slot of externalSlots) html += renderSlotDot(slot, printer.id)
            html += `</div>`
          }

          // AMS groups
          const sortedAmsIds = Object.keys(amsGroups).map(Number).sort((a, b) => a - b)
          for (const amsId of sortedAmsIds) {
            const baseLabel = t('spools.slotGroupTrays')
            const amsLabel = sortedAmsIds.length > 1 ? `${baseLabel} ${amsId + 1}` : baseLabel
            html += `<div style="display:flex;align-items:center;gap:4px;padding:2px 6px;border:1px solid var(--border);border-radius:6px;">` +
              `<span style="font-size:0.6rem;color:var(--text-muted);">${amsLabel}</span>`
            for (const slot of amsGroups[amsId]) html += renderSlotDot(slot, printer.id)
            html += `</div>`
          }

          html += `</div>`
        }

        html += `</div>`
        container.innerHTML = html

        // Attach click handlers to slot dots
        container.querySelectorAll<HTMLElement>('.slot-dot[data-slot]').forEach(dot => {
          dot.addEventListener('click', (e) => {
            e.stopPropagation()
            const slotData = JSON.parse(dot.dataset.slot!)
            const pId = parseInt(dot.dataset.printerId!)
            showSlotContextMenu(dot, slotData, pId)
          })
        })
      } catch (e) {
        if (isAbortError(e)) return
        console.error('Failed to load printer slot overview:', e)
      }
    }

    // -- Slot rendering helpers -----------------------------------------------

    function renderSlotTooltip(slot: any) {
      if (slot._assignment) {
        const a = slot._assignment
        const parts = []
        if (a.manufacturer_name) parts.push(a.manufacturer_name)
        if (a.filament_name) parts.push(a.filament_name)
        if (a.spool_id) parts.push(`(#${a.spool_id})`)
        if (parts.length > 0) return parts.join(' - ')
      }
      return slot.tray_type || 'Empty'
    }

    function renderSlotDot(slot: any, printerId: any) {
      const assignment = slot?._assignment || null
      let colorHex = slot.tray_color || assignment?.tray_color || assignment?.color_hex || ''
      if (colorHex && !colorHex.startsWith('#')) colorHex = '#' + colorHex
      if (colorHex.length === 9) colorHex = colorHex.slice(0, 7)
      const hasColor = colorHex.length >= 7
      const hasAssignedSpool = Boolean(assignment?.spool_id)
      const isPresent = slot.present !== false || assignment?.present === true || hasAssignedSpool
      const slotJson = JSON.stringify(slot).replace(/"/g, '&quot;')
      const dotAttrs = `class="slot-dot" data-slot="${slotJson}" data-printer-id="${printerId}"`
      const tooltipTitle = renderSlotTooltip(slot)
      if (hasColor && isPresent) {
        return `<span ${dotAttrs} title="${tooltipTitle}" style="display:inline-block;width:14px;height:14px;border-radius:50%;background:${colorHex};border:1px solid var(--border);flex-shrink:0;cursor:pointer;"></span>`
      }
      // Empty slot: grey circle with red X
      return `<span ${dotAttrs} title="${tooltipTitle}" style="display:inline-flex;align-items:center;justify-content:center;width:14px;height:14px;border-radius:50%;background:#d1d5db;border:1px solid var(--border);flex-shrink:0;cursor:pointer;font-size:11px;line-height:1;color:#dc2626;font-weight:900;">✕</span>`
    }

    // -- Slot context menu ---------------------------------------------------

    let activeSlotMenu: Element | null = null

    function closeSlotMenu() {
      if (activeSlotMenu) {
        activeSlotMenu.remove()
        activeSlotMenu = null
      }
    }

    document.addEventListener('click', closeSlotMenu)
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeSlotMenu() })

    function showSlotContextMenu(dotEl: any, slot: any, printerId: any) {
      closeSlotMenu()

      const menu = document.createElement('div')
      menu.className = 'fm-card'
      menu.style.cssText = 'position:fixed;z-index:9999;padding:4px 0;min-width:220px;font-size:0.82rem;box-shadow:var(--shadow-lg);background:linear-gradient(var(--success-bg),var(--success-bg)),var(--bg-elevated);border-color:var(--success-border);'

      // Position near the dot
      const rect = dotEl.getBoundingClientRect()
      menu.style.top = (rect.bottom + 4) + 'px'
      menu.style.left = rect.left + 'px'

      // Make slot_name user-friendly: AMS 0 → AMS 1
      let slotLabel = slot.slot_name || slot.slot_index
      slotLabel = slotLabel.replace(/AMS (\d+)/, (_: string, n: string) => `AMS ${parseInt(n) + 1}`)
      const iconFilter = document.documentElement.dataset.theme === 'light' ? 'none' : 'invert(1)'
      menu.innerHTML = `
        <div style="padding:6px 12px;font-weight:600;font-size:0.75rem;color:var(--text-muted);border-bottom:1px solid var(--border);">${slotLabel}</div>
        <button class="ctx-item" data-action="assign" style="display:flex;align-items:center;gap:8px;width:100%;text-align:left;padding:8px 12px;border:none;background:none;color:#16a34a;cursor:pointer;font-size:0.82rem;"><img src="/to_printer.svg" width="18" height="18" style="flex-shrink:0;filter:brightness(0) saturate(100%) invert(45%) sepia(96%) saturate(497%) hue-rotate(110deg) brightness(96%) contrast(91%);" />${t('spools.slotAssignSpool')}</button>
        <button class="ctx-item" data-action="import-spool" style="display:flex;align-items:center;gap:8px;width:100%;text-align:left;padding:8px 12px;border:none;background:none;color:#2563eb;cursor:pointer;font-size:0.82rem;"><img src="/to_spool.svg" width="18" height="18" style="flex-shrink:0;filter:brightness(0) saturate(100%) invert(33%) sepia(100%) saturate(1946%) hue-rotate(215deg) brightness(97%) contrast(96%);" />${t('spools.slotImportToSpool')}</button>
        <button class="ctx-item" data-action="import-both" style="display:flex;align-items:center;gap:8px;width:100%;text-align:left;padding:8px 12px;border:none;background:none;color:#2563eb;cursor:pointer;font-size:0.82rem;"><img src="/to_spool.svg" width="18" height="18" style="flex-shrink:0;filter:brightness(0) saturate(100%) invert(33%) sepia(100%) saturate(1946%) hue-rotate(215deg) brightness(97%) contrast(96%);" />${t('spools.slotImportToSpoolAndFilament')}</button>
      `

      // Hover effect
      menu.querySelectorAll<HTMLElement>('.ctx-item').forEach(btn => {
        btn.addEventListener('mouseenter', () => btn.style.background = 'var(--bg-hover, rgba(128,128,128,0.1))')
        btn.addEventListener('mouseleave', () => btn.style.background = 'none')
      })

      // Action handlers
      menu.querySelector('[data-action="assign"]')?.addEventListener('click', (e) => {
        e.stopPropagation()
        closeSlotMenu()
        handleAssignSpoolToTray(slot, printerId)
      })
      menu.querySelector('[data-action="import-spool"]')?.addEventListener('click', (e) => {
        e.stopPropagation()
        closeSlotMenu()
        handleImportTrayToSpool(slot, printerId)
      })
      menu.querySelector('[data-action="import-both"]')?.addEventListener('click', (e) => {
        e.stopPropagation()
        closeSlotMenu()
        handleImportTrayToSpoolAndFilament(slot, printerId)
      })

      // Ensure menu stays within viewport
      document.body.appendChild(menu)
      const menuRect = menu.getBoundingClientRect()
      if (menuRect.right > window.innerWidth) {
        menu.style.left = (window.innerWidth - menuRect.width - 8) + 'px'
      }
      if (menuRect.bottom > window.innerHeight) {
        menu.style.top = (rect.top - menuRect.height - 4) + 'px'
      }

      activeSlotMenu = menu
    }

    // -- Slot actions --------------------------------------------------------

    function getSlotDot(slotIndex: string, printerId: number): HTMLElement | null {
      const container = document.getElementById('printer-slots-inline')
      return container?.querySelector(`.slot-dot[data-printer-id="${printerId}"][data-slot*='"slot_index":"${slotIndex}"']`) || null
    }

    function clearSlotRingState(dotEl: HTMLElement) {
      dotEl.classList.remove('slot-sending', 'slot-success', 'slot-error')
    }

    function clearPendingSlotAssign() {
      if (pendingSlotTimeout) { clearTimeout(pendingSlotTimeout); pendingSlotTimeout = null }
      if (pendingSlotPollTimer) { clearTimeout(pendingSlotPollTimer); pendingSlotPollTimer = null }
      pendingSlotAssign = null
    }

    function resolveSlotAssign(status: 'success' | 'error') {
      if (!pendingSlotAssign) return
      const { slotIndex, printerId } = pendingSlotAssign
      clearPendingSlotAssign()
      const dot = getSlotDot(slotIndex, printerId)
      if (!dot) { loadPrinterSlotOverview(); return }
      clearSlotRingState(dot)
      if (status === 'success') {
        dot.classList.add('slot-success')
        setTimeout(async () => {
          if (dot) clearSlotRingState(dot)
          await loadPrinterSlotOverview()
        }, 2000)
      } else {
        dot.classList.add('slot-error')
      }
    }

    function startSlotPolling() {
      if (!pendingSlotAssign) return
      const { printerId, slotIndex, expectedColor } = pendingSlotAssign
      let attempts = 0
      const maxAttempts = 5

      async function poll() {
        if (
          !pendingSlotAssign ||
          pendingSlotAssign.slotIndex !== slotIndex ||
          pendingSlotAssign.printerId !== printerId
        ) {
          return
        }
        attempts++
        try {
          const res = await fetch(`/api/v1/printers/${printerId}/driver/health`, { credentials: 'include', signal: getAbortSignal() })
          if (res.ok) {
            const health = await res.json()
            const slots = health.slots || []
            const slot = slots.find((s: any) => s.slot_index === slotIndex)
            if (slot) {
              // Normalize both colors for comparison (strip # and alpha, lowercase)
              const slotColor = (slot.tray_color || '').replace('#', '').slice(0, 6).toLowerCase()
              const expected = expectedColor.toLowerCase()
              if (slotColor === expected) {
                resolveSlotAssign('success')
                return
              }
            }
          }
        } catch (e) {
          if (isAbortError(e)) return
          console.error('Slot poll error:', e)
        }
        if (attempts < maxAttempts && pendingSlotAssign) {
          pendingSlotPollTimer = setTimeout(poll, 3000)
        }
        // If max attempts reached, the global timeout (15s) will handle it
      }

      // Start first poll after 3s (give the printer time to process)
      pendingSlotPollTimer = setTimeout(poll, 3000)
    }

    async function handleAssignSpoolToTray(slot: any, printerId: any) {
      if (!spool) return
      const idx = slot.slot_index || ''
      const parts = idx.split('-')
      const amsId = parseInt(parts[0])
      const trayId = parseInt(parts[1])
      const slotIndex = `${amsId}-${trayId}`

      // Clear any previous pending state
      clearPendingSlotAssign()

      // Immediately show white pulsing ring
      const dotEl = getSlotDot(slotIndex, printerId)
      if (dotEl) {
        clearSlotRingState(dotEl)
        dotEl.classList.add('slot-sending')
      }

      // Gather filament data from spool's printer params or spool/filament defaults
      let filamentData: Record<string, unknown> = {}
      try {
        const [spoolParamsRes, filamentParamsRes] = await Promise.all([
          fetch(`/api/v1/spools/${id}/printer-params?printer_id=${printerId}`, { credentials: 'include', signal: getAbortSignal() }),
          fetch(`/api/v1/filaments/${spool.filament_id}/printer-params?printer_id=${printerId}`, { credentials: 'include', signal: getAbortSignal() }),
        ])
        const spoolParams = spoolParamsRes.ok ? await spoolParamsRes.json() : []
        const filamentParams = filamentParamsRes.ok ? await filamentParamsRes.json() : []

        // Build merged value map (spool overrides filament)
        const valMap: Record<string, string> = {}
        filamentParams.forEach((p: any) => { if (p.param_value) valMap[p.param_key] = p.param_value })
        spoolParams.forEach((p: any) => { if (p.param_value) valMap[p.param_key] = p.param_value })

        filamentData = {
          tray_info_idx: valMap['bambu_idx'] || valMap['bambu_tray_idx'] || 'GFL99',
          bambu_idx: valMap['bambu_idx'] || valMap['bambu_tray_idx'] || '',
          nozzle_temp_min: parseInt(valMap['bambu_nozzle_temp_min']) || 190,
          nozzle_temp_max: parseInt(valMap['bambu_nozzle_temp_max']) || 230,
          material_type: spool.filament?.material_type || 'PLA',
          color: (spool.filament?.colors?.[0]?.color?.hex_code || 'FFFFFF').replace('#', '').slice(0, 6),
        }
      } catch (e) {
        if (isAbortError(e)) return
        console.error('Failed to fetch params for assign:', e)
        filamentData = {
          tray_info_idx: 'GFL99',
          bambu_idx: '',
          nozzle_temp_min: 190,
          nozzle_temp_max: 230,
          material_type: spool.filament?.material_type || 'PLA',
          color: (spool.filament?.colors?.[0]?.color?.hex_code || 'FFFFFF').replace('#', '').slice(0, 6),
        }
      }

      try {
        const res = await fetch(`/api/v1/printers/${printerId}/driver/action`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          credentials: 'include',
          signal: getAbortSignal(),
          body: JSON.stringify({
            action: 'send_filament_to_tray',
            params: { ams_id: amsId, tray_id: trayId, filament_data: filamentData, spool_id: id }
          })
        })
        if (res.ok) {
          // Track expected color for polling comparison
          const expectedColor = ((filamentData.color as string) || 'FFFFFF').slice(0, 6)
          pendingSlotAssign = { slotIndex, printerId, expectedColor }
          // Absolute timeout fallback (15s)
          pendingSlotTimeout = setTimeout(() => {
            resolveSlotAssign('error')
          }, 15000)
          // Start polling printer health for slot confirmation
          startSlotPolling()
        } else {
          const err = await res.json().catch(() => null)
          if (dotEl) { clearSlotRingState(dotEl); dotEl.classList.add('slot-error') }
          clearPendingSlotAssign()
          window.__fmAlert?.(err?.detail?.message || t('spools.slotAssignError'))
        }
      } catch (e) {
        if (isAbortError(e)) return
        console.error('Failed to assign spool to tray:', e)
        if (dotEl) { clearSlotRingState(dotEl); dotEl.classList.add('slot-error') }
        clearPendingSlotAssign()
        window.__fmAlert?.(t('spools.slotAssignError'))
      }
    }

    async function saveTrayParamsToEntity(slot: any, printerId: any, entityType: any) {
      // Map tray data to bambu param keys
      const params = []
      if (slot.tray_info_idx) params.push({ param_key: 'bambu_tray_idx', param_value: String(slot.tray_info_idx) })
      if (slot.nozzle_temp_min != null) params.push({ param_key: 'bambu_nozzle_temp_min', param_value: String(slot.nozzle_temp_min) })
      if (slot.nozzle_temp_max != null) params.push({ param_key: 'bambu_nozzle_temp_max', param_value: String(slot.nozzle_temp_max) })

      if (params.length === 0) {
        window.__fmAlert?.(t('spools.slotNoData'))
        return false
      }

      const entityId = entityType === 'spool' ? id : spool.filament_id
      const urlBase = entityType === 'spool' ? 'spools' : 'filaments'

      try {
        const res = await fetch(`/api/v1/${urlBase}/${entityId}/printer-params/${printerId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          credentials: 'include',
          signal: getAbortSignal(),
          body: JSON.stringify({ params }),
        })
        if (!res.ok) {
          const err = await res.json().catch(() => null)
          throw new Error(err?.detail?.message || 'Failed')
        }
        return true
      } catch (e) {
        if (isAbortError(e)) return
        console.error(`Failed to save tray params to ${entityType}:`, e)
        return false
      }
    }

    async function handleImportTrayToSpool(slot: any, printerId: any) {
      const ok = await saveTrayParamsToEntity(slot, printerId, 'spool')
      if (ok) {
        window.__fmSuccess?.(t('spools.slotImportSpoolSuccess'))
        // Refresh printer params display if same printer is selected
        const sel = document.getElementById('printer-select') as HTMLSelectElement | null
        if (sel && parseInt(sel.value) === printerId) loadSpoolPrinterParams(printerId)
      } else {
        window.__fmAlert?.(t('spools.slotImportError'))
      }
    }

    async function handleImportTrayToSpoolAndFilament(slot: any, printerId: any) {
      const [spoolOk, filamentOk] = await Promise.all([
        saveTrayParamsToEntity(slot, printerId, 'spool'),
        saveTrayParamsToEntity(slot, printerId, 'filament'),
      ])
      if (spoolOk && filamentOk) {
        window.__fmSuccess?.(t('spools.slotImportBothSuccess'))
        const sel = document.getElementById('printer-select') as HTMLSelectElement | null
        if (sel && parseInt(sel.value) === printerId) loadSpoolPrinterParams(printerId)
      } else {
        window.__fmAlert?.(t('spools.slotImportError'))
      }
    }

    // --- SSE Auto-Update (via shared Layout.astro connection) ---
    let pendingOverviewReload: number | null = null
    let overviewIntervalId: number | null = null
    function queueOverviewReload() {
      if (pendingOverviewReload != null) return
      pendingOverviewReload = window.setTimeout(async () => {
        pendingOverviewReload = null
        await loadPrinterSlotOverview()
      }, 200)
    }

    window.addEventListener('filaman:data-changed', async (e: Event) => {
      const data = (e as CustomEvent).detail
      if (data.event === 'slots_update') {
        if (pendingSlotAssign && data.printer_id === pendingSlotAssign.printerId) {
          // Fast path: SSE confirms the assignment for the correct printer
          resolveSlotAssign('success')
        } else if (!pendingSlotAssign) {
          // No pending assign — just reload slot overview as usual
          queueOverviewReload()
        }
        // If pending but wrong printer_id → ignore, let polling handle it
      } else if (data.event === 'printer_update' && !pendingSlotAssign) {
        // Slot assignments or active spool state may have changed.
        queueOverviewReload()
      }
    })

    // Multi-worker fallback: ensure slot/active-spool view stays fresh even
    // if SSE events are handled by another worker process.
    overviewIntervalId = window.setInterval(() => {
      if (!pendingSlotAssign) queueOverviewReload()
    }, 15000)

    window.addEventListener('pagehide', () => {
      if (overviewIntervalId != null) {
        window.clearInterval(overviewIntervalId)
        overviewIntervalId = null
      }
    })

    declare global {
      interface Window {
        __fmAlert?: (msg: string) => void
        __fmSuccess?: (msg: string) => void
        openRfidModal?: () => void
      }
    }

    loadData()
  </script>
</Layout>
