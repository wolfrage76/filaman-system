    async function startTagScan(deviceId: number) {
      importTagContent.innerHTML = ''
      const wrapper = document.createElement('div')
      wrapper.style.cssText = 'text-align: center; padding: 24px 0;'
      const spinner = document.createElement('div')
      spinner.className = 'fm-spinner'
      spinner.style.cssText = 'margin: 0 auto 16px; width: 36px; height: 36px; border-width: 3px;'
      const statusP = document.createElement('p')
      statusP.style.cssText = 'color: var(--text-muted); margin: 0 0 8px;'
      statusP.textContent = t('spools.importFromTagPlaceOnScale')
      const countdownP = document.createElement('p')
      countdownP.id = 'import-tag-countdown'
      countdownP.style.cssText = 'font-size: 0.8rem; color: var(--text-muted); margin: 0;'
      wrapper.append(spinner, statusP, countdownP)
      importTagContent.appendChild(wrapper)

      try {
        const triggerRes = await fetch(`/api/v1/devices/${deviceId}/request-tag-scan`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          credentials: 'include',
          body: '{}',
        })

        if (!triggerRes.ok) {
          let apiMsg: string | null = null
          try {
            const payload = await triggerRes.json()
            if (typeof payload?.detail?.message === 'string') apiMsg = payload.detail.message
            else if (typeof payload?.message === 'string') apiMsg = payload.message
          } catch {
            apiMsg = null
          }
          showImportError(apiMsg || t('spools.importFromTagTriggerFailed'))
          return
        }
      } catch {
        showImportError(t('spools.importFromTagTriggerFailed'))
        return
      }

      let attempts = 0
      const maxAttempts = 30
      importPollInterval = setInterval(async () => {
        attempts++
        const el = document.getElementById('import-tag-countdown')
        if (el) el.textContent = `${maxAttempts - attempts}s`
        if (attempts > maxAttempts) {
          clearInterval(importPollInterval!); importPollInterval = null
          showImportError(t('spools.importFromTagTimeout'))
          return
        }
        try {
          const res = await fetch(`/api/v1/devices/${deviceId}/tag-scan-result`, { credentials: 'include' })
          if (!res.ok) {
            clearInterval(importPollInterval!); importPollInterval = null
            showImportError(t('spools.importFromTagScanFailed'))
            return
          }
          const data = await res.json()
          if (data.status === 'success' && data.tag_data) {
            clearInterval(importPollInterval!); importPollInterval = null
            await applyTagDataToForm(data.tag_data)
          } else if (data.status === 'error') {
            clearInterval(importPollInterval!); importPollInterval = null
            showImportError(data.error_message || t('spools.importFromTagScanFailed'))
          }
        } catch { /* ignore poll errors */ }
      }, 1000)
    }

    function showImportError(msg: string) {
      importTagContent.innerHTML = ''
      const errDiv = document.createElement('div')
      errDiv.className = 'fm-alert-error'
      errDiv.style.marginBottom = '16px'
      errDiv.textContent = msg
      importTagContent.appendChild(errDiv)
      const devId = importSelectedDeviceId
      if (devId) {
        const retryBtn = document.createElement('button')
        retryBtn.type = 'button'
        retryBtn.className = 'fm-btn fm-btn-outline'
        retryBtn.textContent = t('common.retry')
        retryBtn.addEventListener('click', () => startTagScan(devId))
        importTagContent.appendChild(retryBtn)
      }
    }

    async function resolveFilamentFromTag(tagData: any): Promise<any | null> {
      const materialType = String(tagData?.type || '').trim()
      if (!materialType) return null

      const payload: Record<string, unknown> = {
        type: materialType,
      }

      const brand = String(tagData?.brand || '').trim()
      if (brand) payload.brand = brand

      const subtype = String(tagData?.subtype || '').trim()
      if (subtype) payload.subtype = subtype

      if (tagData?.min_temp != null && String(tagData.min_temp).trim() !== '') {
        payload.min_temp = tagData.min_temp
      }
      if (tagData?.max_temp != null && String(tagData.max_temp).trim() !== '') {
        payload.max_temp = tagData.max_temp
      }
      if (tagData?.diameter != null && String(tagData.diameter).trim() !== '') {
        payload.diameter = tagData.diameter
      }

      const res = await fetch('/api/v1/filaments/resolve-from-tag', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
        credentials: 'include',
        body: JSON.stringify(payload),
      })

      if (!res.ok) {
        let message = 'Failed to resolve filament from tag data'
        try {
          const errPayload = await res.json()
          message = errPayload?.detail?.message || errPayload?.message || message
        } catch {
          // keep default message
        }
        throw new Error(message)
      }

      return await res.json()
    }

    async function refreshFilamentsForResolvedSelection(filamentId: number) {
      invalidateCachePrefix(CACHE_KEYS.FILAMENTS)
      const filamentsData = await cachedFetchAllPages(CACHE_KEYS.FILAMENTS, '/api/v1/filaments')
      filaments = filamentsData.items
      populateFilamentDropdown(filamentsData.items, String(filamentId))
    }

    async function applyTagDataToForm(tagData: any) {
      const brand = (tagData.brand || '').toLowerCase().trim()
      const type  = (tagData.type  || '').toLowerCase().trim()
      let matchedFilament: any = null

      if (type) {
        try {
          const resolved = await resolveFilamentFromTag(tagData)
          if (resolved?.filament_id) {
            await refreshFilamentsForResolvedSelection(resolved.filament_id)
            matchedFilament = filaments.find((f: any) => f.id === resolved.filament_id) || null
          }
        } catch (error) {
          console.error('Failed to resolve filament from tag:', error)
          showImportError(error instanceof Error ? error.message : t('spools.importFromTagResolveFailed'))
          return
        }
      }

      if (type) {
        if (!matchedFilament) {
          matchedFilament = filaments.find((f: any) =>
            brand && (f.manufacturer?.name || '').toLowerCase().includes(brand) &&
            (f.material_type || '').toLowerCase() === type
          )
        }
        if (!matchedFilament) {
          matchedFilament = filaments.find((f: any) => (f.material_type || '').toLowerCase() === type)
        }
      }
      importTagContent.innerHTML = ''
      if (matchedFilament) {
        selectFilament(matchedFilament.id)
        const successDiv = document.createElement('div')
        successDiv.className = 'fm-alert-success'
        successDiv.style.marginBottom = '16px'
        successDiv.textContent = `✓ ${t('spools.importFromTagMatched')}: `
        const strong = document.createElement('strong')
        strong.textContent = matchedFilament.designation
        successDiv.appendChild(strong)
        importTagContent.appendChild(successDiv)
      } else {
        const warnDiv = document.createElement('div')
        warnDiv.className = 'fm-alert-warning'
        warnDiv.style.marginBottom = '16px'
        const displayTag = `${tagData.brand || ''} ${tagData.type || ''}`.trim()
        warnDiv.textContent = `${t('spools.importFromTagNoMatch')}: `
        const strong = document.createElement('strong')
        strong.textContent = displayTag
        warnDiv.appendChild(strong)
        const span = document.createElement('span')
        span.textContent = `. ${t('spools.importFromTagSelectManually')}.`
        warnDiv.appendChild(span)
        importTagContent.appendChild(warnDiv)
      }
      const doneBtn = document.createElement('button')
      doneBtn.type = 'button'
      doneBtn.className = matchedFilament ? 'fm-btn fm-btn-primary' : 'fm-btn fm-btn-outline'
      doneBtn.textContent = t('common.close')
      doneBtn.addEventListener('click', closeImportTagModal)
      importTagContent.appendChild(doneBtn)
    }

    btnImportFromTag?.addEventListener('click', openImportTagModal)
    btnImportTagClose?.addEventListener('click', closeImportTagModal)
    importTagModal?.addEventListener('click', (e) => { if (e.target === importTagModal) closeImportTagModal() })

    loadOptions()
    checkActiveDevicesForImport()
  </script>
</Layout>
