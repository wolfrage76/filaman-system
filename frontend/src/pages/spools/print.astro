---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="FilaMan - Label Print">
  <style>
    .print-page { display: flex; height: calc(100vh - 64px); margin: -32px; overflow: hidden; }
    .print-sidebar { width: 320px; background: var(--bg-elevated); border-right: 1px solid var(--border); padding: 24px; display: flex; flex-direction: column; gap: 20px; overflow-y: auto; }
    .sidebar-header { display: flex; align-items: center; gap: 10px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
    .back-link { color: var(--accent); text-decoration: none; font-size: 0.9rem; font-weight: 500; cursor: pointer; }
    .back-link:hover { opacity: 0.8; }
    .settings-section { display: flex; flex-direction: column; gap: 16px; }
    .settings-section h3 { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-muted); margin: 0; }
    .action-buttons { margin-top: auto; display: flex; flex-direction: column; gap: 10px; padding-top: 20px; border-top: 1px solid var(--border); }
    .checkbox-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
    .fm-label { font-size: 0.8rem; font-weight: 600; margin-bottom: 6px; display: block; color: var(--text); }
    .fm-checkbox-group { display: flex; align-items: center; gap: 10px; cursor: pointer; padding: 8px 12px; border-radius: var(--radius-sm); }
    .fm-checkbox-group:hover { background: var(--bg-soft); }
    .fm-checkbox-group input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--accent); cursor: pointer; }
    .fm-checkbox-group span { font-size: 0.9rem; color: var(--text); }
    .fm-btn { padding: 12px 20px; border-radius: 999px; border: 1px solid transparent; font-weight: 600; font-size: 0.875rem; cursor: pointer; font-family: var(--font-sans); }
    .fm-btn-primary { background: var(--accent); color: var(--btn-primary-text); box-shadow: var(--glow); }
    .fm-btn-primary:hover { transform: translateY(-2px); }
    .fm-btn-outline { background: transparent; border-color: var(--border); color: var(--text); }
    .fm-btn-outline:hover { background: var(--bg-soft); }
    .fm-input { background: var(--input-bg); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; color: var(--text); font-size: 0.9rem; width: 100%; height: 42px; box-sizing: border-box; }
    .preview-container { flex: 1; overflow-y: auto; padding: 40px; background: var(--bg-soft); display: flex; flex-direction: column; align-items: center; gap: 24px; }
    .label-count { font-size: 0.85rem; color: var(--text-muted); }
    .checkbox-grid-single { grid-template-columns: 1fr; }
  </style>

  <!-- Label CSS must be global so dynamically inserted elements receive styles -->
  <style is:global>
    .label-preview {
      background: white !important;
      box-shadow: 0 4px 24px rgba(0,0,0,0.18);
      display: flex; flex-direction: column;
      padding: 2mm; box-sizing: border-box; overflow: hidden; position: relative;
      border-radius: 4px; color: black !important;
      font-family: 'Space Grotesk', 'Segoe UI', sans-serif;
    }
    .label-top { display: flex; align-items: center; justify-content: center; gap: 1mm; padding-bottom: 0.3mm; min-height: 0; }
    .label-logo { max-height: 5mm; max-width: 55%; object-fit: contain; display: block; }
    .label-mfr-text { font-weight: 600; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: black !important; }
    .label-divider { border-top: 0.3mm solid black; margin: 0 0 1mm 0; }
    .label-middle { display: flex; align-items: flex-start; justify-content: space-between; gap: 2mm; flex: 1; min-height: 0; }
    .label-middle-left { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.5mm; }
    .label-designation { font-weight: 700; overflow: hidden; word-break: break-word; color: black !important; line-height: 1.1; }
    .label-color-row { display: flex; align-items: center; gap: 1.5mm; }
    .label-color-swatch { width: 100%; height: 3mm; border-radius: 0.5mm; flex-shrink: 0; }
    .label-color-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: black !important; }
    .label-hex-code { font-family: 'Space Mono', 'Courier New', monospace; white-space: nowrap; color: black !important; flex-shrink: 0; align-self: flex-end; }
    .label-bottom { display: flex; align-items: flex-end; justify-content: space-between; gap: 2mm; margin-top: auto; }
    .label-bottom-left { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.3mm; }
    .label-spool-id { font-weight: 600; color: black !important; }
    .label-extra-fields { display: flex; flex-direction: column; gap: 0; }
    .label-qr { flex-shrink: 0; }
    .label-id-corner {
      position: absolute; top: 1.2mm; right: 1.5mm;
      font-weight: 700; font-family: 'Space Mono', 'Courier New', monospace;
      color: black !important; white-space: nowrap; line-height: 1;
    }

    @media print {
      html, body { margin: 0 !important; padding: 0 !important; background: white !important; }
      .fm-sidebar, #fm-confirm-overlay, .fm-sidebar-backdrop { display: none !important; }
      .fm-page { display: block !important; background: white !important; }
      .fm-page > main { padding: 0 !important; margin: 0 !important; background: white !important; }
      .print-sidebar, .label-count { display: none !important; }
      .print-page { margin: 0 !important; height: auto !important; display: block !important; }
      .preview-container { padding: 0 !important; margin: 0 !important; display: block !important; background: white !important; gap: 0 !important; align-items: stretch !important; }
      .label-wrapper { break-after: page !important; page-break-after: always !important; display: flex !important; justify-content: center !important; }
      .label-wrapper:last-child { break-after: avoid !important; page-break-after: avoid !important; }
      /* Reset zoom for print so output is unaffected by preview zoom */
      .label-preview { zoom: 1 !important; }
      .label-preview {
        box-shadow: none !important; border: none !important; border-radius: 0 !important;
        display: flex !important; flex-direction: column !important;
        background: white !important; color: black !important;
        margin: 0 !important; padding: 2mm !important; overflow: hidden !important;
        break-inside: avoid !important;
        -webkit-print-color-adjust: exact; print-color-adjust: exact;
      }
      .label-preview * { color: black !important; }
      .label-color-swatch { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
      .label-qr img, .label-logo { display: block !important; }
    }
  </style>

  <div class="print-page">
    <aside class="print-sidebar">
      <a id="btn-back" href="/spools" class="sidebar-header back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        <span id="btn-back-label" data-i18n="labelPrint.backToOverview">Back to Overview</span>
      </a>

      <div class="settings-section">
        <h3 data-i18n="labelPrint.settingsTitle">Label Settings</h3>
        <div><label class="fm-label" data-i18n="labelPrint.widthMm">Width (mm)</label><input type="number" id="input-width" value="60" class="fm-input"></div>
        <div><label class="fm-label" data-i18n="labelPrint.heightMm">Height (mm)</label><input type="number" id="input-height" value="40" class="fm-input"></div>
        <div><label class="fm-label" data-i18n="labelPrint.fontSize">Font Size (%)</label><input type="range" id="input-font-size" min="50" max="200" value="100" class="fm-input" style="padding: 8px;"></div>
        <div><label class="fm-label" data-i18n="labelPrint.qrSize">QR Size (mm)</label><input type="number" id="input-qr-size" value="18" class="fm-input"></div>

        <h3 data-i18n="labelPrint.displayTitle">Display</h3>
        <div class="checkbox-grid">
          <label class="fm-checkbox-group"><input type="checkbox" id="check-logo" checked><span data-i18n="labelPrint.checkLogo">Logo</span></label>
          <label class="fm-checkbox-group"><input type="checkbox" id="check-qr" checked><span data-i18n="labelPrint.checkQR">QR Code</span></label>
          <label class="fm-checkbox-group"><input type="checkbox" id="check-id" checked><span data-i18n="labelPrint.checkId">Spool ID</span></label>
          <label class="fm-checkbox-group"><input type="checkbox" id="check-mfr" checked><span data-i18n="labelPrint.checkMfr">Manufacturer</span></label>
          <label class="fm-checkbox-group"><input type="checkbox" id="check-mat" checked><span data-i18n="labelPrint.checkMat">Material</span></label>
        </div>

        <h3 id="ef-section-title" data-i18n="labelPrint.extraFieldsTitle" style="display:none;">Extra Fields</h3>
        <div id="ef-checkboxes" class="checkbox-grid checkbox-grid-single" style="display:none;"></div>
        <div id="ef-truncate-row" style="display:none;">
          <label class="fm-label" data-i18n="labelPrint.truncateLabel">Truncate field name (chars, 0 = off)</label>
          <input type="number" id="input-ef-truncate" value="0" min="0" max="60" class="fm-input">
        </div>

        <h3 data-i18n="labelPrint.previewTitle">Preview</h3>
        <div>
          <label class="fm-label" data-i18n="labelPrint.zoomLabel">Zoom (%)</label>
          <input type="range" id="input-zoom" min="25" max="300" value="100" class="fm-input" style="padding: 8px;">
        </div>
      </div>

      <div class="action-buttons">
        <button class="fm-btn fm-btn-primary" onclick="filamanPrint()" data-i18n="labelPrint.btnPrint">Print</button>
        <button id="btn-export-png" class="fm-btn fm-btn-outline" onclick="filamanExportPNG()" data-i18n="labelPrint.btnExportPng">Export PNG</button>
        <button id="btn-export-pdf" class="fm-btn fm-btn-outline" onclick="filamanExportPDF()" data-i18n="labelPrint.btnExportPdf">Export PDF</button>
        <button id="btn-reset" class="fm-btn fm-btn-outline" data-i18n="labelPrint.btnReset">Reset</button>
      </div>
    </aside>

    <main class="preview-container" id="preview-container">
      <div class="label-count" id="label-count"></div>
    </main>
  </div>
</Layout>

<script>
  import { t, initI18n } from '../../lib/i18n'

  ;(window as any).filamanPrint = function() {
    try { document.execCommand('print', false, null) } catch { window.print() }
  }

  const SETTINGS_KEY = 'filaman-label-settings'

  const widthInput   = document.getElementById('input-width') as HTMLInputElement
  const heightInput  = document.getElementById('input-height') as HTMLInputElement
  const fontInput    = document.getElementById('input-font-size') as HTMLInputElement
  const qrSizeInput  = document.getElementById('input-qr-size') as HTMLInputElement
  const checkLogo    = document.getElementById('check-logo') as HTMLInputElement
  const checkQR      = document.getElementById('check-qr') as HTMLInputElement
  const checkID      = document.getElementById('check-id') as HTMLInputElement
  const checkMfr     = document.getElementById('check-mfr') as HTMLInputElement
  const checkMat     = document.getElementById('check-mat') as HTMLInputElement
  const efTruncate   = document.getElementById('input-ef-truncate') as HTMLInputElement
  const zoomInput    = document.getElementById('input-zoom') as HTMLInputElement

  let spools: any[] = []
  const logoCache: Record<number, string | null> = {}

  // Extra field definitions from API: {key, label, target_type}
  let efDefs: {key: string, label: string, target_type: string}[] = []
  // Per-field checkbox state: key -> {checkbox, checked}
  const efCheckMap: Record<string, HTMLInputElement> = {}

  function efMapKey(targetType: string, key: string): string {
    return `${targetType}:${key}`
  }

  function truncLabel(label: string, max: number): string {
    if (!max || max <= 0) return label
    return label.length > max ? label.slice(0, max) : label
  }

  function saveSettings() {
    const efState: Record<string, boolean> = {}
    Object.entries(efCheckMap).forEach(([k, cb]) => { efState[k] = cb.checked })
    localStorage.setItem(SETTINGS_KEY, JSON.stringify({
      width: widthInput.value, height: heightInput.value,
      fontSize: fontInput.value, qrSize: qrSizeInput.value,
      showLogo: checkLogo.checked, showQR: checkQR.checked, showID: checkID.checked,
      showMfr: checkMfr.checked, showMat: checkMat.checked,
      efTruncate: efTruncate.value, zoom: zoomInput.value, extraFields: efState,
    }))
  }

  function loadSettings() {
    try {
      const s = JSON.parse(localStorage.getItem(SETTINGS_KEY) || 'null')
      if (!s) return
      if (s.width) widthInput.value = s.width
      if (s.height) heightInput.value = s.height
      if (s.fontSize) fontInput.value = s.fontSize
      if (s.qrSize) qrSizeInput.value = s.qrSize
      if (s.showLogo !== undefined) checkLogo.checked = s.showLogo
      if (s.showQR !== undefined) checkQR.checked = s.showQR
      if (s.showID !== undefined) checkID.checked = s.showID
      if (s.showMfr !== undefined) checkMfr.checked = s.showMfr
      if (s.showMat !== undefined) checkMat.checked = s.showMat
      if (s.efTruncate !== undefined) efTruncate.value = s.efTruncate
      if (s.zoom !== undefined) zoomInput.value = s.zoom
      if (s.extraFields) {
        Object.entries(s.extraFields as Record<string, boolean>).forEach(([k, v]) => {
          if (efCheckMap[k]) efCheckMap[k].checked = v
        })
      }
    } catch {}
  }

  async function loadLogo(mfrId: number): Promise<string | null> {
    if (mfrId in logoCache) return logoCache[mfrId]
    try {
      const r = await fetch(`/api/v1/manufacturers/${mfrId}/label-logo`, { credentials: 'include' })
      if (r.ok) {
        const blob = await r.blob()
        const dataUrl = await new Promise<string>((res) => {
          const reader = new FileReader()
          reader.onload = () => res(reader.result as string)
          reader.readAsDataURL(blob)
        })
        logoCache[mfrId] = dataUrl; return dataUrl
      }
    } catch {}
    logoCache[mfrId] = null; return null
  }

  function getExtraFieldsForSpool(spool: any): {key: string, label: string, value: string}[] {
    const maxLen = parseInt(efTruncate.value) || 0
    const result: {key: string, label: string, value: string}[] = []

    for (const def of efDefs) {
      const cb = efCheckMap[efMapKey(def.target_type, def.key)]
      if (!cb?.checked) continue

      let val: string | null = null
      if (def.target_type === 'spool' && spool.custom_fields) {
        const raw = spool.custom_fields[def.key]
        if (raw !== undefined && raw !== null) val = String(raw)
      } else if (def.target_type === 'filament' && spool.filament?.custom_fields) {
        const raw = spool.filament.custom_fields[def.key]
        if (raw !== undefined && raw !== null) val = String(raw)
      }
      if (val !== null) result.push({ key: def.key, label: truncLabel(def.label, maxLen), value: val })
    }
    return result
  }

  async function renderLabel(container: HTMLElement, spool: any) {
    const w = widthInput.value, h = heightInput.value
    const qrSize = qrSizeInput.value, fsBase = parseInt(fontInput.value) / 100

    const fil = spool.filament || {}, mfr = fil.manufacturer || {}
    const colors = fil.filament_colors || [], firstColor = colors[0] || {}
    const hex = (firstColor.color?.hex_code || '').replace('#', '')
    const colorName = firstColor.display_name_override || fil.manufacturer_color_name || firstColor.color?.name || ''
    const logoUrl = mfr.id ? await loadLogo(mfr.id) : null

    const zoom = parseInt(zoomInput.value) / 100
    container.style.width = w + 'mm'
    container.style.height = h + 'mm'
    // CSS zoom affects layout flow (unlike transform: scale), so siblings space correctly
    container.style.zoom = String(zoom)

    const topArea  = container.querySelector('.label-top') as HTMLElement
    const topDiv   = container.querySelector('.label-divider') as HTMLElement
    const logoImg  = container.querySelector('.label-logo') as HTMLImageElement
    const mfrText  = container.querySelector('.label-mfr-text') as HTMLElement

    if (checkLogo.checked && logoUrl) {
      logoImg.src = logoUrl; logoImg.style.cssText = `display:block;max-height:${fsBase*5}mm`
      mfrText.style.display = 'none'; topArea.style.display = 'flex'; topDiv.style.display = 'block'
    } else if ((checkLogo.checked || checkMfr.checked) && mfr.name) {
      logoImg.style.display = 'none'
      mfrText.textContent = mfr.name; mfrText.style.cssText = `display:block;font-size:${fsBase*11}pt`
      topArea.style.display = 'flex'; topDiv.style.display = 'block'
    } else {
      topArea.style.display = 'none'; topDiv.style.display = 'none'
    }

    const filEl = container.querySelector('.label-designation') as HTMLElement
    const fullDesig = [fil.designation || '', checkMat.checked ? fil.material_type || '' : ''].filter(Boolean).join(' ')
    filEl.textContent = fullDesig; filEl.style.cssText = `font-size:${fsBase*12}pt;display:${fullDesig?'block':'none'}`

    // Color row and swatch hidden; hex always shown if available
    ;(container.querySelector('.label-color-row') as HTMLElement).style.display = 'none'
    ;(container.querySelector('.label-color-swatch') as HTMLElement).style.display = 'none'
    ;(container.querySelector('.label-color-name') as HTMLElement).style.display = 'none'

    const hexEl = container.querySelector('.label-hex-code') as HTMLElement
    const hasHex = !!hex
    if (hasHex) {
      hexEl.textContent = '#' + hex.toUpperCase(); hexEl.style.cssText = `display:block;font-size:${fsBase*9}pt`
    } else { hexEl.style.display = 'none' }

    const idEl = container.querySelector('.label-id-corner') as HTMLElement
    idEl.style.display = checkID.checked ? 'block' : 'none'
    if (checkID.checked) { idEl.textContent = '# ' + spool.id; idEl.style.fontSize = (fsBase*7)+'pt' }

    // Extra fields
    const efContainer = container.querySelector('.label-extra-fields') as HTMLElement
    efContainer.innerHTML = ''
    const efValues = getExtraFieldsForSpool(spool)
    for (const ef of efValues) {
      const div = document.createElement('div')
      div.style.cssText = `font-size:${fsBase*7}pt;color:black;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.3`
      const labelSpan = document.createElement('span')
      labelSpan.style.color = '#555'
      labelSpan.textContent = `${ef.label}:`
      div.appendChild(labelSpan)
      div.appendChild(document.createTextNode(` ${ef.value}`))
      efContainer.appendChild(div)
    }

    // QR
    const qrCont = container.querySelector('.label-qr') as HTMLElement
    qrCont.style.display = checkQR.checked ? 'block' : 'none'
    if (checkQR.checked) {
      if (typeof (window as any).QRCode === 'undefined') {
        await new Promise<void>((res, rej) => {
          const s = document.createElement('script'); s.src = '/vendor/qrcode.min.js'
          s.onload = () => res(); s.onerror = rej; document.head.appendChild(s)
        })
      }
      qrCont.innerHTML = ''
      const url = window.location.origin + '/spools/' + spool.id
      // High resolution for crisp output; CSS scales to mm size
      const qrPx = 400
      // @ts-ignore
      new QRCode(qrCont, { text: url, width: qrPx, height: qrPx, colorDark: '#000', colorLight: '#fff', correctLevel: (window as any).QRCode.CorrectLevel.H })
      qrCont.style.width = qrSize + 'mm'; qrCont.style.height = qrSize + 'mm'
      const canvas = qrCont.querySelector('canvas') as HTMLCanvasElement | null
      if (canvas) {
        const dataUrl = canvas.toDataURL('image/png')
        qrCont.innerHTML = ''
        const img = document.createElement('img')
        img.src = dataUrl; img.style.cssText = 'width:100%;height:100%;display:block'
        qrCont.appendChild(img)
      }
    }

    // Page size (set once; identical for all labels)
    let styleEl = document.getElementById('page-style')
    if (!styleEl) { styleEl = document.createElement('style'); styleEl.id = 'page-style'; document.head.appendChild(styleEl) }
    const isSafari = /Safari/.test(navigator.userAgent) && !/Chrome/.test(navigator.userAgent)
    styleEl.innerHTML = `
      ${isSafari ? '' : `@page { size: ${w}mm ${h}mm; margin: 0; }`}
      @media print { .label-preview { width:${w}mm !important; height:${h}mm !important; min-width:${w}mm !important; min-height:${h}mm !important; max-width:${w}mm !important; max-height:${h}mm !important; } }
    `
  }

  function makeLabelHtml(spoolId: number): string {
    return `<div class="label-wrapper" id="wrapper-${spoolId}"><div class="label-preview" id="label-${spoolId}">
      <div class="label-id-corner"></div>
      <div class="label-top"><img class="label-logo" alt=""/><div class="label-mfr-text"></div></div>
      <div class="label-divider"></div>
      <div class="label-middle">
        <div class="label-middle-left">
          <div class="label-designation"></div>
          <div class="label-color-row"><div class="label-color-swatch"></div><span class="label-color-name"></span></div>
        </div>
        <div class="label-hex-code"></div>
      </div>
      <div class="label-bottom">
        <div class="label-bottom-left">
          <div class="label-extra-fields"></div>
        </div>
        <div class="label-qr"></div>
      </div>
    </div></div>`
  }

  // Pre-fetch all unique manufacturer logos in parallel
  async function prefetchLogos() {
    const mfrIds = [...new Set(
      spools.map(s => s.filament?.manufacturer?.id).filter((id): id is number => !!id)
    )]
    await Promise.all(mfrIds.map(id => loadLogo(id)))
  }

  // Render labels in parallel chunks so the browser stays responsive
  async function renderAll() {
    const CHUNK = 6
    for (let i = 0; i < spools.length; i += CHUNK) {
      const chunk = spools.slice(i, i + CHUNK)
      await Promise.all(chunk.map(spool => {
        const el = document.getElementById(`label-${spool.id}`)
        return el ? renderLabel(el, spool) : Promise.resolve()
      }))
      // Yield to browser between chunks
      await new Promise(r => setTimeout(r, 0))
    }
    saveSettings()
  }

  async function loadExtraFieldDefs() {
    try {
      const [spoolDefs, filamentDefs] = await Promise.all([
        fetch('/api/v1/system-extra-fields?target_type=spool', { credentials: 'include' }).then(r => r.json()),
        fetch('/api/v1/system-extra-fields?target_type=filament', { credentials: 'include' }).then(r => r.json()),
      ])
      const allDefs = [
        ...(Array.isArray(spoolDefs) ? spoolDefs : (spoolDefs.items || [])).map((d: any) => ({...d, target_type: 'spool'})),
        ...(Array.isArray(filamentDefs) ? filamentDefs : (filamentDefs.items || [])).map((d: any) => ({...d, target_type: 'filament'})),
      ]
      if (allDefs.length === 0) return

      efDefs = allDefs
      const titleEl = document.getElementById('ef-section-title')!
      const container = document.getElementById('ef-checkboxes')!
      const truncRow = document.getElementById('ef-truncate-row')!
      titleEl.style.display = ''; container.style.removeProperty('display'); truncRow.style.display = ''

      const hasBoth = allDefs.some(d => d.target_type === 'spool') && allDefs.some(d => d.target_type === 'filament')
      // Copy Astro scope attribute so scoped CSS applies to dynamic elements
      const scopeAttr = (() => {
        const existing = document.querySelector('.fm-checkbox-group')
        if (!existing) return null
        return Array.from(existing.attributes).find(a => a.name.startsWith('data-astro-cid-'))
      })()
      for (const def of allDefs) {
        const row = document.createElement('label')
        row.className = 'fm-checkbox-group'
        const cb = document.createElement('input'); cb.type = 'checkbox'; cb.checked = false
        const span = document.createElement('span')
        span.textContent = hasBoth ? `${def.label} (${def.target_type === 'spool' ? t('labelPrint.suffixSpool') : t('labelPrint.suffixFilament')})` : def.label
        if (scopeAttr) { row.setAttribute(scopeAttr.name, ''); cb.setAttribute(scopeAttr.name, ''); span.setAttribute(scopeAttr.name, '') }
        row.appendChild(cb); row.appendChild(span)
        container.appendChild(row)
        efCheckMap[efMapKey(def.target_type, def.key)] = cb
        cb.addEventListener('change', renderAll)
      }
    } catch {}
  }

  // ── Export helpers ────────────────────────────────────────────────────────

  function downloadDataUrl(dataUrl: string, filename: string) {
    const a = document.createElement('a')
    a.download = filename; a.href = dataUrl; a.click()
  }

  async function captureLabel(spool: any): Promise<string> {
    const { toPng } = await import('html-to-image')
    const spoolId = spool?.id
    if (spoolId == null) {
      throw new Error('Cannot capture label: spool is missing an id')
    }
    const el = document.getElementById(`label-${spoolId}`)
    if (!(el instanceof HTMLElement)) {
      throw new Error(`Cannot capture label: element label-${spoolId} was not found`)
    }
    const oz = el.style.zoom
    el.style.zoom = '1'
    try {
      if (document.fonts?.ready) {
        await document.fonts.ready
      }
      await new Promise(r => requestAnimationFrame(r))
      const dataUrl = await toPng(el, {
        pixelRatio: 4,
        backgroundColor: '#ffffff',
        skipFonts: true,
        filter: (node: Node) => {
        if (node instanceof Element) {
          const style = window.getComputedStyle(node)
          if (style.display === 'none') {
            return false
          }
        }
        // Skip logo img elements with no explicit/usable src (e.g. hidden placeholder)
        if (node instanceof HTMLImageElement && node.classList.contains('label-logo')) {
          const srcAttr = node.getAttribute('src')?.trim() ?? ''
          if (!srcAttr) {
            return false
          }
          return srcAttr.startsWith('data:') || srcAttr.startsWith('http://') || srcAttr.startsWith('https://') || srcAttr.startsWith('/')
          }
          return true
        },
      })
      return dataUrl
    } finally {
      el.style.zoom = oz
    }
  }

  ;(window as any).filamanExportPNG = async function() {
    if (spools.length === 0) return
    const btn = document.getElementById('btn-export-png') as HTMLButtonElement
    const orig = btn.textContent; btn.disabled = true; btn.textContent = t('labelPrint.exporting')
    try {
      if (spools.length === 1) {
        downloadDataUrl(await captureLabel(spools[0]), `label-${spools[0].id}.png`)
      } else {
        const JSZip = (await import('jszip')).default
        const zip = new JSZip()
        for (const spool of spools) {
          const dataUrl = await captureLabel(spool)
          zip.file(`label-${spool.id}.png`, dataUrl.split(',')[1], { base64: true })
        }
        const blob = await zip.generateAsync({ type: 'blob' })
        const url = URL.createObjectURL(blob)
        downloadDataUrl(url, `labels-${new Date().toISOString().slice(0, 10)}.zip`)
        setTimeout(() => URL.revokeObjectURL(url), 60000)
      }
    } catch (e) {
      alert(t('labelPrint.pngExportFailed'))
      console.error(e)
    } finally { btn.disabled = false; btn.textContent = orig }
  }

  ;(window as any).filamanExportPDF = async function() {
    if (spools.length === 0) return
    const btn = document.getElementById('btn-export-pdf') as HTMLButtonElement
    const orig = btn.textContent; btn.disabled = true; btn.textContent = t('labelPrint.exporting')
    try {
      const { jsPDF } = await import('jspdf')
      const w = parseFloat(widthInput.value), h = parseFloat(heightInput.value)
      const orient = w > h ? 'l' : 'p'
      const pdf = new jsPDF({ orientation: orient, unit: 'mm', format: [w, h] })

      for (let i = 0; i < spools.length; i++) {
        if (i > 0) pdf.addPage([w, h], orient)
        pdf.addImage(await captureLabel(spools[i]), 'PNG', 0, 0, w, h)
      }
      pdf.save(`labels-${new Date().toISOString().slice(0, 10)}.pdf`)
    } catch (e) {
      alert(t('labelPrint.pdfExportFailed'))
      console.error(e)
    } finally { btn.disabled = false; btn.textContent = orig }
  }

  // ── Init ──────────────────────────────────────────────────────────────────

  await initI18n()

  const urlParams = new URLSearchParams(window.location.search)
  const backId = urlParams.get('back')
  const backBtn = document.getElementById('btn-back') as HTMLAnchorElement
  if (backId) {
    backBtn.href = `/spools/${backId}`
    ;(document.getElementById('btn-back-label') as HTMLElement).textContent = t('labelPrint.backToSpool')
  }

  const idsParam = urlParams.get('ids') || ''
  const ids = idsParam.split(',').map(Number).filter(n => n > 0)
  const previewContainer = document.getElementById('preview-container')!
  const countEl = document.getElementById('label-count')!

  if (ids.length === 0) {
    countEl.textContent = t('labelPrint.noSpoolsSelected')
  } else {
    countEl.textContent = t('labelPrint.labelsLoading', { count: String(ids.length) })
    ids.forEach(id => previewContainer.insertAdjacentHTML('beforeend', makeLabelHtml(id)))

    const [spoolResults] = await Promise.all([
      Promise.allSettled(ids.map(async id => {
        const r = await fetch(`/api/v1/spools/${id}`, { credentials: 'include' })
        if (!r.ok) throw new Error(`Failed to load spool ${id}: ${r.status}`)
        return await r.json()
      })),
      loadExtraFieldDefs(),
    ])
    spools = spoolResults.filter(r => r.status === 'fulfilled').map(r => (r as PromiseFulfilledResult<any>).value)
    countEl.textContent = spoolResults.length === spools.length
      ? t('labelPrint.labelsReady', { count: String(spools.length) })
      : `${t('labelPrint.labelsReady', { count: String(spools.length) })} (${spools.length}/${ids.length})`

    loadSettings()
    await prefetchLogos()
    await renderAll()
  }

  ;[widthInput, heightInput, fontInput, qrSizeInput, zoomInput, checkLogo, checkQR, checkID, checkMfr, checkMat, efTruncate].forEach(el => {
    el.addEventListener('change', renderAll)
    if (el.type === 'range' || el.type === 'number') el.addEventListener('input', renderAll)
  })

  document.getElementById('btn-reset')?.addEventListener('click', () => {
    localStorage.removeItem(SETTINGS_KEY)
    widthInput.value = '60'; heightInput.value = '40'; fontInput.value = '100'; qrSizeInput.value = '18'
    efTruncate.value = '0'; zoomInput.value = '100'
    checkLogo.checked = checkQR.checked = checkID.checked = checkMfr.checked = checkMat.checked = true
    Object.values(efCheckMap).forEach(cb => { cb.checked = false })
    renderAll()
  })
</script>
