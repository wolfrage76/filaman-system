---
import Layout from '../layouts/Layout.astro'
---

<Layout title="FilaMan - Spool Log">
  <style is:global>
    .pagination-container { display: flex; justify-content: space-between; align-items: center; }
    .pagination-pages { display: flex; gap: 4px; align-items: center; font-size: 0.8rem; }
    .pagination-pages a { color: var(--accent); cursor: pointer; padding: 2px 6px; text-decoration: none; border-radius: 3px; }
    .pagination-pages a:hover { text-decoration: underline; background: color-mix(in srgb, var(--accent) 10%, transparent); }
    .pagination-pages .page-current { font-weight: 700; color: var(--accent); padding: 2px 8px; background: color-mix(in srgb, var(--accent) 15%, transparent); border-radius: 3px; }
    .pagination-pages .page-ellipsis { color: var(--text-muted); padding: 0 2px; }
    .fm-table .col-spool-id { width: 6ch; max-width: 6ch; white-space: nowrap; padding: 10px 4px 10px 8px; }
  </style>
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h1 style="font-size: 1.8rem; font-weight: 700; margin: 0; font-family: var(--font-serif);" data-i18n="spoolLog.title">Spool Log</h1>
  </div>

  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
    <div class="pagination-container" id="pagination-top" style="flex: 1;"></div>
  </div>

  <div class="fm-card" style="padding: 0;">
    <table class="fm-table">
      <thead>
        <tr style="background: var(--bg-soft);">
          <th class="col-spool-id" data-i18n="spoolLog.spool">Spool</th>
          <th data-i18n="spools.colMfrColor">Mfr. Color</th>
          <th data-i18n="spools.manufacturer">Manufacturer</th>
          <th data-i18n="spools.material">Material</th>
          <th data-i18n="spoolLog.eventType">Type</th>
          <th data-i18n="spoolLog.eventDate">Date</th>
          <th data-i18n="spoolLog.eventWeight">Weight</th>
          <th data-i18n="spoolLog.eventNote">Note</th>
        </tr>
      </thead>
      <tbody id="events-table">
        <tr>
          <td colspan="8" style="text-align: center; color: var(--text-muted);" data-i18n="common.loading">Loading...</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="pagination-container" id="pagination" style="margin-top: 16px;"></div>

  <script>
    import { t, initI18n, translatePage } from '../lib/i18n'
    import { getAbortSignal, isAbortError } from '../lib/abort'

    await initI18n()

    let currentPage = 1
    const allowedPageSizes = [25, 50, 100, 150, 200]
    let pageSize = parseInt(localStorage.getItem('filaman-pagesize-spool-log') || '50', 10)
    if (!allowedPageSizes.includes(pageSize)) pageSize = 50

    async function loadEvents() {
      try {
        const response = await fetch(`/api/v1/spools/all-events?page=${currentPage}&page_size=${pageSize}`, {
          credentials: 'include',
          signal: getAbortSignal(),
        })

        if (!response.ok) throw new Error('Failed to fetch events')

        const data = await response.json()
        renderEvents(data.items)
        renderPagination(data.total, data.page)
      } catch (error) {
        if (isAbortError(error)) return
        console.error('Failed to load events:', error)
        const tbody = document.getElementById('events-table')!
        tbody.innerHTML = `<tr><td colspan="8" style="text-align: center; color: var(--error-text);">${t('spoolLog.failedLoad')}</td></tr>`
      }
    }

    function renderEvents(events: any[]) {
      const tbody = document.getElementById('events-table')!

      if (events.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="8" style="text-align: center; color: var(--text-muted);">${t('spoolLog.noEvents')}</td>
          </tr>
        `
        return
      }

      tbody.innerHTML = events.map(e => `
        <tr>
          <td class="col-spool-id">
            <a href="/spools/${e.spool_id}" style="color: var(--accent); text-decoration: none; font-weight: 500;">#${e.spool_id}</a>
          </td>
          <td style="padding: 12px; font-size: 0.85rem; color: var(--text); white-space: nowrap;">
            <span style="display: inline-flex; align-items: center; gap: 6px;">${renderMfrColorCell(e.colors, e.manufacturer_color_name)}</span>
          </td>
          <td style="padding: 12px; font-size: 0.85rem; color: var(--text-muted);">${escapeHtml(e.manufacturer_name) || '-'}</td>
          <td style="padding: 12px; font-size: 0.85rem; color: var(--text-muted);">${escapeHtml(e.material_type) || '-'}</td>
          <td style="padding: 12px;">
            <span class="fm-pill" style="${getEventTypeStyle(e.event_type)}">${e.event_type}</span>
          </td>
          <td style="padding: 12px; font-size: 0.85rem; color: var(--text-muted);">
            ${new Date(e.event_at).toLocaleString()}
          </td>
          <td style="padding: 12px; font-family: monospace; font-size: 0.85rem;">
            ${e.measured_weight_g !== null ? e.measured_weight_g.toFixed(0) + 'g' : ''}
            ${e.delta_weight_g !== null ? (e.delta_weight_g > 0 ? '+' : '') + e.delta_weight_g.toFixed(0) + 'g' : ''}
          </td>
          <td style="padding: 12px; font-size: 0.85rem; color: var(--text-muted);">${e.note || '-'}</td>
        </tr>
      `).join('')
    }

    function escapeHtml(value: any): string {
      if (value === null || value === undefined) return ''
      return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;')
    }

    function normalizeHexColor(hex: string | null | undefined): string {
      const value = (hex || '').trim()
      if (!value) return ''
      return value.startsWith('#') ? value : `#${value}`
    }

    function renderColorDots(colors: any[] | null | undefined): string {
      if (!colors || colors.length === 0) return ''
      return colors.map(c => {
        if (!c) return ''
        const hex = normalizeHexColor(c.hex_code)
        if (!hex) return ''
        const title = escapeHtml(c.name || '')
        return `<span title="${title}" style="display: inline-block; width: 18px; height: 18px; border-radius: 50%; background-color: ${hex}; border: 2px solid var(--border); vertical-align: middle; margin-right: 6px;"></span>`
      }).join('')
    }

    function renderMfrColorCell(
      colors: any[] | null | undefined,
      manufacturerColorName: string | null | undefined
    ): string {
      const dots = renderColorDots(colors)
      const label = escapeHtml(manufacturerColorName)
      if (!dots && !label) return '<span style="color: var(--text-muted);">-</span>'
      if (!label) return dots
      if (!dots) return label
      return `${dots}<span>${label}</span>`
    }

    function getEventTypeStyle(type: string): string {
      const styles: Record<string, string> = {
        measurement: 'border-color: var(--accent-2); color: var(--accent-2);',
        adjustment: 'border-color: var(--accent); color: var(--accent);',
        consumption: 'border-color: var(--accent-3); color: var(--accent-3);',
        status_change: 'border-color: var(--accent-3); color: var(--accent-3);',
        move_location: 'border-color: var(--accent); color: var(--accent);',
      }
      return styles[type] || ''
    }

    function getPageNumbers(page: number, totalPages: number): (number | string)[] {
      if (totalPages <= 7) return Array.from({ length: totalPages }, (_, i) => i + 1)
      const pages = new Set([1, totalPages])
      for (let i = Math.max(2, page - 1); i <= Math.min(totalPages - 1, page + 1); i++) pages.add(i)
      const sorted = [...pages].sort((a, b) => (a as number) - (b as number))
      const result: (number | string)[] = []
      sorted.forEach((p, i) => {
        if (i > 0 && (p as number) - (sorted[i - 1] as number) > 1) result.push('\u2026')
        result.push(p)
      })
      return result
    }

    function buildPaginationHtml(total: number, page: number): string {
      const totalPages = Math.ceil(total / pageSize)
      if (totalPages <= 1 && total <= allowedPageSizes[0]) {
        return `<div style="font-size: 0.8rem; color: var(--text-muted);">${total} ${t('spoolLog.title')}</div>`
      }
      if (totalPages <= 1) {
        const pageSizeItems = allowedPageSizes.map(s => s === pageSize ? `<span class="page-current">${s}</span>` : `<a class="page-link page-size-link" data-size="${s}">${s}</a>`).join('')
        return `
          <div style="font-size: 0.8rem; color: var(--text-muted);">${total} ${t('spoolLog.title')}</div>
          <div></div>
          <div class="pagination-pages">
            <span style="color: var(--text-muted);">${t('common.perPage')}:</span>
            ${pageSizeItems}
          </div>
        `
      }
      const pageNumbers = getPageNumbers(page, totalPages)
      const pageItems = pageNumbers.map(p => {
        if (p === '\u2026') return `<span class="page-ellipsis">\u2026</span>`
        if (p === page) return `<span class="page-current">${p}</span>`
        return `<a class="page-link" data-page="${p}">${p}</a>`
      }).join('')
      const pageSizeItems = allowedPageSizes.map(s => s === pageSize ? `<span class="page-current">${s}</span>` : `<a class="page-link page-size-link" data-size="${s}">${s}</a>`).join('')
      return `
        <div style="font-size: 0.8rem; color: var(--text-muted);">
          ${t('common.showing')} ${((page - 1) * pageSize) + 1}-${Math.min(page * pageSize, total)} ${t('common.of')} ${total}
        </div>
        <div class="pagination-pages">
          <span style="color: var(--text-muted);">${t('common.page')}:</span>
          ${page > 1 ? `<a class="page-link page-prev">\u2039</a>` : ''}
          ${pageItems}
          ${page < totalPages ? `<a class="page-link page-next">\u203A</a>` : ''}
        </div>
        <div class="pagination-pages">
          <span style="color: var(--text-muted);">${t('common.perPage')}:</span>
          ${pageSizeItems}
        </div>
      `
    }

    function renderPagination(total: number, page: number) {
      const totalPages = Math.ceil(total / pageSize)
      const html = buildPaginationHtml(total, page)
      document.getElementById('pagination-top')!.innerHTML = html
      document.getElementById('pagination')!.innerHTML = html

      document.querySelectorAll('.pagination-container').forEach(container => {
        container.querySelectorAll('.page-link[data-page]').forEach(link => {
          link.addEventListener('click', () => {
            currentPage = parseInt((link as HTMLElement).dataset.page!, 10)
            loadEvents()
            window.scrollTo({ top: 0, behavior: 'smooth' })
          })
        })
        container.querySelector('.page-prev')?.addEventListener('click', () => {
          if (page > 1) {
            currentPage = page - 1
            loadEvents()
            window.scrollTo({ top: 0, behavior: 'smooth' })
          }
        })
        container.querySelector('.page-next')?.addEventListener('click', () => {
          if (page < totalPages) {
            currentPage = page + 1
            loadEvents()
            window.scrollTo({ top: 0, behavior: 'smooth' })
          }
        })
        container.querySelectorAll('.page-size-link').forEach(link => {
          link.addEventListener('click', () => {
            pageSize = parseInt((link as HTMLElement).dataset.size!, 10)
            localStorage.setItem('filaman-pagesize-spool-log', String(pageSize))
            currentPage = 1
            loadEvents()
          })
        })
      })
    }

    translatePage()
    loadEvents()
  </script>
</Layout>
