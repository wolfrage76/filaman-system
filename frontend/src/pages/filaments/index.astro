---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="FilaMan - Filaments">
  <style>
    .sortable { cursor: pointer; user-select: none; }
    .sortable:hover { background: var(--bg-hover); }
    .sortable::after { content: ' \2195'; opacity: 0.3; font-size: 0.8em; }
    .sortable.sort-asc::after { content: ' \2191'; opacity: 1; }
    .sortable.sort-desc::after { content: ' \2193'; opacity: 1; }
  </style>
  <style is:global>
    .pagination-container { display: flex; justify-content: space-between; align-items: center; }
    .pagination-pages { display: flex; gap: 4px; align-items: center; font-size: 0.8rem; }
    .pagination-pages a { color: var(--accent); cursor: pointer; padding: 2px 6px; text-decoration: none; border-radius: 3px; }
    .pagination-pages a:hover { text-decoration: underline; background: color-mix(in srgb, var(--accent) 10%, transparent); }
    .pagination-pages .page-current { font-weight: 700; color: var(--accent); padding: 2px 8px; background: color-mix(in srgb, var(--accent) 15%, transparent); border-radius: 3px; }
    .pagination-pages .page-ellipsis { color: var(--text-muted); padding: 0 2px; }
  </style>
  <style>
    .filter-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 16px;
      align-items: center;
    }
    .filter-bar .fm-input-search {
      flex: 1;
      min-width: 200px;
      max-width: 400px;
    }
    .bulk-checkbox { cursor: pointer; vertical-align: middle; }
    tr.bulk-selected { background: var(--bg-hover) !important; }
    .bulk-action-bar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
      background: var(--bg-elevated); border-top: 2px solid var(--accent);
      padding: 12px 24px; display: flex; align-items: center; gap: 12px;
      box-shadow: 0 -2px 8px rgba(0,0,0,0.15);
      transform: translateY(100%); transition: transform 0.2s ease;
    }
    .bulk-action-bar.visible { transform: translateY(0); }
    .bulk-action-bar .bulk-count { font-weight: 600; margin-right: 8px; white-space: nowrap; }
  </style>
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h1 style="font-size: 1.8rem; font-weight: 700; margin: 0; font-family: var(--font-serif);" data-i18n="filaments.title">Filaments</h1>
    <div style="display: flex; gap: 12px;">
      <a href="/filaments/colors" class="fm-btn fm-btn-outline" data-i18n="filaments.manageColors">
        Manage Colors
      </a>
      <a href="/filaments/new" class="fm-btn fm-btn-primary" data-i18n="filaments.addFilament">
        Add Filament
      </a>
    </div>
  </div>
  
  <div class="filter-bar">
    <input
      type="text"
      id="filter-search"
      class="fm-input fm-input-search"
      data-i18n-placeholder="filaments.searchPlaceholder"
      placeholder="Search designation, color, manufacturer..."
    />
    <select id="filter-manufacturer" class="fm-select" style="width: auto; min-width: 160px;">
      <option value="" data-i18n="filaments.allManufacturers">All Manufacturers</option>
    </select>
    <select id="filter-type" class="fm-select" style="width: auto; min-width: 140px;">
      <option value="" data-i18n="filaments.allTypes">All Types</option>
    </select>
    <select id="filter-color" class="fm-select" style="width: auto; min-width: 140px;">
      <option value="" data-i18n="filaments.allColors">All Colors</option>
    </select>
    <label style="display: flex; align-items: center; gap: 10px; font-size: 0.85rem; cursor: pointer; white-space: nowrap;">
      <input type="checkbox" id="filter-group" class="fm-checkbox" />
      <span data-i18n="filaments.groupByManufacturer">Group by Manufacturer</span>
    </label>
  </div>

  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
    <div class="pagination-container" id="pagination-top" style="flex: 1;"></div>
    <div class="col-picker-wrap">
      <button id="btn-columns" class="fm-btn fm-btn-outline" style="padding: 5px 10px; font-size: 0.8rem; display: flex; align-items: center; gap: 5px; white-space: nowrap;">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M15 3v18"/></svg>
        <span data-i18n="common.columns">Spalten</span>
      </button>
      <div id="columns-dropdown" class="col-picker-dropdown"></div>
    </div>
  </div>

  <div class="fm-card" style="padding: 0;">
    <table class="fm-table">
      <thead>
        <tr style="background: var(--bg-soft);">
          <th style="width: 40px; text-align: center;"><input type="checkbox" id="bulk-select-all" class="fm-checkbox bulk-checkbox" /></th>
          <th data-i18n="filaments.manufacturer" data-sort="manufacturer" class="sortable col-manufacturer">Manufacturer</th>
          <th data-i18n="filaments.type" data-sort="type" class="sortable col-type">Type</th>
          <th data-i18n="filaments.designation" data-sort="designation" class="sortable col-designation">Designation</th>
          <th data-i18n="filaments.colors" data-sort="colors" class="sortable col-colors">Colors</th>
          <th data-i18n="filaments.diameter" data-sort="diameter_mm" class="sortable col-diameter">Diameter</th>
          <th style="text-align: right;" data-i18n="filaments.spools" data-sort="spool_count" class="sortable col-spools">Spools</th>
          <th data-i18n="filaments.colPrice" data-sort="price" class="sortable col-price">Price</th>
          <th data-i18n="filaments.colMfrColor" data-sort="manufacturer_color_name" class="sortable col-mfr_color">Mfr. Color</th>
          <th data-i18n="filaments.colFinish" data-sort="finish_type" class="sortable col-finish">Finish</th>
          <th data-i18n="filaments.colSubgroup" data-sort="material_subgroup" class="sortable col-subgroup">Subgroup</th>
          <th data-i18n="filaments.colWeight" data-sort="raw_material_weight_g" class="sortable col-weight">Material Weight</th>
          <th data-i18n="filaments.colDensity" data-sort="density_g_cm3" class="sortable col-density">Density</th>
        </tr>
      </thead>
      <tbody id="filaments-table">
        <tr>
          <td colspan="13" style="text-align: center; color: var(--text-muted);" data-i18n="common.loading">Loading...</td>
        </tr>
      </tbody>
    </table>
  </div>
  
  <div class="pagination-container" id="pagination" style="margin-top: 16px;"></div>

  <!-- Bulk Action Bar -->
  <div id="bulk-action-bar" class="bulk-action-bar">
    <span class="bulk-count" id="bulk-count"></span>
    <button class="fm-btn fm-btn-outline" id="bulk-btn-price" data-i18n="filaments.bulkSetPrice">Set Price</button>
    <button class="fm-btn fm-btn-outline" id="bulk-btn-diameter" data-i18n="filaments.bulkSetDiameter">Set Diameter</button>
    <button class="fm-btn fm-btn-outline" id="bulk-btn-spool-weight" data-i18n="filaments.bulkSetSpoolWeight">Set Spool Weight</button>
    <button class="fm-btn fm-btn-outline" id="bulk-btn-density" data-i18n="filaments.bulkSetDensity">Set Density</button>
    <button class="fm-btn fm-btn-danger" id="bulk-btn-delete" data-i18n="filaments.bulkDelete">Delete</button>
  </div>

  <!-- Bulk Prompt Modal -->
  <div id="bulk-prompt-modal" class="fm-modal-overlay">
    <div class="fm-card" style="width: 100%; max-width: 24rem; margin: 0 1rem; padding: 24px;">
      <h3 id="bulk-prompt-title" style="font-size: 1.15rem; font-weight: 600; margin-bottom: 16px;"></h3>
      <div id="bulk-prompt-content" style="margin-bottom: 16px;"></div>
      <div style="display: flex; gap: 12px;">
        <button id="bulk-prompt-ok" class="fm-btn fm-btn-primary" data-i18n="common.confirm">Confirm</button>
        <button id="bulk-prompt-cancel" class="fm-btn fm-btn-outline" data-i18n="common.cancel">Cancel</button>
      </div>
    </div>
  </div>
  
  <script>
    import { t, initI18n, translatePage } from '../../lib/i18n'
    import { getAbortSignal, isAbortError } from '../../lib/abort'
    import { initColumnPicker, type ColumnGroup } from '../../lib/column-picker'
    import { initColumnReorder } from '../../lib/column-reorder'
    import { initColumnResize } from '../../lib/column-resize'
    import { formatPrice, getCurrency, initCurrency } from '../../lib/format'
    await initI18n()

    let currentPage = 1
    const allowedPageSizes = [25, 50, 100, 150, 200]
    let pageSize = (() => {
      try {
        const saved = parseInt(localStorage.getItem('filaman-pagesize-filaments') || '50', 10)
        return allowedPageSizes.includes(saved) ? saved : 50
      } catch { return 50 }
    })()
    let allFilaments: any[] = []
    let filteredFilaments: any[] = []
    let totalFilaments = 0
    let sortKey: string | null = null
    let sortDirection: 'asc' | 'desc' | null = null
    const selectedFilamentIds = new Set<number>()

    // Map frontend sort keys to backend sort_by values; empty string = client-side only (not server-sortable)
    const sortKeyMap: Record<string, string> = {
      'type': 'material_type',
      'colors': '', // aggregated (count) — client-side only
    }
    // Returns true if the given sort key cannot be sorted server-side and must be handled client-side over the full dataset
    function isClientOnlySort(key: string | null): boolean {
      if (!key) return false
      if (key.startsWith('cf_')) return true // custom fields are not server-sortable
      return sortKeyMap[key] === ''
    }

    // Restore sort state from localStorage
    try {
      const savedSort = localStorage.getItem('filaman-sort-filaments')
      if (savedSort) {
        const { key, direction } = JSON.parse(savedSort)
        if (key && (direction === 'asc' || direction === 'desc')) {
          sortKey = key
          sortDirection = direction
        }
      }
    } catch { /* ignore invalid data */ }
    // Restore page from localStorage
    try {
      const savedPage = localStorage.getItem('filaman-page-filaments')
      if (savedPage) {
        const p = parseInt(savedPage, 10)
        if (p > 0) currentPage = p
      }
    } catch { /* ignore invalid data */ }
    // Restore filter state from localStorage
    let savedFilterState: { manufacturer?: string, type?: string, color?: string, group?: boolean } | null = null
    try {
      const sf = localStorage.getItem('filaman-filters-filaments')
      if (sf) savedFilterState = JSON.parse(sf)
    } catch { /* ignore invalid data */ }
    let isInitialLoad = true
    let filterManufacturerId: string | null = null

    const urlParams = new URLSearchParams(window.location.search)
    filterManufacturerId = urlParams.get('manufacturer_id')

    // Debounce timer for search input
    let searchTimeout: ReturnType<typeof setTimeout> | null = null

    function getCsrfToken(): string {
      const match = document.cookie.match(/(?:^|;\s*)csrf_token=([^;]*)/)
      return match ? decodeURIComponent(match[1]) : ''
    }

    function setupSortableHeaders() {
      const thead = document.querySelector('.fm-table thead')
      if (!thead) return
      thead.addEventListener('click', (e) => {
        const th = (e.target as HTMLElement).closest('th[data-sort]') as HTMLElement | null
        if (!th) return
        const key = th.dataset.sort!
        if (sortKey === key) {
          if (sortDirection === 'asc') sortDirection = 'desc'
          else if (sortDirection === 'desc') { sortKey = null; sortDirection = null }
          else sortDirection = 'asc'
        } else {
          sortKey = key
          sortDirection = 'asc'
        }
        updateSortIndicators()
        loadFilaments()
        // Save sort state to localStorage
        if (sortKey && sortDirection) {
          localStorage.setItem('filaman-sort-filaments', JSON.stringify({ key: sortKey, direction: sortDirection }))
        } else {
          localStorage.removeItem('filaman-sort-filaments')
        }
      })
    }

    function updateSortIndicators() {
      document.querySelectorAll('th[data-sort]').forEach(th => {
        const key = (th as HTMLElement).dataset.sort!
        th.classList.remove('sort-asc', 'sort-desc')
        if (sortKey === key && sortDirection) {
          th.classList.add(sortDirection === 'asc' ? 'sort-asc' : 'sort-desc')
        }
      })
    }

    function getSortValue(item: any, key: string): any {
      if (key === 'manufacturer') return item.manufacturer?.name || ''
      if (key === 'type') return item.material_type || ''
      if (key === 'colors') {
        const first = item.colors?.[0]
        return (first?.display_name_override || first?.color?.name || '').toLowerCase()
      }
      if (key.startsWith('cf_')) {
        const cfKey = key.slice(3)
        return item.custom_fields?.[cfKey] ?? ''
      }
      return item[key]
    }

    function sortFilaments(filaments: any[]): any[] {
      if (!sortKey || !sortDirection) return filaments
      if (sortKey === 'spool_count') return filaments  // server-only sort: skip client re-sort
      const sortBy = sortKey
      return [...filaments].sort((a, b) => {
        const aVal = getSortValue(a, sortBy)
        const bVal = getSortValue(b, sortBy)
        let cmp = 0
        if (aVal == null && bVal == null) cmp = 0
        else if (aVal == null) cmp = 1
        else if (bVal == null) cmp = -1
        else if (typeof aVal === 'string') cmp = aVal.localeCompare(bVal)
        else cmp = aVal - bVal
        return sortDirection === 'asc' ? cmp : -cmp
      })
    }

    function getFilterValues() {
      const search = (document.getElementById('filter-search') as HTMLInputElement).value.toLowerCase().trim()
      const manufacturerId = (document.getElementById('filter-manufacturer') as HTMLSelectElement).value
      const type = (document.getElementById('filter-type') as HTMLSelectElement).value
      const color = (document.getElementById('filter-color') as HTMLSelectElement).value
      const groupBy = (document.getElementById('filter-group') as HTMLInputElement).checked
      return { search, manufacturerId, type, color, groupBy }
    }

    function filterFilaments(filaments: any[]): any[] {
      const { search, manufacturerId, type, color } = getFilterValues()

      return filaments.filter(f => {
        // Manufacturer filter
        if (manufacturerId && String(f.manufacturer_id) !== manufacturerId) return false

        // Type filter
        if (type && f.material_type !== type) return false

        // Color filter
        if (color) {
          const hasColor = f.colors?.some((fc: any) => {
            const c = fc.color
            return c && c.name === color
          })
          if (!hasColor) return false
        }

        // Text search across designation, manufacturer name, color names, type, manufacturer_color_name
        if (search) {
          const designation = (f.designation || '').toLowerCase()
          const manufacturerName = (f.manufacturer?.name || '').toLowerCase()
          const colorNames = (f.colors || []).map((fc: any) => {
            const parts: string[] = []
            if (fc.color?.name) parts.push(fc.color.name.toLowerCase())
            if (fc.display_name_override) parts.push(fc.display_name_override.toLowerCase())
            return parts.join(' ')
          }).join(' ')
          const typeName = (f.material_type || '').toLowerCase()
          const mfColorName = (f.manufacturer_color_name || '').toLowerCase()

          const haystack = `${designation} ${manufacturerName} ${colorNames} ${typeName} ${mfColorName}`
          if (!haystack.includes(search)) return false
        }

        return true
      })
    }

    function applyFiltersAndRender() {
      if (isInitialLoad) {
        isInitialLoad = false
      } else {
        currentPage = 1
      }
      localStorage.setItem('filaman-page-filaments', String(currentPage))
      loadFilaments()
    }

    function renderPage() {
      const { groupBy, color } = getFilterValues()
      // In needsAllData modes (color filter, groupBy, or client-only sort key), data is already fully loaded + filtered
      const needsAllData = !!color || groupBy || isClientOnlySort(sortKey)

      if (groupBy) {
        const sorted = sortFilaments(allFilaments)
        renderGroupedFilaments(sorted)
        document.getElementById('pagination-top')!.innerHTML = ''
        document.getElementById('pagination')!.innerHTML = `<div style="font-size: 0.85rem; color: var(--text-muted);">${t('filaments.filamentCount', { count: totalFilaments })}</div>`
      } else if (needsAllData) {
        // Color filter active (no groupBy): client-side pagination over filtered data
        const sorted = sortFilaments(allFilaments)
        const startIdx = (currentPage - 1) * pageSize
        const pageItems = sorted.slice(startIdx, startIdx + pageSize)
        renderFilaments(pageItems)
        renderPagination(totalFilaments, currentPage)
      } else {
        // Normal server-paginated mode
        renderFilaments(allFilaments)
        renderPagination(totalFilaments, currentPage)
      }
    }

    async function populateFilterDropdowns() {
      try {
        const signal = getAbortSignal()
        const [mfRes, typesRes, colorsRes] = await Promise.all([
          fetch('/api/v1/manufacturers?page=1&page_size=200', { credentials: 'include', signal }).catch(() => null),
          fetch('/api/v1/filaments/types', { credentials: 'include', signal }).catch(() => null),
          fetch('/api/v1/colors?page=1&page_size=200', { credentials: 'include', signal }).catch(() => null),
        ])

        // Manufacturers
        const mfSelect = document.getElementById('filter-manufacturer') as HTMLSelectElement
        if (mfRes?.ok) {
          const mfData = await mfRes.json()
          const mfs = (mfData.items || mfData) as any[]
          const sortedMfs = [...mfs].sort((a, b) => (a.name || '').localeCompare(b.name || ''))
          sortedMfs.forEach(m => {
            const opt = document.createElement('option')
            opt.value = String(m.id)
            opt.textContent = m.name
            mfSelect.appendChild(opt)
          })
        }
        if (filterManufacturerId) mfSelect.value = filterManufacturerId
        else if (savedFilterState?.manufacturer) mfSelect.value = savedFilterState.manufacturer

        // Types
        const typeSelect = document.getElementById('filter-type') as HTMLSelectElement
        if (typesRes?.ok) {
          const types = await typesRes.json() as string[]
          types.forEach(type => {
            const opt = document.createElement('option')
            opt.value = type
            opt.textContent = type
            typeSelect.appendChild(opt)
          })
        }
        if (savedFilterState?.type) typeSelect.value = savedFilterState.type

        // Colors
        const colorSelect = document.getElementById('filter-color') as HTMLSelectElement
        if (colorsRes?.ok) {
          const colorsData = await colorsRes.json()
          const colors = (colorsData.items || colorsData) as any[]
          const sortedColors = [...colors].sort((a, b) => (a.name || '').localeCompare(b.name || ''))
          sortedColors.forEach(c => {
            const opt = document.createElement('option')
            opt.value = c.name
            opt.textContent = c.name
            colorSelect.appendChild(opt)
          })
        }
        if (savedFilterState?.color) colorSelect.value = savedFilterState.color
      } catch (e) {
        if (isAbortError(e)) return
        console.error('Failed to populate filter dropdowns:', e)
      }
    }
    
    async function loadFilaments() {
      const { search, manufacturerId, type, color, groupBy } = getFilterValues()

      // Build query params for backend
      const params = new URLSearchParams()
      if (manufacturerId) params.set('manufacturer_id', manufacturerId)
      if (type) params.set('type', type)
      if (search) params.set('search', search)
      // sortKeyMap lives at module scope; '' means client-side only
      if (sortKey && sortDirection) {
        const backendSortKey = sortKeyMap[sortKey] ?? sortKey
        if (backendSortKey) {
          params.set('sort_by', backendSortKey)
          params.set('sort_order', sortDirection)
        }
      }

      // If color filter is active, groupBy is on, or sort key is client-only, we need ALL matching data
      const needsAllData = !!color || groupBy || isClientOnlySort(sortKey)

      try {
        const signal = getAbortSignal()

        if (needsAllData) {
          // Load all matching filaments for client-side color filter / group-by
          params.set('page', '1')
          params.set('page_size', '200')
          const response = await fetch(`/api/v1/filaments?${params}`, { credentials: 'include', signal })
          if (!response.ok) throw new Error('Failed to fetch filaments')
          const data = await response.json()
          allFilaments = data.items
          totalFilaments = data.total
          if (data.total > 200) {
            const totalPages = Math.ceil(data.total / 200)
            const pagePromises: Promise<any[]>[] = []
            for (let p = 2; p <= totalPages; p++) {
              const pParams = new URLSearchParams(params)
              pParams.set('page', String(p))
              pagePromises.push(
                fetch(`/api/v1/filaments?${pParams}`, { credentials: 'include', signal })
                  .then(res => res.ok ? res.json() : null)
                  .then(d => d ? d.items : [])
              )
            }
            const additionalPages = await Promise.all(pagePromises)
            additionalPages.forEach(pageItems => { allFilaments = allFilaments.concat(pageItems) })
          }
          // Apply client-side color filter if needed
          if (color) {
            allFilaments = allFilaments.filter(f => {
              return f.colors?.some((fc: any) => fc.color?.name === color)
            })
            totalFilaments = allFilaments.length
          }
        } else {
          // Normal mode: load only the current page from backend
          params.set('page', String(currentPage))
          params.set('page_size', String(pageSize))
          const response = await fetch(`/api/v1/filaments?${params}`, { credentials: 'include', signal })
          if (!response.ok) throw new Error('Failed to fetch filaments')
          const data = await response.json()
          allFilaments = data.items
          totalFilaments = data.total
          // Clamp currentPage if it exceeds available pages
          const maxPage = Math.ceil(totalFilaments / pageSize) || 1
          if (currentPage > maxPage) {
            currentPage = maxPage
            localStorage.setItem('filaman-page-filaments', String(currentPage))
            params.set('page', String(currentPage))
            const retry = await fetch(`/api/v1/filaments?${params}`, { credentials: 'include', signal })
            if (retry.ok) {
              const retryData = await retry.json()
              allFilaments = retryData.items
              totalFilaments = retryData.total
            }
          }
        }

        // Save filter state
        localStorage.setItem('filaman-page-filaments', String(currentPage))
        localStorage.setItem('filaman-filters-filaments', JSON.stringify({
          manufacturer: manufacturerId, type, color, group: groupBy
        }))

        renderPage()
      } catch (error) {
        if (isAbortError(error)) return
        console.error('Failed to load filaments:', error)
        document.getElementById('filaments-table')!.innerHTML = `
          <tr>
            <td colspan="13" style="text-align: center; color: var(--error-text);">${t('filaments.failedLoad')}</td>
          </tr>
        `
      }
    }
    
    function renderColorDots(colors: any[]): string {
      if (!colors || colors.length === 0) return '-'
      return colors.map(fc => {
        const c = fc.color
        if (!c) return ''
        return `<span title="${fc.display_name_override || c.name}" style="display: inline-block; width: 18px; height: 18px; border-radius: 50%; background: ${c.hex_code}; border: 2px solid var(--border); vertical-align: middle; margin-right: 2px;"></span>`
      }).join('')
    }

    function renderFilaments(filaments: any[]) {
      const tbody = document.getElementById('filaments-table')!
      
      if (filaments.length === 0) {
        const { search, manufacturerId, type, color } = getFilterValues()
        const hasFilters = search || manufacturerId || type || color
        tbody.innerHTML = `
          <tr>
            <td colspan="13" style="text-align: center; color: var(--text-muted);">
              ${hasFilters ? t('filaments.noResults') : `${t('filaments.noFilaments')} <a href="/filaments/new" style="color: var(--accent);">${t('filaments.addOne')}</a>.`}
            </td>
          </tr>
        `
        return
      }
      
      tbody.innerHTML = filaments.map(f => renderFilamentRow(f)).join('')
      filReorder.applyOrder()
      filResize.refreshColumns()
    }

    function renderFilamentRow(f: any): string {
      const currency = getCurrency()
      return `
        <tr class="${selectedFilamentIds.has(f.id) ? 'bulk-selected' : ''}" style="cursor: pointer;" onclick="window.location='/filaments/${f.id}'">
          <td style="padding: 12px; text-align: center;" onclick="event.stopPropagation()"><input type="checkbox" class="fm-checkbox bulk-checkbox" data-filament-id="${f.id}" ${selectedFilamentIds.has(f.id) ? 'checked' : ''} onchange="window.__toggleFilamentSelection(${f.id}, this.checked)" /></td>
          <td class="col-manufacturer" style="padding: 12px; color: var(--text-muted);">${f.manufacturer?.name || '-'}</td>
          <td class="col-type" style="padding: 12px; color: var(--text-muted);">${f.material_type}</td>
          <td class="col-designation" style="padding: 12px;">
            <div style="font-weight: 500;">${f.designation}</div>
            ${f.manufacturer_color_name ? `<div style="font-size: 0.85rem; color: var(--text-muted);">${f.manufacturer_color_name}</div>` : ''}
          </td>
          <td class="col-colors" style="padding: 12px;">${renderColorDots(f.colors)}</td>
          <td class="col-diameter" style="padding: 12px; color: var(--text-muted);">${f.diameter_mm}mm</td>
          <td class="col-spools" style="padding: 12px; text-align: right; color: var(--text-muted);">${f.spool_count ?? 0}</td>
          <td class="col-price" style="padding: 12px; font-family: monospace;">${f.price != null ? formatPrice(f.price, currency) : '-'}</td>
          <td class="col-mfr_color" style="padding: 12px; color: var(--text-muted);">${f.manufacturer_color_name || '-'}</td>
          <td class="col-finish" style="padding: 12px; color: var(--text-muted);">${f.finish_type || '-'}</td>
          <td class="col-subgroup" style="padding: 12px; color: var(--text-muted);">${f.material_subgroup || '-'}</td>
          <td class="col-weight" style="padding: 12px; font-family: monospace;">${f.raw_material_weight_g != null ? f.raw_material_weight_g + 'g' : '-'}</td>
          <td class="col-density" style="padding: 12px; font-family: monospace;">${f.density_g_cm3 != null ? f.density_g_cm3 + ' g/cm\u00B3' : '-'}</td>
          ${((window as any).__filamentExtraFields || []).map((ef: any) => {
            const val = f.custom_fields?.[ef.key]
            const display = ef.field_type === 'checkbox' ? (val ? '\u2713' : '\u2717') : (val ?? '-')
            return `<td class="col-cf_${ef.key}" style="padding: 12px; color: var(--text-muted);">${display}</td>`
          }).join('')}
        </tr>
      `
    }

    function renderGroupedFilaments(filaments: any[]) {
      const tbody = document.getElementById('filaments-table')!

      if (filaments.length === 0) {
        const { search, manufacturerId, type, color } = getFilterValues()
        const hasFilters = search || manufacturerId || type || color
        tbody.innerHTML = `
          <tr>
            <td colspan="13" style="text-align: center; color: var(--text-muted);">
              ${hasFilters ? t('filaments.noResults') : `${t('filaments.noFilaments')} <a href="/filaments/new" style="color: var(--accent);">${t('filaments.addOne')}</a>.`}
            </td>
          </tr>
        `
        return
      }

      // Group by manufacturer_id
      const groups = new Map<string, { label: string; filaments: any[] }>()

      filaments.forEach(f => {
        const groupKey = f.manufacturer_id ? String(f.manufacturer_id) : '_none'
        if (!groups.has(groupKey)) {
          groups.set(groupKey, {
            label: f.manufacturer?.name || '-',
            filaments: [],
          })
        }
        groups.get(groupKey)!.filaments.push(f)
      })

      let html = ''
      let groupIdx = 0
      groups.forEach((group, key) => {
        const gid = `group-${groupIdx}`
        html += `
          <tr data-group="${gid}" style="background: var(--group-header-bg); font-weight: 600; cursor: pointer; user-select: none; border-left: 3px solid var(--group-header-border);" onmouseenter="this.style.background='var(--group-header-bg-hover)'" onmouseleave="this.style.background='var(--group-header-bg)'">
            <td colspan="13" style="padding: 10px 12px; color: var(--text);">
              <span data-toggle="${gid}" style="display: inline-block;">&#9660; ${group.label}</span>
              <span style="margin-left: 12px; font-weight: 400; color: var(--text-muted); font-size: 0.85rem;">${t('filaments.filamentsInGroup', { count: group.filaments.length })}</span>
            </td>
          </tr>
        `
        group.filaments.forEach(f => {
          html += renderFilamentRow(f).replace('<tr ', `<tr data-group-row="${gid}" `)
        })
        groupIdx++
      })

      tbody.innerHTML = html
      filReorder.applyOrder()
      filResize.refreshColumns()

      // Wire up group toggle
      tbody.querySelectorAll('tr[data-group]').forEach(header => {
        header.addEventListener('click', () => {
          const gid = (header as HTMLElement).dataset.group!
          const toggle = header.querySelector(`span[data-toggle]`) as HTMLElement
          const rows = tbody.querySelectorAll(`tr[data-group-row="${gid}"]`)
          const isCollapsed = toggle.dataset.collapsed === 'true'
          
          if (isCollapsed) {
            toggle.dataset.collapsed = 'false'
            toggle.innerHTML = toggle.innerHTML.replace('&#9654;', '&#9660;').replace('\u25B6', '\u25BC')
            rows.forEach(r => (r as HTMLElement).style.display = '')
          } else {
            toggle.dataset.collapsed = 'true'
            toggle.innerHTML = toggle.innerHTML.replace('&#9660;', '&#9654;').replace('\u25BC', '\u25B6')
            rows.forEach(r => (r as HTMLElement).style.display = 'none')
          }
        })
      })
    }
    
    function getPageNumbers(page: number, totalPages: number): (number | string)[] {
      if (totalPages <= 7) return Array.from({ length: totalPages }, (_, i) => i + 1)
      const pages = new Set([1, totalPages])
      for (let i = Math.max(2, page - 1); i <= Math.min(totalPages - 1, page + 1); i++) pages.add(i)
      const sorted = [...pages].sort((a, b) => a - b)
      const result: (number | string)[] = []
      sorted.forEach((p, i) => {
        if (i > 0 && p - sorted[i - 1] > 1) result.push('\u2026')
        result.push(p)
      })
      return result
    }

    function buildPaginationHtml(total: number, page: number): string {
      const totalPages = Math.ceil(total / pageSize)
      if (totalPages <= 1) {
        const pageSizeItems = allowedPageSizes.map(s => s === pageSize ? `<span class="page-current">${s}</span>` : `<a class="page-link page-size-link" data-size="${s}">${s}</a>`).join('')
        return `
          <div style="font-size: 0.8rem; color: var(--text-muted);">${t('filaments.filamentCount', { count: total })}</div>
          <div></div>
          <div class="pagination-pages">
            <span style="color: var(--text-muted);">${t('common.perPage')}:</span>
            ${pageSizeItems}
          </div>
        `
      }
      const pageNumbers = getPageNumbers(page, totalPages)
      const pageItems = pageNumbers.map(p => {
        if (p === '\u2026') return `<span class="page-ellipsis">\u2026</span>`
        if (p === page) return `<span class="page-current">${p}</span>`
        return `<a class="page-link" data-page="${p}">${p}</a>`
      }).join('')
      const pageSizeItems = allowedPageSizes.map(s => s === pageSize ? `<span class="page-current">${s}</span>` : `<a class="page-link page-size-link" data-size="${s}">${s}</a>`).join('')
      return `
        <div style="font-size: 0.8rem; color: var(--text-muted);">
          ${t('common.showing')} ${((page - 1) * pageSize) + 1}-${Math.min(page * pageSize, total)} ${t('common.of')} ${total}
        </div>
        <div class="pagination-pages">
          <span style="color: var(--text-muted);">${t('common.page')}:</span>
          ${page > 1 ? `<a class="page-link page-prev">\u2039</a>` : ''}
          ${pageItems}
          ${page < totalPages ? `<a class="page-link page-next">\u203A</a>` : ''}
        </div>
        <div class="pagination-pages">
          <span style="color: var(--text-muted);">${t('common.perPage')}:</span>
          ${pageSizeItems}
        </div>
      `
    }

    function renderPagination(total: number, page: number) {
      const totalPages = Math.ceil(total / pageSize)
      const html = buildPaginationHtml(total, page)
      document.getElementById('pagination-top')!.innerHTML = html
      document.getElementById('pagination')!.innerHTML = html

      document.querySelectorAll('.pagination-container').forEach(container => {
        container.querySelectorAll('.page-link[data-page]').forEach(link => {
          link.addEventListener('click', () => {
            currentPage = parseInt((link as HTMLElement).dataset.page!, 10)
            localStorage.setItem('filaman-page-filaments', String(currentPage))
            loadFilaments()
          })
        })
        container.querySelector('.page-prev')?.addEventListener('click', () => {
          if (page > 1) {
            currentPage = page - 1
            localStorage.setItem('filaman-page-filaments', String(currentPage))
            loadFilaments()
          }
        })
        container.querySelector('.page-next')?.addEventListener('click', () => {
          if (page < totalPages) {
            currentPage = page + 1
            localStorage.setItem('filaman-page-filaments', String(currentPage))
            loadFilaments()
          }
        })
        container.querySelectorAll('.page-size-link').forEach(link => {
          link.addEventListener('click', () => {
            const newSize = parseInt((link as HTMLElement).dataset.size!, 10)
            if (allowedPageSizes.includes(newSize)) {
              pageSize = newSize
              localStorage.setItem('filaman-pagesize-filaments', String(newSize))
              currentPage = 1
              localStorage.setItem('filaman-page-filaments', '1')
              loadFilaments()
            }
          })
        })
      })
    }

    // Wire up filter events
    document.getElementById('filter-search')?.addEventListener('input', () => {
      if (searchTimeout) clearTimeout(searchTimeout)
      searchTimeout = setTimeout(() => applyFiltersAndRender(), 250)
    })
    document.getElementById('filter-manufacturer')?.addEventListener('change', () => applyFiltersAndRender())
    document.getElementById('filter-type')?.addEventListener('change', () => applyFiltersAndRender())
    document.getElementById('filter-color')?.addEventListener('change', () => applyFiltersAndRender())
    document.getElementById('filter-group')?.addEventListener('change', () => applyFiltersAndRender())
    
    // ── Column Visibility ──────────────────────────────────────────────
    const filColumnGroups: ColumnGroup[] = [
      {
        heading: t('common.columnsStandard'),
        columns: [
          { key: 'manufacturer', label: t('filaments.manufacturer') },
          { key: 'type', label: t('filaments.type') },
          { key: 'colors', label: t('filaments.colors') },
          { key: 'diameter', label: t('filaments.diameter') },
          { key: 'spools', label: t('filaments.spools') },
        ],
      },
      {
        heading: t('common.columnsExtended'),
        columns: [
          { key: 'price', label: t('filaments.colPrice') },
          { key: 'mfr_color', label: t('filaments.colMfrColor') },
          { key: 'finish', label: t('filaments.colFinish') },
          { key: 'subgroup', label: t('filaments.colSubgroup') },
          { key: 'weight', label: t('filaments.colWeight') },
          { key: 'density', label: t('filaments.colDensity') },
        ],
      },
    ]
    const filPicker = initColumnPicker({
      storageKey: 'filaman-columns-filaments',
      defaultVisible: ['manufacturer', 'type', 'colors', 'diameter', 'spools'],
      groups: filColumnGroups,
      btnId: 'btn-columns',
      dropdownId: 'columns-dropdown',
      orderStorageKey: 'filaman-column-order-filaments',
      widthsStorageKey: 'filaman-column-widths-filaments',
      resetLabel: t('common.columnsReset'),
      onReset: () => filReorder.resetOrder(),
      onResetWidths: () => filResize.resetWidths(),
    })

    const filReorder = initColumnReorder({
      tableSelector: '.fm-table',
      storageKey: 'filaman-column-order-filaments',
    })
    const filResize = initColumnResize({
      tableSelector: '.fm-table',
      storageKey: 'filaman-column-widths-filaments',
    })

    // Load SystemExtraFields for filaments and add as dynamic column group
    async function loadFilamentExtraFieldColumns() {
      try {
        const res = await fetch('/api/v1/system-extra-fields?target_type=filament', { credentials: 'include', signal: getAbortSignal() })
        if (!res.ok) return
        const fields: any[] = await res.json()
        if (fields.length === 0) return
        const extraGroup: ColumnGroup = {
          heading: t('common.columnsExtraFields'),
          columns: fields.map(f => ({ key: `cf_${f.key}`, label: f.label })),
        }
        filPicker.updateGroups([...filColumnGroups, extraGroup])
        // Add dynamic <th> headers for extra fields
        const headerRow = document.querySelector('.fm-table thead tr')
        if (headerRow) {
          fields.forEach(f => {
            const th = document.createElement('th')
            th.className = `sortable col-cf_${f.key}`
            th.dataset.sort = `cf_${f.key}`
            th.textContent = f.label
            headerRow.appendChild(th)
          })
        }
        // Store fields for renderFilamentRow access
        ;(window as any).__filamentExtraFields = fields
        // Refresh column reorder to include new extra field columns
        filReorder.refreshColumns()
        filResize.refreshColumns()
      } catch (e) {
        if (isAbortError(e)) return
        console.error('Failed to load filament extra field columns:', e)
      }
    }
    // ── End Column Visibility ──────────────────────────────────────────

    setupSortableHeaders()
    if (sortKey && sortDirection) updateSortIndicators()
    // Restore group checkbox from saved state
    if (savedFilterState?.group) {
      (document.getElementById('filter-group') as HTMLInputElement).checked = true
    }
    Promise.all([initCurrency(), loadFilamentExtraFieldColumns(), populateFilterDropdowns()]).then(() => loadFilaments())
      .then(() => {
        // Refresh column utilities after first render to ensure handles are attached
        filReorder.refreshColumns()
        filResize.refreshColumns()
      })

    // Live-Update via SSE: Filamente automatisch neu laden
    let _filamentsReloadTimer: ReturnType<typeof setTimeout> | null = null
    window.addEventListener('filaman:data-changed', (e: Event) => {
      const { event } = (e as CustomEvent).detail ?? {}
      if (event === 'filaments_changed' || event === 'manufacturers_changed') {
        if (_filamentsReloadTimer) clearTimeout(_filamentsReloadTimer)
        _filamentsReloadTimer = setTimeout(() => loadFilaments(), 300)
      }
    })

    // ── Bulk Selection & Actions ──────────────────────────────
    function updateBulkBar() {
      const bar = document.getElementById('bulk-action-bar')!
      const countEl = document.getElementById('bulk-count')!
      const selectAllCb = document.getElementById('bulk-select-all') as HTMLInputElement
      countEl.textContent = t('filaments.bulkSelected', { count: selectedFilamentIds.size })
      if (selectedFilamentIds.size > 0) {
        bar.classList.add('visible')
      } else {
        bar.classList.remove('visible')
      }
      // Update select-all checkbox state
      const visibleCheckboxes = document.querySelectorAll('#filaments-table input.bulk-checkbox[data-filament-id]')
      const visibleIds = Array.from(visibleCheckboxes).map(cb => Number((cb as HTMLInputElement).dataset.filamentId))
      const allChecked = visibleIds.length > 0 && visibleIds.every(id => selectedFilamentIds.has(id))
      const someChecked = visibleIds.some(id => selectedFilamentIds.has(id))
      selectAllCb.checked = allChecked
      selectAllCb.indeterminate = someChecked && !allChecked
    }

    function toggleFilamentSelection(id: number, checked: boolean) {
      if (checked) {
        selectedFilamentIds.add(id)
      } else {
        selectedFilamentIds.delete(id)
      }
      const row = document.querySelector(`#filaments-table input.bulk-checkbox[data-filament-id="${id}"]`)?.closest('tr')
      if (row) row.classList.toggle('bulk-selected', checked)
      updateBulkBar()
    }

    ;(window as any).__toggleFilamentSelection = toggleFilamentSelection

    // Select all checkbox
    document.getElementById('bulk-select-all')?.addEventListener('change', (e) => {
      const checked = (e.target as HTMLInputElement).checked
      const visibleCheckboxes = document.querySelectorAll('#filaments-table input.bulk-checkbox[data-filament-id]') as NodeListOf<HTMLInputElement>
      visibleCheckboxes.forEach(cb => {
        const id = Number(cb.dataset.filamentId)
        cb.checked = checked
        const row = cb.closest('tr')
        if (checked) {
          selectedFilamentIds.add(id)
          if (row) row.classList.add('bulk-selected')
        } else {
          selectedFilamentIds.delete(id)
          if (row) row.classList.remove('bulk-selected')
        }
      })
      updateBulkBar()
    })

    // Generic bulk prompt modal
    function openBulkPrompt(title: string, contentHtml: string): Promise<string | null> {
      const modal = document.getElementById('bulk-prompt-modal')!
      const titleEl = document.getElementById('bulk-prompt-title')!
      const contentEl = document.getElementById('bulk-prompt-content')!
      titleEl.textContent = title
      contentEl.innerHTML = contentHtml
      modal.classList.add('open')
      translatePage()
      return new Promise((resolve) => {
        function cleanup() {
          modal.classList.remove('open')
          okBtn.removeEventListener('click', onOk)
          cancelBtn.removeEventListener('click', onCancel)
          modal.removeEventListener('click', onOverlay)
        }
        function onOk() {
          const input = contentEl.querySelector('select, input') as HTMLInputElement | HTMLSelectElement | null
          cleanup()
          resolve(input ? input.value : '')
        }
        function onCancel() {
          cleanup()
          resolve(null)
        }
        function onOverlay(e: Event) {
          if (e.target === modal) { cleanup(); resolve(null) }
        }
        const okBtn = document.getElementById('bulk-prompt-ok')!
        const cancelBtn = document.getElementById('bulk-prompt-cancel')!
        okBtn.addEventListener('click', onOk)
        cancelBtn.addEventListener('click', onCancel)
        modal.addEventListener('click', onOverlay)
      })
    }

    async function bulkPatch(body: Record<string, unknown>) {
      const count = selectedFilamentIds.size
      try {
        const res = await fetch('/api/v1/filaments/bulk', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          credentials: 'include',
          body: JSON.stringify({ filament_ids: [...selectedFilamentIds], ...body }),
          signal: getAbortSignal(),
        })
        if (!res.ok) throw new Error('API error')
        await (window as any).__fmSuccess(t('filaments.bulkSuccess', { count }))
        selectedFilamentIds.clear()
        updateBulkBar()
        loadFilaments()
      } catch {
        (window as any).__fmAlert(t('filaments.bulkError'))
      }
    }

    // Delete
    document.getElementById('bulk-btn-delete')?.addEventListener('click', async () => {
      const count = selectedFilamentIds.size
      if (count === 0) return
      const result = await (window as any).__fmConfirm(
        t('filaments.bulkConfirmDelete', { count }),
        {
          title: t('filaments.bulkDelete'),
          okLabel: t('filaments.bulkDelete'),
          isDanger: true,
          checkbox: { label: t('filaments.bulkConfirmDeleteForce', { count }), checked: false }
        }
      )
      if (!result.confirmed) return
      try {
        const res = await fetch('/api/v1/filaments/bulk', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          credentials: 'include',
          body: JSON.stringify({ filament_ids: [...selectedFilamentIds], force: result.checked }),
          signal: getAbortSignal(),
        })
        if (!res.ok) throw new Error('API error')
        await (window as any).__fmSuccess(t('filaments.bulkDeleteSuccess', { count }))
        selectedFilamentIds.clear()
        updateBulkBar()
        loadFilaments()
      } catch {
        (window as any).__fmAlert(t('filaments.bulkError'))
      }
    })

    // Set Price
    document.getElementById('bulk-btn-price')?.addEventListener('click', async () => {
      if (selectedFilamentIds.size === 0) return
      const value = await openBulkPrompt(
        t('filaments.bulkSetPrice'),
        `<input type="number" class="fm-input" style="width: 100%;" min="0" step="0.01" value="0" />`
      )
      if (value === null) return
      await bulkPatch({ price: Number(value) })
    })

    // Set Diameter
    document.getElementById('bulk-btn-diameter')?.addEventListener('click', async () => {
      if (selectedFilamentIds.size === 0) return
      const value = await openBulkPrompt(
        t('filaments.bulkSetDiameter'),
        `<input type="number" class="fm-input" style="width: 100%;" min="0" step="0.01" value="1.75" />`
      )
      if (value === null) return
      await bulkPatch({ diameter_mm: Number(value) })
    })

    // Set Spool Weight
    document.getElementById('bulk-btn-spool-weight')?.addEventListener('click', async () => {
      if (selectedFilamentIds.size === 0) return
      const value = await openBulkPrompt(
        t('filaments.bulkSetSpoolWeight'),
        `<input type="number" class="fm-input" style="width: 100%;" min="0" step="0.1" value="0" />`
      )
      if (value === null) return
      await bulkPatch({ default_spool_weight_g: Number(value) })
    })

    // Set Density
    document.getElementById('bulk-btn-density')?.addEventListener('click', async () => {
      if (selectedFilamentIds.size === 0) return
      const value = await openBulkPrompt(
        t('filaments.bulkSetDensity'),
        `<input type="number" class="fm-input" style="width: 100%;" min="0" step="0.01" value="1.24" />`
      )
      if (value === null) return
      await bulkPatch({ density_g_cm3: Number(value) })
    })
  </script>
</Layout>
