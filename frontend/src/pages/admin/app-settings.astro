---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="FilaMan - App Settings">
  <style>
    .fm-toggle {
      position: relative;
      display: inline-block;
      width: 40px;
      height: 22px;
      flex-shrink: 0;
    }
    .fm-toggle input {
      opacity: 0;
      width: 0;
      height: 0;
    }
    .fm-toggle-slider {
      position: absolute;
      cursor: pointer;
      inset: 0;
      background: var(--border);
      border-radius: 999px;
      transition: background 0.2s;
    }
    .fm-toggle-slider::before {
      content: "";
      position: absolute;
      left: 3px;
      bottom: 3px;
      width: 16px;
      height: 16px;
      background: #fff;
      border-radius: 50%;
      transition: transform 0.2s;
    }
    .fm-toggle input:checked + .fm-toggle-slider {
      background: var(--accent);
    }
    .fm-toggle input:checked + .fm-toggle-slider::before {
      transform: translateX(18px);
    }
    .fm-toggle input:disabled + .fm-toggle-slider {
      opacity: 0.5;
      cursor: not-allowed;
    }
  </style>

  <!-- Responsive: stack cards on mobile -->
  <style>
    @media (max-width: 768px) {
      div[style*="grid-template-columns: repeat(2, 1fr)"] {
        grid-template-columns: 1fr !important;
      }
    }
  </style>

  <div style="margin-bottom: 24px;">
    <a href="/admin" style="color: var(--accent); text-decoration: none;">&larr; <span data-i18n="admin.backToAdmin">Back to Admin</span></a>
  </div>

  <h1 style="font-size: 1.8rem; font-weight: 700; margin: 0 0 8px; font-family: var(--font-serif);" data-i18n="admin.appSettingsTitle">App Settings</h1>
  <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0 0 24px;" data-i18n="admin.appSettingsSubtitle">Configure application settings</p>

  <form id="app-settings-form" style="display: grid; gap: 20px;">
    <!-- Grid container for the two cards -->
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; align-items: start;">
      <!-- Card 1: Login Disabled -->
      <div class="fm-card" style="padding: 20px;">
        <div style="display: flex; align-items: center; justify-content: space-between;">
          <div style="flex: 1;">
            <label data-i18n="admin.loginDisabled" style="font-weight: 500; display: block; margin-bottom: 4px;">Disable Login</label>
            <p style="font-size: 0.78rem; color: var(--text-muted); margin: 0;" data-i18n="admin.loginDisabledHint">When enabled, all endpoints are accessible without authentication</p>
          </div>
          <label class="fm-toggle">
            <input type="checkbox" id="login-disabled" />
            <span class="fm-toggle-slider"></span>
          </label>
        </div>
        <!-- Warning (moved inside card 1) -->
        <div id="login-warning" class="hidden" style="margin-top: 12px; padding: 12px 16px; border-radius: 8px; background: var(--error-bg); color: var(--error-text); font-size: 0.85rem; border: 1px solid var(--error-border);" data-i18n="admin.loginDisabledWarning">
          Warning: Disabling login removes all authentication. Only use in trusted environments!
        </div>
      </div>

      <!-- Card 2: Currency Selection -->
      <div class="fm-card" style="padding: 20px;">
        <label data-i18n="admin.appSettingsCurrencyLabel" style="font-weight: 500; display: block; margin-bottom: 4px;">Display Currency</label>
        <p style="font-size: 0.78rem; color: var(--text-muted); margin: 0 0 8px;" data-i18n="admin.appSettingsCurrencyDescription">Select the currency for displaying prices throughout the application</p>
        <select id="currency" class="fm-select">
          <option value="EUR">EUR — Euro</option>
          <option value="USD">USD — US Dollar</option>
          <option value="GBP">GBP — British Pound</option>
          <option value="CHF">CHF — Swiss Franc</option>
          <option value="CAD">CAD — Canadian Dollar</option>
          <option value="AUD">AUD — Australian Dollar</option>
          <option value="JPY">JPY — Japanese Yen</option>
          <option value="SEK">SEK — Swedish Krona</option>
          <option value="NOK">NOK — Norwegian Krone</option>
          <option value="DKK">DKK — Danish Krone</option>
          <option value="PLN">PLN — Polish Zloty</option>
          <option value="CZK">CZK — Czech Koruna</option>
        </select>
      </div>
    </div>

    <!-- RFID Extended Data Card (full width) -->
    <div class="fm-card" style="padding: 20px;">
      <h2 style="font-size: 1rem; font-weight: 600; margin: 0 0 16px;" data-i18n="admin.rfidSettingsTitle">RFID Tag Extended Data</h2>

      <!-- Toggle: Extended Data aktivieren -->
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
        <div style="flex: 1;">
          <label data-i18n="admin.rfidExtendedDataEnabled" style="font-weight: 500; display: block; margin-bottom: 4px;">Write extended data</label>
          <p style="font-size: 0.78rem; color: var(--text-muted); margin: 0;" data-i18n="admin.rfidExtendedDataEnabledHint">When enabled, additional filament data will be written to the RFID tag.</p>
        </div>
        <label class="fm-toggle">
          <input type="checkbox" id="rfid-extended-data-enabled" />
          <span class="fm-toggle-slider"></span>
        </label>
      </div>

      <!-- Protokoll-Auswahl -->
      <div id="rfid-protocol-section">
        <label data-i18n="admin.rfidProtocol" style="font-weight: 500; display: block; margin-bottom: 4px;">Protocol</label>
        <p style="font-size: 0.78rem; color: var(--text-muted); margin: 0 0 8px;" data-i18n="admin.rfidProtocolHint">Select the protocol for the extended tag data.</p>
        <select id="rfid-protocol" class="fm-select" style="max-width: 240px;">
          <option value="openspool" data-i18n="admin.rfidProtocolOpenspool">OpenSpool</option>
          <option value="filaman" data-i18n="admin.rfidProtocolFilaman">FilaMan</option>
        </select>
      </div>
    </div>

    <!-- Spool Weight Defaults Card (full width) -->
    <div class="fm-card" style="padding: 20px;">
      <h2 style="font-size: 1rem; font-weight: 600; margin: 0 0 4px;">Spool Weight Defaults</h2>
      <p style="font-size: 0.78rem; color: var(--text-muted); margin: 0 0 16px;">Global weight settings applied to all spools. Individual spools can override these on their Edit page.</p>

      <div>
        <label style="font-weight: 500; display: block; margin-bottom: 4px;" for="default-spool-core-weight">Default Core / Adapter Weight (g)</label>
        <p style="font-size: 0.78rem; color: var(--text-muted); margin: 0 0 8px;">
          Extra weight added on top of the empty spool weight when calculating remaining filament from a scale reading.
          Use this for cardboard inner tubes, spool holders, or scale adapters that are always present when weighing a spool.
          <br><strong>Formula:</strong> Remaining = Scale reading − Empty spool weight − Core/adapter weight.
          <br>Leave blank or set to 0 to disable.
        </p>
        <input
          type="number"
          id="default-spool-core-weight"
          step="1"
          min="0"
          placeholder="0 (disabled)"
          class="fm-input"
          style="max-width: 200px;"
        />
      </div>
    </div>

    <!-- Form message AND Save button OUTSIDE the cards, below the grid -->
    <div id="form-message" class="hidden" style="padding: 10px 14px; border-radius: 8px; font-size: 0.85rem;"></div>
    <button type="submit" id="save-btn" class="fm-btn fm-btn-primary" style="justify-self: start; padding: 10px 28px;" data-i18n="admin.appSettingsSave">Save</button>
  </form>

  <script>
    import { t, initI18n } from '../../lib/i18n'
    import { getAbortSignal, isAbortError } from '../../lib/abort'
    import { initCurrency } from '../../lib/format'

    async function init() {
      await initI18n()
      await initCurrency()

      function getCsrfToken(): string {
        const match = document.cookie.match(/(?:^|;\s*)csrf_token=([^;]*)/)
        return match ? decodeURIComponent(match[1]) : ''
      }

      const form = document.getElementById('app-settings-form') as HTMLFormElement
      const loginDisabledInput = document.getElementById('login-disabled') as HTMLInputElement
      const currencySelect = document.getElementById('currency') as HTMLSelectElement
      const warningDiv = document.getElementById('login-warning')!
      const formMessage = document.getElementById('form-message')!
      const saveBtn = document.getElementById('save-btn') as HTMLButtonElement
      const rfidExtendedDataInput = document.getElementById('rfid-extended-data-enabled') as HTMLInputElement
      const rfidProtocolSelect = document.getElementById('rfid-protocol') as HTMLSelectElement
      const rfidProtocolSection = document.getElementById('rfid-protocol-section')!
      const defaultSpoolCoreWeightInput = document.getElementById('default-spool-core-weight') as HTMLInputElement

      function showMessage(text: string, isError: boolean) {
        formMessage.textContent = text
        formMessage.className = isError ? 'fm-alert-error' : 'fm-alert-success'
        formMessage.classList.remove('hidden')
        setTimeout(() => formMessage.classList.add('hidden'), 5000)
      }

      // Toggle warning visibility
      loginDisabledInput.addEventListener('change', () => {
        warningDiv.classList.toggle('hidden', !loginDisabledInput.checked)
      })

      // Protokoll-Section nur sichtbar wenn Extended Data aktiv
      function updateRfidProtocolVisibility() {
        rfidProtocolSection.style.opacity = rfidExtendedDataInput.checked ? '1' : '0.4'
        rfidProtocolSelect.disabled = !rfidExtendedDataInput.checked
      }
      rfidExtendedDataInput.addEventListener('change', updateRfidProtocolVisibility)

      // Load settings
      try {
        const resp = await fetch('/api/v1/admin/app-settings/', { credentials: 'include', signal: getAbortSignal() })
        if (resp.ok) {
          const data = await resp.json()
          loginDisabledInput.checked = data.login_disabled
          currencySelect.value = data.currency || 'EUR'
          warningDiv.classList.toggle('hidden', !data.login_disabled)
          rfidExtendedDataInput.checked = data.rfid_extended_data_enabled ?? false
          rfidProtocolSelect.value = data.rfid_protocol || 'openspool'
          updateRfidProtocolVisibility()
          defaultSpoolCoreWeightInput.value = data.default_spool_core_weight_g != null ? String(data.default_spool_core_weight_g) : ''
        } else {
          showMessage(t('admin.appSettingsLoadFailed'), true)
        }
      } catch {
        showMessage(t('admin.appSettingsLoadFailed'), true)
      }

      // Save settings
      form.addEventListener('submit', async (e) => {
        e.preventDefault()

        saveBtn.disabled = true
        saveBtn.textContent = t('admin.appSettingsSaving')

        const rawCoreWeight = defaultSpoolCoreWeightInput.value.trim()
        const payload = {
          login_disabled: loginDisabledInput.checked,
          currency: currencySelect.value,
          rfid_extended_data_enabled: rfidExtendedDataInput.checked,
          rfid_protocol: rfidProtocolSelect.value,
          default_spool_core_weight_g: rawCoreWeight !== '' ? parseFloat(rawCoreWeight) : null,
        }

        try {
          const resp = await fetch('/api/v1/admin/app-settings/', {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': getCsrfToken(),
            },
            credentials: 'include',
            body: JSON.stringify(payload),
            signal: getAbortSignal(),
          })

          if (resp.ok) {
            localStorage.setItem('currency', currencySelect.value)
            showMessage(t('admin.appSettingsSaveSuccess'), false)
          } else {
            const err = await resp.json().catch(() => ({}))
            const msg =
              err.detail?.message ||
              err.message ||
              (typeof err.detail === 'string' ? err.detail : null) ||
              (Array.isArray(err.detail) ? err.detail[0]?.msg : null) ||
              t('admin.appSettingsSaveFailed')
            showMessage(msg, true)
          }
        } catch {
          showMessage(t('admin.appSettingsSaveFailed'), true)
        } finally {
          saveBtn.disabled = false
          saveBtn.textContent = t('admin.appSettingsSave')
        }
      })
    }

    init()
  </script>
</Layout>
